                    weapon_slowdown_gain[WEAPON_PROFILE_ONESHOT] = 999;
                    weapon_rotation_gain[WEAPON_PROFILE_ONESHOT] = 999;
                    weapon_snap_gain[WEAPON_PROFILE_ONESHOT] = 999;
                    weapon_resist_gain[WEAPON_PROFILE_ONESHOT] = 999;
                    weapon_autopull_gain[WEAPON_PROFILE_ONESHOT] = 999;
        
