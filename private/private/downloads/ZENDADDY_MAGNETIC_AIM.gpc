                    weapon_slowdown_gain[WEAPON_PROFILE_SNIPER] = 90;
                    weapon_rotation_gain[WEAPON_PROFILE_SNIPER] = 92;
                    weapon_snap_gain[WEAPON_PROFILE_SNIPER] = 110;
                    weapon_resist_gain[WEAPON_PROFILE_SNIPER] = 105;
                    weapon_autopull_gain[WEAPON_PROFILE_SNIPER] = 88;
        
                    weapon_ads_slowdown_gain[WEAPON_PROFILE_AR] = 100;
                    weapon_ads_slowdown_gain[WEAPON_PROFILE_ONESHOT] = 999;
                    weapon_ads_slowdown_gain[WEAPON_PROFILE_SNIPER] = 95;
        
                    weapon_ads_rotation_gain[WEAPON_PROFILE_AR] = 100;
                    weapon_ads_rotation_gain[WEAPON_PROFILE_ONESHOT] = 999;
                    weapon_ads_rotation_gain[WEAPON_PROFILE_SNIPER] = 92;
        
                    weapon_recoil_pitch_gain[WEAPON_PROFILE_AR] = 65;
                    weapon_recoil_pitch_gain[WEAPON_PROFILE_ONESHOT] = 1;
                    weapon_recoil_pitch_gain[WEAPON_PROFILE_SNIPER] = 18;
        
                    weapon_recoil_yaw_gain[WEAPON_PROFILE_AR] = 55;
                    weapon_recoil_yaw_gain[WEAPON_PROFILE_ONESHOT] = 1;
                    weapon_recoil_yaw_gain[WEAPON_PROFILE_SNIPER] = 12;
        
                    weapon_profile_current = WEAPON_PROFILE_AR;
                    weapon_profile_target = WEAPON_PROFILE_AR;
                    weapon_profile_active = WEAPON_PROFILE_AR;
                    weapon_profile_timer = 0;
                    weapon_profile_blend_pct = 0;
        
                    weapon_gain_core_mix = weapon_core_gain[WEAPON_PROFILE_AR];
                    weapon_gain_slowdown_mix = weapon_slowdown_gain[WEAPON_PROFILE_AR];
                    weapon_gain_rotation_mix = weapon_rotation_gain[WEAPON_PROFILE_AR];
                    weapon_gain_snap_mix = weapon_snap_gain[WEAPON_PROFILE_AR];
                    weapon_gain_resist_mix = weapon_resist_gain[WEAPON_PROFILE_AR];
                    weapon_gain_autopull_mix = weapon_autopull_gain[WEAPON_PROFILE_AR];
                    weapon_gain_ads_slowdown_mix = weapon_ads_slowdown_gain[WEAPON_PROFILE_AR];
                    weapon_gain_ads_rotation_mix = weapon_ads_rotation_gain[WEAPON_PROFILE_AR];
        
                    weapon_profile_confidence[WEAPON_PROFILE_AR] = 80;
                    weapon_profile_confidence[WEAPON_PROFILE_ONESHOT] = 25;
                    weapon_profile_confidence[WEAPON_PROFILE_SNIPER] = 25;
                }
        
                function apply_weapon_profile_scaling(){
                    assist_core_blend = clamp_i((assist_core_blend * weapon_gain_core_mix) / 100, 0, 100);
                    assist_slowdown_blend = clamp_i((assist_slowdown_blend * weapon_gain_slowdown_mix) / 100, 0, 100);
                    assist_rotation_blend = clamp_i((assist_rotation_blend * weapon_gain_rotation_mix) / 100, 0, 100);
                    assist_snap_blend = clamp_i((assist_snap_blend * weapon_gain_snap_mix) / 100, 0, 100);
                    aim_state_resistance_pct = clamp_i((aim_state_resistance_pct * weapon_gain_resist_mix) / 100, 40, 200);
                }
        
                // ============== RECOIL GAIN MODULATION ==============
                function apply_recoil_modulation(){
                    if(!ads || !shooting) return;
        
                    g_val = weapon_recoil_pitch_gain[weapon_profile_current]; // current_pitch_gain
                    g_temp = weapon_recoil_yaw_gain[weapon_profile_current]; // current_yaw_gain
        
                    // Vertical modulation (pitch) applied to Snap (vertical)
                    // Reduce snap strength to prevent aim assist fighting recoil.
                    // Max reduction is 50%. A gain of 48 means 48% of the assist is modulated/reduced
                    g_p = 100 - (g_val / 2); // vertical_mod_pct
                    if(g_p < 50) g_p = 50;
        
                    // Horizontal modulation (yaw)
                    g_fill = 100 - (g_temp / 2); // horizontal_mod_pct
                    if(g_fill < 70) g_fill = 70;
        
                    // Apply modulation to blended assist factors
                    // Horizontal modulation primarily affects Rotation (aim pull)
                    assist_rotation_blend = (assist_rotation_blend * g_fill) / 100;
        
                    // Vertical modulation primarily affects Snap (target acquisition/vertical pull)
                    assist_snap_blend = (assist_snap_blend * g_p) / 100;
        
                    // Core blend modulation (general sensitivity to control everything)
                    assist_core_blend = (assist_core_blend * g_p) / 100;
                }
        
                function update_weapon_profile(){
                    // g_val = the determined target profile index (replacement for local 'target')
                    g_val = weapon_profile_target;
                    if(g_val < 0) g_val = 0;
                    if(g_val >= WEAPON_PROFILE_COUNT) g_val = WEAPON_PROFILE_COUNT - 1;
        
                    // g_temp = active profile index (replacement for local 'active')
                    g_temp = weapon_profile_active;
                    if(g_temp < 0 || g_temp >= WEAPON_PROFILE_COUNT){
                        g_temp = g_val; // active = target
                        weapon_profile_active = g_temp;
                        weapon_profile_timer = 0;
                        weapon_profile_blend_pct = 0;
                    }
        
                    if(g_temp != g_val){ // active != target
                        weapon_profile_timer = weapon_profile_timer + delta;
                        if(weapon_profile_timer >= WEAPON_PROFILE_BLEND_TIME){
                            weapon_profile_active = g_val; // active = target
                            weapon_profile_current = g_val; // current = target
                            weapon_profile_timer = 0;
                            weapon_profile_blend_pct = 0;
                        } else {
                            weapon_profile_blend_pct = (weapon_profile_timer * 100) / WEAPON_PROFILE_BLEND_TIME;
                            if(weapon_profile_blend_pct > 100) weapon_profile_blend_pct = 100;
                        }
                    } else {
                        g_temp = weapon_profile_current;
                        weapon_profile_current = g_temp; // current = active
                        weapon_profile_timer = 0;
                        weapon_profile_blend_pct = 0;
                    }
        
                    g_p = weapon_profile_blend_pct; // blend_pct
                    g_fill = weapon_profile_active; // blend_from
                    g_expected = g_val; // blend_to
        
                    if(g_p > 0 && g_fill != g_expected){
                        weapon_gain_core_mix = lerp_pct(weapon_core_gain[g_fill], weapon_core_gain[g_expected], g_p);
                        weapon_gain_slowdown_mix = lerp_pct(weapon_slowdown_gain[g_fill], weapon_slowdown_gain[g_expected], g_p);
                        weapon_gain_rotation_mix = lerp_pct(weapon_rotation_gain[g_fill], weapon_rotation_gain[g_expected], g_p);
                        weapon_gain_snap_mix = lerp_pct(weapon_snap_gain[g_fill], weapon_snap_gain[g_expected], g_p);
                        weapon_gain_resist_mix = lerp_pct(weapon_resist_gain[g_fill], weapon_resist_gain[g_expected], g_p);
                        weapon_gain_autopull_mix = lerp_pct(weapon_autopull_gain[g_fill], weapon_autopull_gain[g_expected], g_p);
                        weapon_gain_ads_slowdown_mix = lerp_pct(weapon_ads_slowdown_gain[g_fill], weapon_ads_slowdown_gain[g_expected], g_p);
                        weapon_gain_ads_rotation_mix = lerp_pct(weapon_ads_rotation_gain[g_fill], weapon_ads_rotation_gain[g_expected], g_p);
                    } else {
                        g_temp = weapon_profile_current;
                        weapon_gain_core_mix = weapon_core_gain[g_temp];
                        weapon_gain_slowdown_mix = weapon_slowdown_gain[g_temp];
                        weapon_gain_rotation_mix = weapon_rotation_gain[g_temp];
                        weapon_gain_snap_mix = weapon_snap_gain[g_temp];
                        weapon_gain_resist_mix = weapon_resist_gain[g_temp];
                        weapon_gain_autopull_mix = weapon_autopull_gain[g_temp];
                        weapon_gain_ads_slowdown_mix = weapon_ads_slowdown_gain[g_temp];
                        weapon_gain_ads_rotation_mix = weapon_ads_rotation_gain[g_temp];
                    }
                }
        
                // ====================== INIT =======================
                // recompute slider-driven scaling at entry so init-time values respect ADS/hip state
                init {
                    load_sliders();  // CRITICAL: Load saved slider values FIRST!
                    apply_slider_scaling();
                    update_smoothness_scales();
                    splash_draw();  // Show logo IMMEDIATELY - prevent filename flash!
        
                    last_time = get_rtime();
                    set_led(LED_1,0); set_led(LED_2,0); set_led(LED_3,0); set_led(LED_4,1);  // LED_4 = AAN bij start
        
                    // Initialize SIN/COS lookup tables (GPC needs manual init)
                    sinLUT[0]=0; sinLUT[1]=38; sinLUT[2]=71; sinLUT[3]=92; sinLUT[4]=100; sinLUT[5]=92; sinLUT[6]=71; sinLUT[7]=38;
                    sinLUT[8]=0; sinLUT[9]=-38; sinLUT[10]=-71; sinLUT[11]=-92; sinLUT[12]=-100; sinLUT[13]=-92; sinLUT[14]=-71; sinLUT[15]=-38;
                    cosLUT[0]=100; cosLUT[1]=92; cosLUT[2]=71; cosLUT[3]=38; cosLUT[4]=0; cosLUT[5]=-38; cosLUT[6]=-71; cosLUT[7]=-92;
                    cosLUT[8]=-100; cosLUT[9]=-92; cosLUT[10]=-71; cosLUT[11]=-38; cosLUT[12]=0; cosLUT[13]=38; cosLUT[14]=71; cosLUT[15]=92;
        
                    // Initialize adaptive resistance
                    prev_rx = 0; prev_ry = 0;
                    input_velocity = 0;
                    resistance_active = 0;  // Start DISABLED - only activate inside bubble!
        
                    // V4.0 HIP/ADS SPLIT SLIDERS - 50 = neutral
                    // Removed redundant load_sliders() call - already done at line 1746
        
                    // Reset to defaults if sliders are at invalid values (0 or 100 = never properly initialized)
                    if((slider_hip_strength == 0 || slider_hip_strength == 100) && 
                       (slider_ads_strength == 0 || slider_ads_strength == 100)){
                        slider_hip_strength = 50; slider_hip_rotation = 50;
                        slider_ads_strength = 50; slider_ads_rotation = 50;
                        slider_smoothness = 50;
                        slider_close = 50; slider_medium = 50; slider_far = 50;
                        slider_curve_mode = 0;
                        update_curve_mode_state();
                        save_sliders();
                        apply_slider_scaling();  // Re-apply scaling with new values
                    }
        
                    micro_angle = 0;
                    micro_orbit_index = 0;
                    init_weapon_profiles();
                    assist_pipeline_reset();
                    waveform_seed(get_rtime());
                    rotation_gap_current = ROTATION_FREQ_SLOW_LOCK;
                    rotation_jitter_timer = 0;
                    rotation_jitter_interval = 0;
                    micro_orbit_timer = 0;
                    micro_orbit_variation_timer = 0;
                    micro_orbit_direction = 1;
        
                    // Phase F: Anti-Detection Jitter Initialization for Combo Timers
                    stealth_stealth_factor = 100; // Max stealth (max jitter)
                    idle_pull_interval = IDLE_AUTO_PULL_TIME + waveform_rand_signed(STEALTH_IDLE_JITTER);
                    movement_gate_interval = MOVEMENT_GATE_TIME + waveform_rand_signed(STEALTH_MOVEMENT_JITTER);
                    if(idle_pull_interval < 10) idle_pull_interval = 10; // Safety minimum
                    if(movement_gate_interval < 10) movement_gate_interval = 10; // Safety minimum
        
                    subsystem_flags = SUBSYSTEM_ALL;
                    hipfire_sticky_active = 0;
                    subsystem_flags = SUBSYSTEM_ALL;
                    hipfire_sticky_active = 0;
                    hipfire_sticky_timer = 0;
                    hipfire_sticky_weight = 0;
                    hipfire_resistance_bonus = 0;
        
                    bubble_zone_edges[0] = 20;   // v4.0: was 12 - ULTRA sticky!
                    bubble_zone_edges[1] = 40;   // v4.0: was 25 - vroegere activatie!
                    bubble_zone_edges[2] = 70;   // v4.0: was 40 - betere tracking!
                    bubble_zone_edges[3] = 110;  // v4.0: was 60 - langere range!
                    bubble_zone_edges[4] = 150;  // v4.0: was 90 - maximum coverage!
        
                    slowdown_zone_map[0] = SLOWDOWN_ULTRA;
                    slowdown_zone_map[1] = SLOWDOWN_CLOSE;
                    slowdown_zone_map[2] = SLOWDOWN_MEDIUM;
                    slowdown_zone_map[3] = SLOWDOWN_FAR;
                    slowdown_zone_map[4] = SLOWDOWN_OUTER;
        
                    rotation_pull_hip_map[0] = ROTATION_PULL_HIP_ULTRA;
                    rotation_pull_hip_map[1] = ROTATION_PULL_HIP_CLOSE;
                    rotation_pull_hip_map[2] = ROTATION_PULL_HIP_MEDIUM;
                    rotation_pull_hip_map[3] = ROTATION_PULL_HIP_FAR;
        
                    rotation_pull_ads_map[0] = ROTATION_PULL_ADS_ULTRA;
                    rotation_pull_ads_map[1] = ROTATION_PULL_ADS_CLOSE;
                    rotation_pull_ads_map[2] = ROTATION_PULL_ADS_MEDIUM;
                    rotation_pull_ads_map[3] = ROTATION_PULL_ADS_FAR;
                }
        
                function update_bubble_state(){
                    bubble_zone_raw = 0;
                    g_chars = 0;
                    while(g_chars < 5){
                        if(distance_pixels <= bubble_zone_edges[g_chars]){
                            bubble_zone_raw = g_chars + 1;
                            break;
                        }
                        g_chars = g_chars + 1;
                    }
        
                    if(bubble_zone_stable == 0){
                        bubble_zone_stable = bubble_zone_raw;
                    }
        
                    if(bubble_zone_stable > 0){
                        g_val = get_zone_slider_value(bubble_zone_stable);
                        g_temp = BUBBLE_ENABLE_MARGIN + ((g_val - 50) * BUBBLE_ENABLE_MARGIN) / 100;
                        if(g_temp < 1) g_temp = 1;
                        bubble_inner_radius = bubble_zone_edges[bubble_zone_stable - 1] - g_temp;
                        if(bubble_inner_radius < 0) bubble_inner_radius = 0;
        
                        g_total = BUBBLE_DISABLE_MARGIN + ((g_val - 50) * BUBBLE_DISABLE_MARGIN) / 100;
                        if(g_total < 1) g_total = 1;
                        bubble_outer_radius = bubble_zone_edges[bubble_zone_stable - 1] + g_total;
        
                        if(distance_pixels <= bubble_inner_radius){
                            bubble_zone_stable = bubble_zone_stable;  // Stay in current zone
                        } else if(distance_pixels >= bubble_outer_radius){
                            bubble_zone_stable = bubble_zone_raw;
                        }
                    } else {
                        bubble_inner_radius = 0;
                        bubble_outer_radius = 0;
                    }
        
                    if(bubble_zone_stable == 0 && bubble_zone_raw > 0){
                        bubble_zone_stable = bubble_zone_raw;
                    }
        
                    bubble_zone = bubble_zone_stable;
                }
        

// =============== MISSING FUNCTIONS (FIX COMPILATION ERRORS) =================
function compute_unreal_search_release(){
    g_val = 0;
    if(distance_pixels > (bubble_outer_radius + UE_SEARCH_RELEASE_MARGIN)){
        g_val = 100;
    } else if(freedom_release_active){
        g_val = 100;
    } else if(lock_confidence < 20 && input_velocity > 80){
        g_val = 75;
    }
    
    search_release_pct = smooth_gain(search_release_pct, g_val, 35);
    search_release_pct = clamp_i(search_release_pct, 0, 100);
    
    if(search_release_pct > 0){
        assist_release_pct = lerp_pct(100, UE_SEARCH_RELEASE_CORE, search_release_pct);
    } else {
        assist_release_pct = 100;
    }
    assist_release_pct = clamp_i(assist_release_pct, 0, 100);
}

function compute_unreal_search_suppress(){
    g_val = 0;
    if(lock_confidence < UE_SEARCH_SUPPRESS_LOCK_GATE){
        g_val = 60;
    } else if(aim_error_pixels > 25){
        g_val = 40;
    }
    
    search_suppress_pct = smooth_gain(search_suppress_pct, g_val, 28);
    search_suppress_pct = clamp_i(search_suppress_pct, 0, 100);
    
    if(search_suppress_pct > 0){
        assist_alignment_pct = lerp_pct(100, UE_SEARCH_SUPPRESS_CORE, search_suppress_pct);
        search_output_pct = lerp_pct(100, UE_SEARCH_SUPPRESS_OUTPUT, search_suppress_pct);
    } else {
        assist_alignment_pct = 100;
        search_output_pct = 100;
    }
    assist_alignment_pct = clamp_i(assist_alignment_pct, 0, 100);
    search_output_pct = clamp_i(search_output_pct, 0, 100);
}

function update_super_blends(){
    assist_core_blend = clamp_i(assist_core_blend, 0, 100);
    assist_slowdown_blend = clamp_i(assist_slowdown_blend, 0, 100);
    assist_rotation_blend = clamp_i(assist_rotation_blend, 0, 100);
    assist_snap_blend = clamp_i(assist_snap_blend, 0, 100);
    
    if(aim_state_resistance_pct > 220) aim_state_resistance_pct = 220;
    if(aim_state_resistance_pct < 40) aim_state_resistance_pct = 40;
}


// =============== MISSING FUNCTION DEFINITIONS =================

function update_alignment_scalers(){
    assist_alignment_pct = clamp_i(assist_alignment_pct, 0, 100);
    assist_release_pct = clamp_i(assist_release_pct, 0, 100);
    assist_scale_slowdown_pct = clamp_i(assist_scale_slowdown_pct, 0, 100);
    assist_scale_rotation_pct = clamp_i(assist_scale_rotation_pct, 0, 100);
    assist_scale_snap_pct = clamp_i(assist_scale_snap_pct, 0, 100);
}

function load_sliders(){
    slider_hip_strength = get_pvar(SPVAR_1, 0, 100, 50);
    slider_hip_rotation = get_pvar(SPVAR_2, 0, 100, 50);
    slider_ads_strength = get_pvar(SPVAR_3, 0, 100, 50);
    slider_ads_rotation = get_pvar(SPVAR_4, 0, 100, 50);
    slider_smoothness = get_pvar(SPVAR_5, 0, 100, 50);
    slider_close = get_pvar(SPVAR_6, 0, 100, 50);
    slider_medium = get_pvar(SPVAR_7, 0, 100, 50);
    slider_far = get_pvar(SPVAR_8, 0, 100, 50);
}

function save_sliders(){
    set_pvar(SPVAR_1, slider_hip_strength);
    set_pvar(SPVAR_2, slider_hip_rotation);
    set_pvar(SPVAR_3, slider_ads_strength);
    set_pvar(SPVAR_4, slider_ads_rotation);
    set_pvar(SPVAR_5, slider_smoothness);
    set_pvar(SPVAR_6, slider_close);
    set_pvar(SPVAR_7, slider_medium);
    set_pvar(SPVAR_8, slider_far);
}

function compute_alignment_suppression(){
    g_total = clamp_i(search_suppress_pct, 0, 100);
    if(g_total > 0){
        g_val = g_val - (g_total * 35) / 100;
    }
    
    g_chars = 100 - assist_release_pct;
    if(g_chars > 0){
        if(g_chars > 60) g_chars = 60;
        g_val = (g_chars * 20) / 100;
        g_total = g_total - g_val;
    }
    
    if(ads){
        g_expected = soft_step(input_velocity, UE_ALIGN_LOCK_INPUT_GATE, UE_ALIGN_LOCK_INPUT_GATE + 28);
    } else {
        g_expected = soft_step(input_velocity, UE_ALIGN_LOCK_INPUT_GATE - 2, UE_ALIGN_LOCK_INPUT_GATE + 24);
    }
    if(g_expected > 0){
        g_total = g_total - (g_expected * 60) / 100;
    }
    
    if(freedom_release_active || panic_triggered > 0){
        g_total = (g_total * 40) / 100;
    }
    
    if(g_total < 0) g_total = 0;
    if(g_total > 100) g_total = 100;
    
    align_suppress_pct = clamp_i(g_total, 0, 100);
    align_suppress_rotation_scale = lerp_pct(100, 42, align_suppress_pct);
    align_suppress_snap_scale = lerp_pct(100, 28, align_suppress_pct);
    align_suppress_pulse_scale = lerp_pct(100, 20, align_suppress_pct);
    align_suppress_bullet_scale = lerp_pct(100, 55, align_suppress_pct);
    align_suppress_micro_scale = lerp_pct(100, 45, align_suppress_pct);
    align_suppress_glide_scale = lerp_pct(100, 46, align_suppress_pct);
    align_suppress_slowdown_scale = lerp_pct(100, 32, align_suppress_pct);
    align_suppress_resist_scale = lerp_pct(100, 130, align_suppress_pct);
    
    if(align_suppress_pct >= 98){
        align_suppress_freeze = 1;
    } else {
        align_suppress_freeze = 0;
    }
}

                // ====================== MAIN =======================
                main {
                    delta = get_rtime() - last_time;
                    last_time = get_rtime();
                    shake_timer = shake_timer + delta;
        
                    // Update hyper-burst timer
                    if(hyper_burst_active){
                        hyper_burst_timer = hyper_burst_timer + delta;
                        if(hyper_burst_timer > HYPER_BURST_DURATION){
                            hyper_burst_active = 0;
                        }
                    }
        
                    if(jump_timer > 0){ jump_timer = jump_timer - delta; if(jump_timer < 0) jump_timer = 0; }
                    if(shot_timer > 0){ shot_timer = shot_timer - delta; if(shot_timer < 0) shot_timer = 0; }
                    if(build_lockout > 0){ build_lockout = build_lockout - delta; if(build_lockout < 0) build_lockout = 0; }
        
                    if(get_val(BTN_MENU_OPEN) && event_press(BTN_MENU_KEY)) {
                        menu_mode = TRUE;
                    }
        
                    if(menu_mode && event_press(BTN_MENU_CLOSE)) {
                        menu_mode = FALSE;
                        menu_close_delay = 200;  // 200ms delay to prevent Circle from triggering build
                        splash_draw();
                    }
        
                    // Count down close delay
                    if(menu_close_delay > 0){
                        menu_close_delay = menu_close_delay - delta;
                        if(menu_close_delay < 0) menu_close_delay = 0;
                    }
        
                    if(menu_mode) {
                        set_val(AXIS_RX, 0);
                        set_val(AXIS_RY, 0);
                        set_val(LX, 0);
                        set_val(LY, 0);
                        set_val(BTN_SHOOT, 0);
                        set_val(BTN_JUMP, 0);
        
                        if(event_press(BTN_RIGHT)) {
                            active_func = active_func + 1;
                            if(active_func > 8) active_func = 0;
                        }  // 9 menu items (0-8)
                        if(event_press(BTN_LEFT))  {
                            active_func = active_func - 1;
                            if(active_func < 0) active_func = 8;
                        }
        
                    // L3 PRESS = RESET CURRENT SLIDER TO 50 (NEUTRAL)
                    if(event_press(BTN_L3)) {
                        if(active_func==0) slider_hip_strength = 50;
                        if(active_func==1) slider_hip_rotation = 50;
                        if(active_func==2) slider_ads_strength = 50;
                        if(active_func==3) slider_ads_rotation = 50;
                        if(active_func==4) slider_smoothness = 50;
                        if(active_func==5) slider_close = 50;
                        if(active_func==6) slider_medium = 50;
                        if(active_func==7) slider_far = 50;
                        if(active_func==8) slider_curve_mode = 0;
                        save_sliders();
                        load_sliders();
                    }

                        if(event_press(BTN_UP)) {
                            if(active_func==0 && slider_hip_strength < 100) slider_hip_strength = slider_hip_strength + 10;
                            if(active_func==1 && slider_hip_rotation < 100) slider_hip_rotation = slider_hip_rotation + 10;
                            if(active_func==2 && slider_ads_strength < 100) slider_ads_strength = slider_ads_strength + 10;
                            if(active_func==3 && slider_ads_rotation < 100) slider_ads_rotation = slider_ads_rotation + 10;
                            if(active_func==4 && slider_smoothness < 100) slider_smoothness = slider_smoothness + 10;
                            if(active_func==5 && slider_close < 100) slider_close = slider_close + 10;
                            if(active_func==6 && slider_medium < 100) slider_medium = slider_medium + 10;
                            if(active_func==7 && slider_far < 100) slider_far = slider_far + 10;
                            if(active_func==8 && slider_curve_mode < 100){
                                slider_curve_mode = 100;
                                update_curve_mode_state();
                            }
                            save_sliders();
                            load_sliders();
                        }
                        if(event_press(BTN_DOWN)) {
                            if(active_func==0 && slider_hip_strength > 0) slider_hip_strength = slider_hip_strength - 10;
                            if(active_func==1 && slider_hip_rotation > 0) slider_hip_rotation = slider_hip_rotation - 10;
                            if(active_func==2 && slider_ads_strength > 0) slider_ads_strength = slider_ads_strength - 10;
                            if(active_func==3 && slider_ads_rotation > 0) slider_ads_rotation = slider_ads_rotation - 10;
                            if(active_func==4 && slider_smoothness > 0) slider_smoothness = slider_smoothness - 10;
                            if(active_func==5 && slider_close > 0) slider_close = slider_close - 10;
                            if(active_func==6 && slider_medium > 0) slider_medium = slider_medium - 10;
                            if(active_func==7 && slider_far > 0) slider_far = slider_far - 10;
                            if(active_func==8 && slider_curve_mode > 0){
                                slider_curve_mode = 0;
                                update_curve_mode_state();
                            }
                            save_sliders();
                            load_sliders();
                        }
        
                        render_menu();
                    }
                    else {
                        // Capture physical inputs before any script-driven overrides are applied
                        raw_rx = get_val(AXIS_RX);
                        raw_ry = get_val(AXIS_RY);
                        raw_lx = get_val(LX);
                        raw_ly = get_val(LY);
                        raw_r2_input = get_val(BTN_SHOOT);
                        raw_r2_physical = raw_r2_input;
                        ads = (get_val(BTN_ADS) > 30);
                        shooting = (raw_r2_input > 30);
        
                            if(event_press(BTN_RIGHT)){
                                toggle_subsystem(SUBSYSTEM_ROTATION);
                                // printf("Rotation subsystem=%d\n", (subsystem_flags & SUBSYSTEM_ROTATION) > 0);
                            }
                            if(event_press(BTN_UP)){
                                toggle_subsystem(SUBSYSTEM_SNAP);
                                // printf("Snap subsystem=%d\n", (subsystem_flags & SUBSYSTEM_SNAP) > 0);
                            }
                            if(event_press(BTN_DOWN)){
                                toggle_subsystem(SUBSYSTEM_RESISTANCE);
                                // printf("Resistance subsystem=%d\n", (subsystem_flags & SUBSYSTEM_RESISTANCE) > 0);
                            }
                            if((get_val(BTN_TOGGLE) && event_press(BTN_TOGGLE_R1)) ||
                            (get_val(BTN_TOGGLE_R1) && event_press(BTN_TOGGLE))){
                                if(aim_on){
                                    toggle_aim_off();
                                } else {
                                    aim_on = 1;
                                    assist_pipeline_reset();
                                    forced_fire_reset();
                                    set_led(LED_4,1);
                                }
                            }
                        }
        
                        if(!ads && (oneshot_mode || r2_assist_timer > 0 || magnet_capture_active)){
                            if(event_press(BTN_SHOOT) || (!hipfire_sticky_active && (r2_assist_timer > 0 || magnet_capture_active))){
                                hipfire_sticky_active = 1;
                                hipfire_sticky_timer = HIP_STICKY_WINDOW_MS;
                            }
                            if(hipfire_sticky_active){
                                if(shooting){
                                    hipfire_sticky_timer = HIP_STICKY_WINDOW_MS;
                                } else if(hipfire_sticky_timer > 0){
                                    hipfire_sticky_timer = hipfire_sticky_timer - delta;
                                    if(hipfire_sticky_timer < 0) hipfire_sticky_timer = 0;
                                }
                                g_val = abs(lx);
                                g_temp = abs(ly);
                                g_chars = abs(rx);
                                g_expected = abs(ry);
                                g_total = 0;
                                if(g_val >= HIP_STICKY_CANCEL_AXIS && g_chars >= HIP_STICKY_CANCEL_AXIS){
                                    g_total = 1;
                                } else if(g_temp >= HIP_STICKY_CANCEL_AXIS && g_expected >= HIP_STICKY_CANCEL_AXIS){
                                    g_total = 1;
                                } else if(input_velocity >= HIP_STICKY_CANCEL_VELOCITY){
                                    g_total = 1;
                                }
                                if(hipfire_sticky_timer == 0 || g_total){
                                    hipfire_sticky_active = 0;
                                }
                            }
                        } else {
                            if(!ads && r2_assist_timer > 0){
                                hipfire_sticky_active = 1;
                                hipfire_sticky_timer = HIP_STICKY_WINDOW_MS;
                            } else {
                                hipfire_sticky_active = 0;
                                hipfire_sticky_timer = 0;
                            }
                        }
        
        
                        // ===== VICTRIX TOUCHPAD MAPPING (L3 + OPTIONS = MAP) =====
                        // Victrix Pro BFG heeft geen touchpad - L3 + OPTIONS simuleert touchpad press
                        if(get_val(PS4_L3) && get_val(PS4_OPTIONS)){
                            set_val(PS4_TOUCH, 100);  // Simuleer touchpad press voor Fortnite map
                        }
        
                        // Build/Edit detection - SMART real-time detection!
                        // CIRCLE ingedrukt = build mode, release = weapon mode
                        // GATE: Skip detection if menu just closed (prevent Circle from triggering build)
                        if(get_val(BTN_BUILD) && menu_close_delay == 0){
                            // CIRCLE pressed = BUILD MODE ACTIVE
                            if(!build_mode){
                                // Net in build mode gegaan - stop aim assist + LOCKOUT
                                build_mode = 1;
                                combo_stop(UltimateMaster);
                                build_lockout = 100;
                            }
        
                            // Edit mode timer (hold > 200ms = edit)
                            edit_timer = edit_timer + delta;
                            if(edit_timer > 200 && !edit_mode){
                                edit_mode = 1;
                            }
                        }
                        else {
                            // CIRCLE released = WEAPON MODE ACTIVE
                            if(build_mode || edit_mode){
                                // Net uit build/edit - instant restart aim assist (ONLY if lockout expired!)
                                build_mode = 0;
                                edit_mode = 0;
                                edit_timer = 0;
                            }
                        }
        
                    // Aim assist actief tijdens ADS of schieten
                    if(aim_on && (ads || shooting)){
                        combo_run(UltimateMaster);
                        // ADS Spam removed - Logic Cleaned
                        if(forced_fire_override){
                            set_val(BTN_SHOOT, FORCED_FIRE_PRESS_VALUE);
                        }
                    } else if(!aim_on){
                        assist_pipeline_reset();
                    }
        
                        
                        // Drift compensation
                        if(abs(raw_lx) < 10 && abs(raw_ly) < 10 && !shooting){
                            drift_timer = drift_timer + 1;
        
                            if(drift_timer > 50){
                                if(abs(raw_rx) < 25 && abs(raw_rx) > 3){
                                    drift_x = raw_rx;
                                }
                                if(abs(raw_ry) < 25 && abs(raw_ry) > 3){
                                    drift_y = raw_ry;
                                }
                            }
                        }
                        else {
                            drift_timer = 0;
                        }
        
                        rx = raw_rx - drift_x;
                        ry = raw_ry - drift_y;
                        lx = raw_lx;
                        ly = raw_ly;
        
                        if(abs(rx) < DEADZONE_BASE) rx = 0;
                        if(abs(ry) < DEADZONE_BASE) ry = 0;
        
                        // Edit mode direct output
                        if(edit_mode){
                            set_val(AXIS_RX, rx);
                            set_val(AXIS_RY, ry);
                        }
        
                        // State detection
                        velocity_mag = abs(lx) + abs(ly);
        
                        // R2-TRIGGERED ASSIST: v4.7 ZERO DELAY - PRO FORTNITE!
                        if(shooting && !r2_was_pressed) {
                            // v4.7: INSTANT assist - GEEN DELAY! (weapon swap fix!)
                            r2_assist_timer = 220;  // v5.0: ULTRA actief - geen wachttijd!
                            r2_was_pressed = TRUE;
                            r2_hipfire_instant = 1;
                        }
                        else if(shooting) {
                            // Keep active while shooting
                            r2_assist_timer = 220;
                        }
                        else if(r2_was_pressed) {
                            // R2 just released - start fade-out
                            r2_assist_fade_timer = 280;  // v4.4: LANGERE fade! (was 150)
                            r2_was_pressed = FALSE;
                            r2_hipfire_instant = 0;
                        }
        
                        // Fade-out countdown
                        if(r2_assist_fade_timer > 0) {
                            r2_assist_fade_timer = r2_assist_fade_timer - delta;
                            if(r2_assist_fade_timer < 0) r2_assist_fade_timer = 0;
                        }
        
                        // Jump detection
                        if(event_press(BTN_JUMP)) {
                            jump_timer = 1200;
                            aerial_timer = 0;
                            fall_velocity = 0;
                            aerial_offset_y = 0;
                        }
        
                        if(jump_timer > 0 && get_val(BTN_JUMP) < 30){
                            jump_timer = 0;
                            aerial_timer = 0;
                            fall_velocity = 0;
                            aerial_offset_y = 0;
                        }
        
                        jumping = (jump_timer > 0);
                        if(jump_timer > (1200 - AERIAL_THRESHOLD)) aerial_mode = 1; else aerial_mode = 0;
        
                        // Weapon detection - VERBETERD voor one-shots!
                        if(event_press(BTN_SHOOT)){
                            // Bereken interval tussen shots
                            if(last_shot_time > 0){
                                shot_interval = get_rtime() - last_shot_time;
        
                                // Detecteer weapon type op basis van interval
                                if(shot_interval > WEAPON_SHOTGUN_TIME){
                                    oneshot_mode = 1;  // Shotgun
                                }
                                else if(shot_interval > WEAPON_SNIPER_TIME){
                                    oneshot_mode = 1;  // Sniper
                                }
                                else if(shot_interval < WEAPON_AR_TIME){
                                    oneshot_mode = 0;  // AR/SMG
                                }
                            }
        
                            last_shot_time = get_rtime();
        
                            // Sniper mode voor aerial
                        if(shot_timer > SNIPER_DELAY) sniper_mode = 1; else sniper_mode = 0;
                        shot_timer = 1500;
        
                        if(ai_confidence_pct >= AI_CONFIDENCE_SUPER_GATE || magnet_capture_active || (!ads && oneshot_mode && lock_confidence >= HIP_AUTOCORRECT_LOCK_GATE)){
                            bullet_correct_timer = AI_BULLET_CORRECT_WINDOW;
                            bullet_correct_strength = AI_BULLET_CORRECT_GAIN;
                            if(!ads && oneshot_mode){
                                bullet_correct_strength = (bullet_correct_strength * HIP_ONESHOT_SUPER_GAIN) / 100;
                                bullet_correct_timer = bullet_correct_timer + HIP_AUTOCORRECT_TIMER_BONUS;
                            }
                            g_val = ai_future_offset_x - pixel_offset_x + ballistic_travel_offset_x;
                            bullet_correct_target_x = clamp_i(g_val, -AI_PREDICT_CLAMP_X * 3, AI_PREDICT_CLAMP_X * 3);
                            g_temp = ai_future_offset_y - pixel_offset_y - ballistic_drop_offset;
                            bullet_correct_target_y = clamp_i(g_temp, -AI_PREDICT_CLAMP_Y * 3, AI_PREDICT_CLAMP_Y * 3);
                            if(distance_pixels > (BALLISTIC_RANGE_HARD_CAP * 3) / 4){
                                bullet_correct_timer = bullet_correct_timer + BALLISTIC_EXTRA_TIMER_FAR;
                                g_chars = AI_BULLET_CORRECT_WINDOW + BALLISTIC_EXTRA_TIMER_FAR;
                                if(bullet_correct_timer > g_chars) bullet_correct_timer = g_chars;
                            }
                            bullet_correct_offset_x = 0;
                            bullet_correct_offset_y = 0;
                        }
        
                    }
        
                        update_weapon_profile_detection();
                        update_forced_fire();
        
                        // FLICKSHOT DETECTION - instant max assist!
                        input_spike = abs(input_mag - last_input_mag);
                        last_input_mag = input_mag;  // Update for next frame
                        if(input_spike > FLICK_THRESHOLD && input_mag > 40){
                            flick_detected = 1;
                            // Reset na 150ms
                            if(delta > FLICK_WINDOW) flick_detected = 0;
                        }
        
                    if(bubble_zone_stable == 0){
                        bubble_zone_stable = bubble_zone_raw;
                    }
        
                    if(bubble_zone_stable > 0){
                        g_val = get_zone_slider_value(bubble_zone_stable);
                        g_temp = BUBBLE_ENABLE_MARGIN + ((g_val - 50) * BUBBLE_ENABLE_MARGIN) / 100;
                        if(g_temp < 1) g_temp = 1;
                        bubble_inner_radius = bubble_zone_edges[bubble_zone_stable - 1] - g_temp;
                        if(bubble_inner_radius < 0) bubble_inner_radius = 0;
        
                        g_total = BUBBLE_DISABLE_MARGIN + ((g_val - 50) * BUBBLE_DISABLE_MARGIN) / 100;
                        if(g_total < 1) g_total = 1;
                        bubble_outer_radius = bubble_zone_edges[bubble_zone_stable - 1] + g_total;
        
                        if(distance_pixels <= bubble_inner_radius){
                            bubble_zone_stable = bubble_zone_stable;  // Stay in current zone
                        } else if(distance_pixels >= bubble_outer_radius){
                            bubble_zone_stable = bubble_zone_raw;
                        }
                    } else {
                        bubble_inner_radius = 0;
                        bubble_outer_radius = 0;
                    }
        
                    if(bubble_zone_stable == 0 && bubble_zone_raw > 0){
                        bubble_zone_stable = bubble_zone_raw;
                    }
        
                    bubble_zone = bubble_zone_stable;
                }
        
                // ================ RANGE DETECTION ===================
                // CRITICAL: Use distance_pixels (screen-space) not input_mag (stick magnitude)!
                // input_mag is LOW when locked (stick centered), maar distance kan GROOT zijn!
                // Dit zorgt dat long/med sliders correct werken op alle ranges!
                function get_current_range(){
                    // Range based on screen-space distance (pixels from center)
                    if(distance_pixels <= 25){
                        current_range = 0;  // SHORT: 0-25px (close combat)
                    }
                    else if(distance_pixels <= 50){
                        current_range = 1;  // MEDIUM: 25-50px (mid-range)
                    }
                    else {
                        current_range = 2;  // LONG: 50+px (long-range)
                    }
                }
        
                // =============== TARGET LOCK DETECTION ==============
                // HYSTERESIS toegevoegd: voorkomt oscillatie!
                function update_target_lock(){
                    delta_rx = abs(rx - last_rx);
                        delta_ry = abs(ry - last_ry);
                    tk_combined_delta = delta_rx + delta_ry;
        
        
                    input_mag = abs(rx) + abs(ry);
                    aim_error_pixels = distance_pixels;
                    distance_delta = distance_pixels - last_distance_pixels;
        
                    aim_error_avg = smooth_gain(aim_error_avg, aim_error_pixels, 20);
                    aim_error_trend = smooth_gain(aim_error_trend, distance_delta, 20);
                    velocity_avg = smooth_gain(velocity_avg, input_mag, 20);
        
                    tk_proximity_score = 100 - soft_step(aim_error_pixels, BUBBLE_ULTRA_CLOSE, BUBBLE_OUTER);
                    if(tk_proximity_score < 0) tk_proximity_score = 0;
                    assist_last_proximity_score = tk_proximity_score;
                    tk_stability_score = 100 - soft_step(tk_combined_delta, 8, 45);
                    if(tk_stability_score < 0) tk_stability_score = 0;
                    tk_trend_score = 100 - soft_step(abs(distance_delta), 5, 35);
                    if(tk_trend_score < 0) tk_trend_score = 0;
                    tk_timer_score = soft_step(lock_timer, LOCK_TIMER_MIN, LOCK_TIMER_STABLE);
        
                    aim_error_variance = smooth_gain(aim_error_variance, abs(aim_error_pixels - aim_error_avg), 35);
        
                    tk_raw_lock_conf = (tk_proximity_score * 45 + tk_stability_score * 25 + tk_trend_score * 15 + tk_timer_score * 15) / 100;
                    tk_raw_lock_conf = clamp_i(tk_raw_lock_conf, 0, 100);
        
                    if(oneshot_mode || flick_detected || shooting){
                        if(tk_raw_lock_conf < 80) tk_raw_lock_conf = 80;
                    }
        
                    g_temp = 30;
                    if(target_locked) g_temp = 12;
                    lock_confidence = smooth_gain(lock_confidence, tk_raw_lock_conf, g_temp);
        
                    lock_confidence = clamp_i(lock_confidence, 0, 100);
        
                    if(lock_confidence >= 55){
                        if(!target_locked){
                            target_locked = 1;
                            lock_timer = 0;
                            if(oneshot_mode || flick_detected){
                                hyper_burst_active = 1;
                                hyper_burst_timer = 0;
                            }
                        } else {
                            if(lock_timer < LOCK_TIMER_MAX) lock_timer = lock_timer + 1;
                        }
                    }
                    else if(lock_confidence <= 15 && !auto_aim_overrun_active && bullet_correct_gain == 0 && !magnet_capture_active){  // v4.4: LAGER voor langere lock persistence! (was 20)
                        target_locked = 0;
                        lock_timer = 0;
                        hyper_burst_active = 0;
                    }
        
                    if(target_locked){
                        if(lock_confidence >= 90){
                            lock_strength = 100;
                        }
                        else if(lock_confidence >= 70){
                            lock_strength = 85 + ((lock_confidence - 70) * 15) / 20;
                        }
                        else {
                            lock_strength = 70 + ((lock_confidence - 55) * 15) / 15;
                        }
                        lock_strength = clamp_i(lock_strength, 60, 100);
                    }
                    else {
                        lock_strength = clamp_i(lock_confidence, 0, 75);
                    }
        
                    last_rx = rx;
                    last_ry = ry;
                    last_distance_pixels = distance_pixels;
                }
        
                function update_magnet_capture(){
                    g_val = 0;
                    if(build_mode || edit_mode){
                        g_val = 0;
                    } else {
                    if(distance_pixels > 0 && distance_pixels <= MAGNET_CAPTURE_DISTANCE){
                        g_temp = input_velocity;
                        g_expected = MAGNET_CAPTURE_INPUT_MAX;
                        if(ads){
                            g_expected = g_expected + 24 + (slider_ads_strength / 2);
                            if(ads_lock_steady_active){
                                g_expected = g_expected + 18;
                            }
                            if(g_expected > MAGNET_CAPTURE_INPUT_MAX + 64){
                                g_expected = MAGNET_CAPTURE_INPUT_MAX + 64;
                            }
                        }
                        if(g_temp <= g_expected || target_locked){
                            if(ads || shooting || r2_assist_timer > 0 || hipfire_sticky_active || hipfire_engaged){
                                g_val = 1;
                            }
                        }
                        if(!g_val){
                            // New proactive hipfire magnet capture: based on proximity and low input velocity
                            if(!ads && !shooting && distance_pixels <= PRE_AIM_STICKY_ENGAGE_PX + 10 && input_velocity <= HIP_FAST_INPUT_GATE + 5){
                                g_val = 1;
                            }
                        }
                        if(!g_val){
                            g_chars = MAGNET_CAPTURE_INPUT_MAX + MAGNET_CAPTURE_ASSIST_INPUT_PAD;
                            if(ads){
                                g_chars = g_chars + 18;
                            }
                            if(g_temp <= g_chars){
                                if(ai_confidence_pct >= MAGNET_CAPTURE_ASSIST_GATE || assist_core_blend >= MAGNET_CAPTURE_CORE_GATE){
                                    g_val = 1;
                                }
                            }
                        }
                        if(!g_val){
                            if(ads && g_temp <= g_expected + 24){
                                if(magnet_capture_active || ads_lock_steady_active || bullet_correct_gain > 0){
                                    g_val = 1;
                                }
                            } else if(auto_aim_overrun_active || bullet_correct_gain > 0){
                                g_val = 1;
                            } else if(ai_confidence_pct >= MAGNET_CAPTURE_ASSIST_GATE && lock_confidence >= MAGNET_CAPTURE_LOCK_MIN){
                                g_val = 1;
                            }
                        }
                        }
                    }
        
                    if(g_val){
                        magnet_capture_hold_timer = MAGNET_CAPTURE_PERSIST_MS;
                        if(!ads){
                            magnet_capture_hold_timer = magnet_capture_hold_timer + UE_HIP_CAPTURE_PERSIST_EXTRA + PRE_AIM_STICKY_PERSIST_MS; // Add pre-aim persistence
                        }
                        magnet_capture_strength = smooth_gain(magnet_capture_strength, 100, MAGNET_CAPTURE_RAMP_GAIN);
                    } else {
                        if(magnet_capture_hold_timer > 0){
                            magnet_capture_hold_timer = magnet_capture_hold_timer - delta;
                            if(magnet_capture_hold_timer < 0) magnet_capture_hold_timer = 0;
                        }
                        if(magnet_capture_hold_timer > 0){
                            magnet_capture_strength = smooth_gain(magnet_capture_strength, 65, MAGNET_CAPTURE_DECAY_GAIN);
                        } else {
                            magnet_capture_strength = smooth_gain(magnet_capture_strength, 0, MAGNET_CAPTURE_DECAY_GAIN);
                        }
                    }
        
                    if(magnet_capture_strength < 0) magnet_capture_strength = 0;
                    if(magnet_capture_strength > 100) magnet_capture_strength = 100;
        
                    magnet_capture_active = (magnet_capture_strength > 5);
        
                    if(magnet_capture_active){
                        magnet_capture_lock_boost = (magnet_capture_strength * MAGNET_CAPTURE_STRENGTH_MAX) / 100;
                        if(ads){
                            g_val = slider_ads_strength;
                            magnet_capture_lock_boost = magnet_capture_lock_boost + (g_val / 2) + 8;
                        }
                        if(magnet_capture_lock_boost < MAGNET_CAPTURE_LOCK_MIN){
                            magnet_capture_lock_boost = MAGNET_CAPTURE_LOCK_MIN;
                        }
                        if(ads && magnet_capture_lock_boost < 96){
                            magnet_capture_lock_boost = 96;
                        }
                    } else {
                        magnet_capture_lock_boost = 0;
                    }
        
                    if(magnet_capture_active && lock_confidence < magnet_capture_lock_boost){
                        lock_confidence = smooth_gain(lock_confidence, magnet_capture_lock_boost, MAGNET_CAPTURE_RAMP_GAIN);
                    }
                    if(lock_confidence > 100) lock_confidence = 100;
        
                    magnet_capture_snap_boost = 0;
                    magnet_capture_rotation_boost = 0;
                    magnet_capture_resist_boost = 0;
                    magnet_capture_slowdown_boost = 0;
                    if(magnet_capture_active){
                        magnet_capture_snap_boost = (MAGNET_CAPTURE_SNAP_BONUS * magnet_capture_strength) / 100;
                        magnet_capture_rotation_boost = (MAGNET_CAPTURE_ROTATION_BONUS * magnet_capture_strength) / 100;
                        magnet_capture_resist_boost = (MAGNET_CAPTURE_RESIST_BONUS * magnet_capture_strength) / 100;
                        magnet_capture_slowdown_boost = (MAGNET_CAPTURE_SLOWDOWN_BONUS * magnet_capture_strength) / 100;
                        if(ads){
                            magnet_capture_rotation_boost = magnet_capture_rotation_boost + (slider_ads_rotation / 2) + 6;
                            magnet_capture_slowdown_boost = magnet_capture_slowdown_boost + (slider_ads_strength / 3) + 6;
                        }
                    }
        
                    magnet_lock_gate = target_locked;
                    if(magnet_capture_active){
                        magnet_lock_gate = 1;
                    }
                }
        
                function update_cone_engagement(){
                    g_val = 0;
                    if(!ads && magnet_lock_gate){
                        g_temp = soft_step(distance_pixels, UE_CONE_RADIUS, UE_CONE_RADIUS + 24);
                        if(g_temp < 0) g_temp = 0;
                        if(g_temp > 100) g_temp = 100;
                        g_val = 100 - g_temp;
                        g_val = (g_val * (lock_confidence + 40)) / 140;
                        if(g_val > 100) g_val = 100;
                        g_val = (g_val * (100 - bubble_release_weight)) / 100;
                        if(g_val < 0) g_val = 0;
                        if(search_release_pct > 0){
                            g_val = (g_val * (100 - search_release_pct)) / 100;
                        }
                    }
                    if(g_val < 0) g_val = 0;
                    if(g_val > 100) g_val = 100;
        
                    if(ads || !magnet_lock_gate){
                        cone_engage_weight = smooth_gain(cone_engage_weight, 0, UE_CONE_DECAY_GAIN);
                    } else {
                        cone_engage_weight = smooth_gain(cone_engage_weight, g_val, UE_CONE_BLEND_GAIN);
                        if(g_val == 0){
                            cone_engage_weight = smooth_gain(cone_engage_weight, 0, UE_CONE_DECAY_GAIN);
                        }
                    }
        
                    if(cone_engage_weight < 2){
                        cone_engage_weight = 0;
                    } else if(cone_engage_weight > 100){
                        cone_engage_weight = 100;
                    }
        
                    g_temp = 0;
                    if(!ads && magnet_lock_gate && enemy_speed_mag >= UE_HIP_GLUE_VELOCITY_GATE){
                        g_temp = UE_HIP_GLUE_VELOCITY_FLOOR + ((enemy_speed_mag - UE_HIP_GLUE_VELOCITY_GATE) * 60) / 160;
                        if(g_temp < UE_HIP_GLUE_VELOCITY_FLOOR) g_temp = UE_HIP_GLUE_VELOCITY_FLOOR;
                        if(g_temp > 100) g_temp = 100;
                    }
                    hip_velocity_glue_floor = smooth_gain(hip_velocity_glue_floor, g_temp, UE_HIP_GLUE_VELOCITY_DECAY);
                    if(ads || !magnet_lock_gate || search_release_pct > 0){
                        hip_velocity_glue_floor = smooth_gain(hip_velocity_glue_floor, 0, UE_HIP_GLUE_VELOCITY_DECAY);
                    }
                    if(hip_velocity_glue_floor < 0) hip_velocity_glue_floor = 0;
                    if(hip_velocity_glue_floor > 100) hip_velocity_glue_floor = 100;
                }
        
                function update_momentum_accumulator(){
                    if(!magnet_lock_gate || freedom_release_active){
                        momentum_x = (momentum_x * (100 - (UE_MOMENTUM_DECAY * 2))) / 100;
                        momentum_y = (momentum_y * (100 - (UE_MOMENTUM_DECAY * 2))) / 100;
                        if(momentum_x < 2 && momentum_x > -2) momentum_x = 0;
                        if(momentum_y < 2 && momentum_y > -2) momentum_y = 0;
                        return;
                    }
        
                    g_val = enemy_velocity_blend_x + ai_output_rx;
                    g_temp = enemy_velocity_blend_y + ai_output_ry;
        
                    momentum_x = momentum_x + (g_val * UE_MOMENTUM_GAIN) / 100;
                    momentum_y = momentum_y + (g_temp * UE_MOMENTUM_GAIN) / 100;
        
                    momentum_x = (momentum_x * (100 - UE_MOMENTUM_DECAY)) / 100;
                    momentum_y = (momentum_y * (100 - UE_MOMENTUM_DECAY)) / 100;
        
                    momentum_x = clamp_i(momentum_x, 0 - UE_MOMENTUM_CAP, UE_MOMENTUM_CAP);
                    momentum_y = clamp_i(momentum_y, 0 - UE_MOMENTUM_CAP, UE_MOMENTUM_CAP);
                }
        
                // =============== SCREEN-SPACE CONVERSION ==============
                function update_screen_space(){
                    // Convert rx/ry to screen pixels from center
                    pixel_offset_x = (rx * SCREEN_WIDTH) / 200;
                    pixel_offset_y = (ry * SCREEN_HEIGHT) / 200;
        
                    // Calculate distance in pixels (Pythagoras)
                    distance_pixels = isqrt_custom((pixel_offset_x * pixel_offset_x) + (pixel_offset_y * pixel_offset_y));
        
                    // Hyper-burst maakt bubble 2x groter voor one-shots!
                    if(hyper_burst_active){
                        distance_pixels = (distance_pixels * 100) / HYPER_BUBBLE_MULTI;
                    }
                }
        
                // =============== MULTI-ZONE WEIGHTED SYSTEM ==============
                function update_weighted_zones(){
                    // Reset weights
                    zone_weight_ultra = 0;
                    zone_weight_close = 0;
                    zone_weight_mid = 0;
                    zone_weight_far = 0;
        
                    // Weighted blending tussen zones (smooth transitions!)
                    if(distance_pixels <= BUBBLE_ZONE_ULTRA){
                        zone_weight_ultra = 100;
                    }
                    else if(distance_pixels <= BUBBLE_ZONE_CLOSE){
                        zone_weight_ultra = 100 - (((distance_pixels - BUBBLE_ZONE_ULTRA) * 100) / (BUBBLE_ZONE_CLOSE - BUBBLE_ZONE_ULTRA));
                        zone_weight_close = 100 - zone_weight_ultra;
                    }
                    else if(distance_pixels <= BUBBLE_ZONE_MID){
                        zone_weight_close = 100 - (((distance_pixels - BUBBLE_ZONE_CLOSE) * 100) / (BUBBLE_ZONE_MID - BUBBLE_ZONE_CLOSE));
                        zone_weight_mid = 100 - zone_weight_close;
                    }
                    else if(distance_pixels <= BUBBLE_ZONE_FAR){
                        zone_weight_mid = 100 - (((distance_pixels - BUBBLE_ZONE_MID) * 100) / (BUBBLE_ZONE_FAR - BUBBLE_ZONE_MID));
                        zone_weight_far = 100 - zone_weight_mid;
                    }
                    else if(distance_pixels <= BUBBLE_ZONE_OUTER){
                        zone_weight_far = 100 - (((distance_pixels - BUBBLE_ZONE_FAR) * 100) / (BUBBLE_ZONE_OUTER - BUBBLE_ZONE_FAR));
                    }
                }
        
                function update_bubble_center_lock(){
                    g_val = 0;
                    if(distance_pixels <= BUBBLE_EDGE_RELEASE_RADIUS){
                        g_val = 100 - soft_step(distance_pixels, BUBBLE_CENTER_LOCK_RADIUS, BUBBLE_CENTER_SOFT_RADIUS);
                        if(g_val < 0) g_val = 0;
                    }
                    bubble_core_weight = smooth_gain(bubble_core_weight, g_val, 28);
        
                    g_temp = 0;
                    if(distance_pixels <= BUBBLE_EDGE_RELEASE_RADIUS){
                        g_temp = 100 - soft_step(distance_pixels, BUBBLE_EDGE_SOFT_RADIUS, BUBBLE_EDGE_RELEASE_RADIUS);
                        if(g_temp < 0) g_temp = 0;
                    }
                    bubble_edge_weight = smooth_gain(bubble_edge_weight, g_temp, 24);
        
                    g_chars = 0;
                    if(input_velocity > BUBBLE_RELEASE_INPUT || !magnet_lock_gate){
                        g_chars = 100;
                    }
                    bubble_release_weight = smooth_gain(bubble_release_weight, g_chars, BUBBLE_RELEASE_DECAY);
        
                    g_total = (bubble_core_weight * (100 - bubble_release_weight)) / 100;
                    if(g_total < 0) g_total = 0;
                    if(g_total > 100) g_total = 100;
                    bubble_lock_weight = g_total;
        
                    g_expected = (bubble_edge_weight * (100 - bubble_release_weight)) / 100;
                    bubble_guidance_weight = bubble_lock_weight;
                    if(g_expected > bubble_guidance_weight){
                        bubble_guidance_weight = (bubble_guidance_weight * (100 - BUBBLE_EDGE_GUIDE_BLEND) + g_expected * BUBBLE_EDGE_GUIDE_BLEND) / 100;
                    } else {
                        bubble_guidance_weight = (bubble_guidance_weight * 90 + g_expected * 10) / 100;
                    }
                    if(bubble_guidance_weight < bubble_lock_weight) bubble_guidance_weight = bubble_lock_weight;
                    if(bubble_guidance_weight > 100) bubble_guidance_weight = 100;
        
                    bubble_center_pull_x = 0;
                    bubble_center_pull_y = 0;
        
                    if(distance_pixels > 0){
                        g_val = BUBBLE_CENTER_GAIN_MIN + ((bubble_guidance_weight * (BUBBLE_CENTER_GAIN_MAX - BUBBLE_CENTER_GAIN_MIN)) / 100);
                        if(g_val > BUBBLE_CENTER_GAIN_MAX) g_val = BUBBLE_CENTER_GAIN_MAX;
        
                        if(!ads){
                            g_val = (g_val * (80 + slider_hip_strength)) / 130;
                            if(oneshot_mode){
                                g_val = (g_val * HIP_ONESHOT_SUPER_GAIN) / 140;
                            }
                        } else {
                            g_val = (g_val * (70 + slider_ads_strength)) / 120;
                        }
        
                        g_temp = (-pixel_offset_x * g_val) / (distance_pixels + 6);
                        g_chars = (-pixel_offset_y * g_val) / (distance_pixels + 6);
        
                        if(ballistic_active > 0){
                            g_total = distance_pixels + 6;
                            if(g_total < 6) g_total = 6;
                            g_expected = (ballistic_travel_offset_x * g_val) / g_total;
                            g_expected = (g_expected * BALLISTIC_CENTER_TRAVEL_BLEND) / 100;
                            g_temp = g_temp + (g_expected * ballistic_active) / 100;
        
                            g_fill = (ballistic_drop_offset * g_val) / g_total;
                            g_fill = (g_fill * BALLISTIC_CENTER_DROP_BLEND) / 100;
                            g_chars = g_chars - (g_fill * ballistic_active) / 100;
                        }
        
                        if(!ads){
                            g_temp = clamp_i(g_temp, -BUBBLE_GUIDE_MAX_PULL_HIP_X, BUBBLE_GUIDE_MAX_PULL_HIP_X);
                            g_chars = clamp_i(g_chars, -BUBBLE_GUIDE_MAX_PULL_HIP_Y, BUBBLE_GUIDE_MAX_PULL_HIP_Y);
                        } else {
                            g_temp = clamp_i(g_temp, -BUBBLE_GUIDE_MAX_PULL_ADS_X, BUBBLE_GUIDE_MAX_PULL_ADS_X);
                            g_chars = clamp_i(g_chars, -BUBBLE_GUIDE_MAX_PULL_ADS_Y, BUBBLE_GUIDE_MAX_PULL_ADS_Y);
                        }
        
                        g_expected = 100 - ((bubble_release_weight * BUBBLE_GUIDE_RELEASE_DAMP) / 100);
                        if(g_expected < 0) g_expected = 0;
                        g_temp = (g_temp * g_expected) / 100;
                        g_chars = (g_chars * g_expected) / 100;
        
                        bubble_center_pull_x = (g_temp * bubble_guidance_weight) / 100;
                        bubble_center_pull_y = (g_chars * bubble_guidance_weight) / 100;
                    }
                }
        
                // =============== LEFT-STICK ROTATION GATE ==============
                function update_rotation_gate(){
                    // Bereken strafe velocity (left stick + VIRTUAL strafe!)
                    // Virtual strafe wordt toegevoegd voor magnetic mode calculation
                    strafe_velocity = abs(lx + virtual_strafe_x) + abs(ly + virtual_strafe_y);
        
                    // Rotation ALLEEN actief bij strafe OF micro aim movements
                    // Virtual strafe zorgt dat dit ALTIJD triggered bij magnetic mode!
                    if(strafe_velocity > ROTATION_STRAFE_GATE || (input_mag > 5 && input_mag < 25)){
                        rotation_active = 1;
                    }
                    else {
                        rotation_active = 0;
                    }
        
                    if(hipfire_sticky_active){
                        rotation_active = 1;
                    }
                    if(hipfire_engaged){
                        rotation_active = 1;
                    }
                }
        
                // =============== PREDICTIVE LAZY AIM ==============
                function update_predictive_aim_legacy(){
                    enemy_velocity_prev_x = enemy_velocity_x;
                    enemy_velocity_prev_y = enemy_velocity_y;
        
                    enemy_velocity_x = pixel_offset_x - last_pixel_x;
                    enemy_velocity_y = pixel_offset_y - last_pixel_y;
        
                    enemy_accel_x = enemy_velocity_x - enemy_velocity_prev_x;
                    enemy_accel_y = enemy_velocity_y - enemy_velocity_prev_y;
        
                    enemy_velocity_hist_x[enemy_hist_index] = enemy_velocity_x;
                    enemy_velocity_hist_y[enemy_hist_index] = enemy_velocity_y;
        
                    enemy_hist_index = enemy_hist_index + 1;
                    if(enemy_hist_index >= PRED_BUFFER_SIZE) enemy_hist_index = 0;
        
                    if(enemy_hist_count < PRED_BUFFER_SIZE) enemy_hist_count = enemy_hist_count + 1;
        
                    enemy_velocity_avg_prev_x = enemy_velocity_avg_x;
                    enemy_velocity_avg_prev_y = enemy_velocity_avg_y;
        
                    g_chars = 0;
                    g_total = 0;
                    while(g_chars < enemy_hist_count){
                        g_total = g_total + enemy_velocity_hist_x[g_chars];
                        g_chars = g_chars + 1;
                    }
                    if(enemy_hist_count > 0){
                        g_temp = g_total / enemy_hist_count;
                    } else {
                        g_temp = enemy_velocity_x;
                    }
                    enemy_velocity_avg_x = smooth_gain(enemy_velocity_avg_x, g_temp, PRED_VELOCITY_SMOOTH_GAIN);
        
                    g_chars = 0;
                    g_total = 0;
                    while(g_chars < enemy_hist_count){
                        g_total = g_total + enemy_velocity_hist_y[g_chars];
                        g_chars = g_chars + 1;
                    }
                    if(enemy_hist_count > 0){
                        g_temp = g_total / enemy_hist_count;
                    } else {
                        g_temp = enemy_velocity_y;
                    }
                    enemy_velocity_avg_y = smooth_gain(enemy_velocity_avg_y, g_temp, PRED_VELOCITY_SMOOTH_GAIN);
        
                    g_temp = enemy_velocity_avg_x - enemy_velocity_avg_prev_x;
                    enemy_accel_avg_x = smooth_gain(enemy_accel_avg_x, g_temp, PRED_ACCEL_SMOOTH_GAIN);
                    g_temp = enemy_velocity_avg_y - enemy_velocity_avg_prev_y;
                    enemy_accel_avg_y = smooth_gain(enemy_accel_avg_y, g_temp, PRED_ACCEL_SMOOTH_GAIN);
        
                    g_temp = enemy_accel_avg_x * enemy_accel_avg_x;
                    g_total = enemy_accel_avg_y * enemy_accel_avg_y;
                    enemy_accel_avg_mag = isqrt_custom((g_temp + g_total));
                    if(enemy_accel_avg_mag > 160) enemy_accel_avg_mag = 160;
        
                    g_total = 100 - PRED_HISTORY_BLEND;
                    enemy_velocity_blend_x = ((enemy_velocity_avg_x * PRED_HISTORY_BLEND) + (enemy_velocity_x * g_total)) / 100;
                    enemy_velocity_blend_y = ((enemy_velocity_avg_y * PRED_HISTORY_BLEND) + (enemy_velocity_y * g_total)) / 100;
                    enemy_accel_blend_x = ((enemy_accel_avg_x * PRED_HISTORY_BLEND) + (enemy_accel_x * g_total)) / 100;
                    enemy_accel_blend_y = ((enemy_accel_avg_y * PRED_HISTORY_BLEND) + (enemy_accel_y * g_total)) / 100;
        
                    g_temp = enemy_accel_blend_x * enemy_accel_blend_x;
                    g_total = enemy_accel_blend_y * enemy_accel_blend_y;
                    enemy_accel_mag = isqrt_custom((g_temp + g_total));
                    if(enemy_accel_mag > 160) enemy_accel_mag = 160;
        
                    g_temp = enemy_velocity_blend_x * enemy_velocity_blend_x;
                    g_temp = enemy_velocity_blend_x * enemy_velocity_blend_x;
                    g_total = enemy_velocity_blend_y * enemy_velocity_blend_y;
                    enemy_speed_mag = isqrt_custom((g_temp + g_total));
                    if(enemy_speed_mag > 160) enemy_speed_mag = 160;
        
                    predict_horizon_target = 4 + (lock_confidence * 6) / 100;
                    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
                    if(predict_horizon_target > 10) predict_horizon_target = 10;
        
                    g_val = slider_smoothness - 50;
                    if(g_val != 0){
                        predict_horizon_target = predict_horizon_target + (g_val / 25);
                    }
                    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
                    if(predict_horizon_target > PRED_HORIZON_MAX) predict_horizon_target = PRED_HORIZON_MAX;
        
                    g_total = abs(enemy_velocity_blend_x) + abs(enemy_velocity_blend_y);
                    if(g_total > 120){
                        predict_horizon_target = (predict_horizon_target * 70) / 100;
                    } else if(g_total < 35){
                        predict_horizon_target = (predict_horizon_target * 120) / 100;
                    }
                    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
                    if(predict_horizon_target > PRED_HORIZON_MAX) predict_horizon_target = PRED_HORIZON_MAX;
        
                    if(enemy_accel_mag > PRED_ACCEL_VARIANCE_GATE){
                        g_chars = enemy_accel_mag - PRED_ACCEL_VARIANCE_GATE;
                        if(g_chars > PRED_ACCEL_VARIANCE_CLAMP) g_chars = PRED_ACCEL_VARIANCE_CLAMP;
                        g_expected = 100 - g_chars;
                        if(g_expected < 30) g_expected = 30;
                        predict_horizon_target = (predict_horizon_target * g_expected) / 100;
                    }
        
                    if(enemy_accel_avg_mag < 15 && enemy_speed_mag < 45){
                        predict_horizon_target = (predict_horizon_target * 120) / 100;
                    }
        
                    if(oneshot_mode){
                        predict_horizon_target = predict_horizon_target + 1;
                    }
        
                    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
                    if(predict_horizon_target > PRED_HORIZON_MAX) predict_horizon_target = PRED_HORIZON_MAX;
        
                    if(predict_horizon_frames <= 0){
                        predict_horizon_frames = predict_horizon_target;
                    } else {
                        predict_horizon_frames = smooth_gain(predict_horizon_frames, predict_horizon_target, PRED_HORIZON_SMOOTH_GAIN);
                    }
                    if(predict_horizon_frames < PRED_HORIZON_MIN) predict_horizon_frames = PRED_HORIZON_MIN;
                    if(predict_horizon_frames > PRED_HORIZON_MAX) predict_horizon_frames = PRED_HORIZON_MAX;
        
                    g_val = (predict_horizon_frames * (predict_horizon_frames + 1)) / 2;
                    if(g_val < 1) g_val = 1;
        
                    g_temp = enemy_velocity_blend_x * predict_horizon_frames;
                    g_total = (enemy_accel_blend_x * g_val * PRED_ACCEL_GAIN) / 100;
                    predict_offset_x = pixel_offset_x + g_temp + g_total;
        
                    g_temp = enemy_velocity_blend_y * predict_horizon_frames;
                    if(lock_strength >= LAZY_AIM_MIN_LOCK && target_locked){
                        pred_weapon_mult = PRED_AR_MULT;
                        if(oneshot_mode){
                            pred_weapon_mult = PRED_ONESHOT_MULT;
                        } else if(sniper_mode){
                            pred_weapon_mult = PRED_SNIPER_MULT;
                        }
                        if(aerial_mode){
                            pred_weapon_mult = (pred_weapon_mult * PRED_AERIAL_MULT) / 100;
                        }
                        if(pred_weapon_mult < 60) pred_weapon_mult = 60;
                        if(pred_weapon_mult > 180) pred_weapon_mult = 180;
        
                        predictive_bias_strength = LAZY_AIM_BIAS;
                        predictive_bias_strength = (predictive_bias_strength * (40 + lock_confidence)) / 100;
                        predictive_bias_strength = (predictive_bias_strength * (60 + assist_core_blend)) / 100;
                        predictive_bias_strength = (predictive_bias_strength * pred_weapon_mult) / 100;
                        predictive_bias_strength = (predictive_bias_strength * (80 + enemy_stability_pct)) / 100;
                        predictive_bias_strength = (predictive_bias_strength * weapon_gain_core_mix) / 100;
                        if(predictive_bias_strength < 6) predictive_bias_strength = 6;
                        if(predictive_bias_strength > 80) predictive_bias_strength = 80;
        
                        g_val = (predict_horizon_frames * (predict_horizon_frames + 1)) / 2;
                        if(g_val < 1) g_val = 1;
        
                        g_temp = enemy_velocity_blend_x * predict_horizon_frames;
                        g_total = (enemy_accel_blend_x * g_val * PRED_ACCEL_GAIN) / 100;
                        predict_offset_x = pixel_offset_x + g_temp + g_total;
        
                        g_temp = enemy_velocity_blend_y * predict_horizon_frames;
                        g_expected = (enemy_accel_blend_y * g_val * PRED_ACCEL_GAIN) / 100;
                        g_chars = (enemy_velocity_blend_y * PRED_VERTICAL_GAIN) / 100;
                        predict_offset_y = pixel_offset_y + g_temp + g_expected + g_chars;
        
                        lazy_bias_x = ((predict_offset_x - pixel_offset_x) * predictive_bias_strength) / 100;
                        lazy_bias_y = ((predict_offset_y - pixel_offset_y) * predictive_bias_strength) / 100;
        
                        g_temp = 50 + current_rotation_slider;
                        lazy_bias_x = (lazy_bias_x * g_temp) / 100;
                        lazy_bias_y = (lazy_bias_y * g_temp) / 100;
        
                        g_total = 100 + (enemy_speed_mag * VELOCITY_FOLLOW_STRENGTH) / 200;
                        if(g_total < 80) g_total = 80;
                        if(g_total > 160) g_total = 160;
                        lazy_bias_x = (lazy_bias_x * g_total) / 100;
                        lazy_bias_y = (lazy_bias_y * g_total) / 100;
        
                        lazy_bias_cap_x = 10 + (assist_rotation_blend / 4);
                        lazy_bias_cap_y = 8 + (assist_rotation_blend / 6);
                        if(lazy_bias_cap_x < 8) lazy_bias_cap_x = 8;
                        if(lazy_bias_cap_x > 32) lazy_bias_cap_x = 32;
                        if(lazy_bias_cap_y < 8) lazy_bias_cap_y = 8;
                        if(lazy_bias_cap_y > 28) lazy_bias_cap_y = 28;
        
                        if(oneshot_mode){
                            lazy_bias_cap_x = (lazy_bias_cap_x * 12) / 10;
                            lazy_bias_cap_y = (lazy_bias_cap_y * 12) / 10;
                        }
        
                        if(hip_fast_track_active){
                            lazy_bias_x = (lazy_bias_x * HIP_FAST_PREDICT_GAIN) / 100;
                            lazy_bias_y = (lazy_bias_y * HIP_FAST_PREDICT_GAIN) / 100;
                            lazy_bias_cap_x = (lazy_bias_cap_x * HIP_FAST_PREDICT_GAIN) / 100;
                            lazy_bias_cap_y = (lazy_bias_cap_y * HIP_FAST_PREDICT_GAIN) / 100;
                            if(lazy_bias_cap_x > 48) lazy_bias_cap_x = 48;
                            if(lazy_bias_cap_y > 42) lazy_bias_cap_y = 42;
                        }
        
                        if(search_release_pct > 0){
                            g_total = lerp_pct(100, UE_SEARCH_RELEASE_BIAS, search_release_pct);
                            lazy_bias_x = (lazy_bias_x * g_total) / 100;
                            lazy_bias_y = (lazy_bias_y * g_total) / 100;
                        }
        
                        if(lazy_bias_x > lazy_bias_cap_x) lazy_bias_x = lazy_bias_cap_x;
                        if(lazy_bias_x < 0 - lazy_bias_cap_x) lazy_bias_x = 0 - lazy_bias_cap_x;
                        if(lazy_bias_y > lazy_bias_cap_y) lazy_bias_y = lazy_bias_cap_y;
                        if(lazy_bias_y < 0 - lazy_bias_cap_y) lazy_bias_y = 0 - lazy_bias_cap_y;
                    }
                    else {
                        predict_offset_x = pixel_offset_x;
                        predict_offset_y = pixel_offset_y;
                        lazy_bias_x = 0;
                        lazy_bias_y = 0;
                    }
        
                    last_pixel_x = pixel_offset_x;
                    last_pixel_y = pixel_offset_y;
        
                    if(enemy_speed_mag > 0){
                        enemy_dir_x = (enemy_velocity_blend_x * 100) / enemy_speed_mag;
                        enemy_dir_y = (enemy_velocity_blend_y * 100) / enemy_speed_mag;
                        enemy_dir_x = clamp_i(enemy_dir_x, -100, 100);
                        enemy_dir_y = clamp_i(enemy_dir_y, -100, 100);
                    } else {
                        enemy_dir_x = 0;
                        enemy_dir_y = 0;
                    }
        
                    enemy_velocity_avg_prev_x = enemy_velocity_avg_x;
                    enemy_velocity_avg_prev_y = enemy_velocity_avg_y;
                    enemy_velocity_prev_x = enemy_velocity_x;
                    enemy_velocity_prev_y = enemy_velocity_y;
                }
        
                function update_ai_tracking_engine(){
                    ai_bias_target_x = 0;
                    ai_bias_target_y = 0;
                    ai_confidence_target = 0;
                    ai_future_offset_x = pixel_offset_x;
                    ai_future_offset_y = pixel_offset_y;
        
                    if(!target_locked || lock_confidence < AI_LOCK_MIN_CONF){
                        ai_confidence_target = 0;
                    } else {
                        g_val = AI_TRACK_ITERATIONS;
                        ai_iterations_active = 0;
                        ai_residual_error = 0;
                        ai_future_offset_x = predict_offset_x;
                        ai_future_offset_y = predict_offset_y;
        
                        while(g_val > 0){
                            g_val = g_val - 1;
                            ai_iterations_active = ai_iterations_active + 1;
        
                            g_temp = predict_horizon_frames;
                            if(g_temp < 2) g_temp = 2;
                            g_expected = g_temp - (g_val * 2);
                            if(g_expected < 1) g_expected = 1;
                            if(g_expected > PRED_HORIZON_MAX) g_expected = PRED_HORIZON_MAX;
        
                            g_fill = (enemy_velocity_blend_x * g_expected) / 2;
                            g_chars = (enemy_accel_blend_x * g_expected) / 6;
                            g_total = pixel_offset_x + g_fill + g_chars;
                            ai_future_offset_x = smooth_gain(ai_future_offset_x, g_total, 40 + (lock_confidence / 3));
        
                            g_fill = (enemy_velocity_blend_y * g_expected) / 2;
                            g_chars = (enemy_accel_blend_y * g_expected) / 6;
                            g_total = pixel_offset_y + g_fill + g_chars;
                            ai_future_offset_y = smooth_gain(ai_future_offset_y, g_total, 40 + (lock_confidence / 3));
        
                            g_fill = ai_future_offset_x - pixel_offset_x;
                            if(g_fill < 0) g_fill = 0 - g_fill;
                            ai_residual_error = ai_residual_error + g_fill;
        
                            g_fill = ai_future_offset_y - pixel_offset_y;
                            if(g_fill < 0) g_fill = 0 - g_fill;
                            ai_residual_error = ai_residual_error + g_fill;
                        }
        
                        if(ai_iterations_active > 0){
                            ai_residual_error = ai_residual_error / (ai_iterations_active * 2);
                        }
        
                        ai_bias_target_x = ai_future_offset_x - pixel_offset_x;
                        ai_bias_target_y = ai_future_offset_y - pixel_offset_y;
        
                        g_total = clamp_i(100 - (ai_residual_error * 8), 0, 100);
                        g_total = (g_total * (60 + lock_confidence)) / 100;
                        if(magnet_capture_active){
                            g_total = clamp_i(g_total + 18, 0, 100);
                        }
                        ai_confidence_target = g_total;
                    }
        
                    if(freedom_release_active || input_velocity >= AI_INPUT_RELEASE_THRESHOLD || panic_triggered > 0){
                        ai_confidence_target = 0;
                    }
        
                    if(ai_confidence_target >= ai_confidence_pct){
                        ai_confidence_pct = smooth_gain(ai_confidence_pct, ai_confidence_target, AI_CONFIDENCE_GAIN);
                    } else {
                        ai_confidence_pct = smooth_gain(ai_confidence_pct, ai_confidence_target, AI_CONFIDENCE_DECAY);
                    }
        
                    g_val = AI_SMOOTH_GAIN_ADS;
                    if(!ads) g_val = AI_SMOOTH_GAIN_HIP;
        
                    ai_bias_x = smooth_gain(ai_bias_x, ai_bias_target_x, g_val);
                    ai_bias_y = smooth_gain(ai_bias_y, ai_bias_target_y, g_val);
        
                    g_total = (ai_confidence_pct * AI_PREDICT_CLAMP_X) / 100;
                    if(g_total < AI_TRACK_ERROR_EPS) g_total = AI_TRACK_ERROR_EPS;
                    ai_bias_x = clamp_i(ai_bias_x, -g_total, g_total);
        
                    g_total = (ai_confidence_pct * AI_PREDICT_CLAMP_Y) / 100;
                    if(g_total < AI_TRACK_ERROR_EPS) g_total = AI_TRACK_ERROR_EPS;
                    ai_bias_y = clamp_i(ai_bias_y, -g_total, g_total);
        
                    g_temp = ai_bias_x - ai_last_output_rx;
                    if(g_temp > AI_DRIFT_CLAMP_DELTA) g_temp = AI_DRIFT_CLAMP_DELTA;
                    if(g_temp < -AI_DRIFT_CLAMP_DELTA) g_temp = -AI_DRIFT_CLAMP_DELTA;
                    ai_output_rx = ai_last_output_rx + g_temp;
                    ai_last_output_rx = ai_output_rx;
        
                    g_temp = ai_bias_y - ai_last_output_ry;
                    if(g_temp > AI_DRIFT_CLAMP_DELTA) g_temp = AI_DRIFT_CLAMP_DELTA;
                    if(g_temp < -AI_DRIFT_CLAMP_DELTA) g_temp = -AI_DRIFT_CLAMP_DELTA;
                    ai_output_ry = ai_last_output_ry + g_temp;
                    ai_last_output_ry = ai_output_ry;
        
                    if(ai_confidence_pct <= 4){
                        ai_output_rx = smooth_gain(ai_output_rx, 0, 75);
                        ai_output_ry = smooth_gain(ai_output_ry, 0, 75);
                        ai_last_output_rx = ai_output_rx;
                        ai_last_output_ry = ai_output_ry;
                    }
        
                    if(ai_confidence_pct <= 2){
                        ai_output_rx = 0;
                        ai_output_ry = 0;
                        ai_last_output_rx = 0;
                        ai_last_output_ry = 0;
                    }
                }
                function update_assist_core(){
                    // GPC FIX: No local variables! Use globals g_val, g_temp, g_p, etc.
        
                    if(input_velocity >= INPUT_VELOCITY_PANIC){
                        panic_triggered = 250;
                    }
                    if(panic_triggered > 0){
                        panic_triggered = panic_triggered - delta;
                        if(panic_triggered < 0) panic_triggered = 0;
                    }
        
                    g_val = 100 - soft_step(aim_error_pixels, BUBBLE_ULTRA_CLOSE, BUBBLE_OUTER);
                    if(g_val < 0) g_val = 0;
                    assist_last_proximity_score = g_val;
        
                    g_temp = abs(aim_error_trend);
                    g_p = 100 - soft_step(g_temp, 3, 30);
                    if(g_p < 0) g_p = 0;
        
                    g_tboost = 100 - soft_step(abs(distance_delta), 4, 35);
                    if(g_tboost < 0) g_tboost = 0;
        
                    g_expected = INPUT_VELOCITY_FAST_HIP;
                    if(ads) g_expected = INPUT_VELOCITY_FAST_ADS;
                    g_fill = soft_step(input_velocity, 12, g_expected);
                    if(g_fill < 0) g_fill = 0;
        
                    g_total = (100 - g_fill) * 15;
                    g_temp = lock_confidence * 50 + g_val * 20 + g_p * 15 + g_total;
                    g_chars = g_temp / 100;
        
                    if(!target_locked && g_val > 70 && g_fill < 40){
                        if(g_chars < 25) g_chars = 25;
                    }
        
                    if(ads) g_chars = clamp_i(g_chars + 8, 0, 100);
        
                    if(panic_triggered > 0){
                        g_expected = soft_step(panic_triggered, 1, 250);
                        g_chars = (g_chars * (100 - g_expected)) / 100;
                    }
        
                    assist_core_blend = smooth_gain(assist_core_blend, g_chars, 18);
                    assist_core_blend = clamp_i(assist_core_blend, 0, 100);
        
                    // Phase C refinement: Error Variance Stability Score (VSS) for smooth snap blending
                    g_expected = 100 - soft_step(aim_error_variance, 6, 40); // 100 = Stable (low variance), 0 = Volatile (high variance)
                    if(g_expected < 0) g_expected = 0;
        
                    g_total = (assist_core_blend * 60 + g_val * 25 + (100 - g_fill) * 15) / 100;
                    if(!ads) g_total = (g_total * 85) / 100;
                    g_total = clamp_i(g_total, 0, 100);
        
                    range_slider = assist_core_blend;
                    if(rotation_active || strafe_active) range_slider = clamp_i(range_slider + 15, 0, 100);
                    range_slider = range_slider - (g_fill / 2);
                    if(range_slider < 0) range_slider = 0;
                    range_slider = clamp_i(range_slider, 0, 100);
        
                    // Snap Blend Target (Refined Phase C: Core Blend, Proximity, VSS, Trend Stability)
                    // g_expected holds the VSS (aim_error_variance stability) from before g_total calculation
                    g_temp = (assist_core_blend * 50 + g_val * 20 + g_expected * 15 + g_tboost * 15) / 100;
                    if(flick_detected) g_temp = clamp_i(g_temp + 30, 0, 100);
                    g_temp = clamp_i(g_temp, 0, 100);
        
                    assist_slowdown_blend = smooth_gain(assist_slowdown_blend, g_total, 18);
                    assist_rotation_blend = smooth_gain(assist_rotation_blend, range_slider, 18);
                    assist_snap_blend = smooth_gain(assist_snap_blend, g_temp, 18);
                }
        
                // vPro: New state machine logic, replacing detect_assist_state()
                function update_zd_state_machine() {
                    // Calculate slowdown ratio: 100 = no slowdown, 0 = full slowdown
                    // A more accurate ratio would be based on raw input vs output
                    g_val = abs(raw_rx) + abs(raw_ry) + 1;
                    g_temp = abs(final_rx) + abs(final_ry) + 1;
                    zd_slowdown_ratio = 100 - ((g_temp * 100) / g_val);
                    if (zd_slowdown_ratio < 0) zd_slowdown_ratio = 0;
                    if (zd_slowdown_ratio > 100) zd_slowdown_ratio = 100;
        
                    // State transition logic
                    g_expected = zd_state; // candidate state
        
                    // OVERRIDE has top priority
                    if (input_velocity >= ZD_OVERRIDE_VELOCITY_GATE) {
                        g_expected = ZD_STATE_OVERRIDE;
                    } else {
                        // Conditions for GLUE state (the core of sticky aim)
                        g_val = (zd_slowdown_ratio >= ZD_GLUE_SLOWDOWN_RATIO_GATE);
                        g_temp = (lock_confidence >= ZD_GLUE_CONFIDENCE_GATE);
                        g_p = (input_velocity <= ZD_GLUE_INPUT_VEL_GATE);
        
                        if (zd_state == ZD_STATE_GLUE || zd_state == ZD_STATE_PERSIST) {
                            if (g_val && g_temp && g_p) {
                                g_expected = ZD_STATE_GLUE; // Stay in GLUE
                            } else {
                                g_expected = ZD_STATE_PERSIST; // Transition to PERSIST
                            }
                        } else {
                            if (g_val && g_temp && g_p) {
                                g_expected = ZD_STATE_GLUE; // Enter GLUE
                            } else if (distance_pixels <= PRE_AIM_STICKY_ENGAGE_PX + 10 && input_velocity <= HIP_FAST_INPUT_GATE + 5) {
                                g_expected = ZD_STATE_ACQUIRE; // Proactive acquisition based on proximity and low input
                            } else if (target_locked) {
                                g_expected = ZD_STATE_TRACK; // Default to TRACK if locked
                            } else if (assist_core_blend > 10) {
                                g_expected = ZD_STATE_ACQUIRE; // Acquiring target
                            } else {
                                g_expected = ZD_STATE_FREE; // No target
                            }
                        }
                    }
        
                    // Handle state transitions and timers
                    if (g_expected != zd_state) {
                        zd_state = g_expected;
                        zd_state_timer = 0;
                        if (zd_state == ZD_STATE_PERSIST) {
                            zd_state_persist_timer = ZD_PERSIST_DURATION_MS;
                        }
                    } else {
                        zd_state_timer = zd_state_timer + delta;
                    }
        
                    // Handle PERSIST state timeout
                    if (zd_state == ZD_STATE_PERSIST) {
                        zd_state_persist_timer = zd_state_persist_timer - delta;
                        if (zd_state_persist_timer <= 0) {
                            zd_state = ZD_STATE_TRACK; // Fallback to TRACK
                            zd_state_timer = 0;
                        }
                    }
        
                    // Apply state-based subsystem blending (vPro Plan)
                    // 50% Glue/Resistance, 30% Slowdown, 15% Rotation, 5% Snap
                    if (zd_state == ZD_STATE_GLUE || zd_state == ZD_STATE_PERSIST) {
                        // Prioritize Resistance and Slowdown
                        aim_state_resistance_pct = 200; // Max resistance
                        assist_slowdown_blend = 100;
                        assist_rotation_blend = 50;
                        assist_snap_blend = 20;
                    } else if (zd_state == ZD_STATE_TRACK) {
                        aim_state_resistance_pct = 120;
                        assist_slowdown_blend = 90;
                        assist_rotation_blend = 100;
                        assist_snap_blend = 80;
                    } else if (zd_state == ZD_STATE_ACQUIRE) {
                        aim_state_resistance_pct = 80;
                        assist_slowdown_blend = 100;
                        assist_rotation_blend = 80;
                        assist_snap_blend = 100;
                    } else { // FREE or OVERRIDE
                        aim_state_resistance_pct = 0;
                        assist_slowdown_blend = 0;
                        assist_rotation_blend = 0;
                        assist_snap_blend = 0;
                    }
                }
        
                // ================ STRAFE DETECTION ==================
                function update_strafe_detection(){
                    velocity_mag = abs(lx) + abs(ly);
        
                    if(velocity_mag >= STRAFE_THRESHOLD){
                        strafe_active = 1;
                    }
                    else {
                        strafe_active = 0;
                    }
                }
        
                // ========== ASSIST AMPLIFICATION (V3.0 RE-ENABLED - OPTIMIZED!) ==========
                // OPLOSSING: Subtielere micro-orbit werkt NU SAMEN met Fortnite's aim assist!
                // - Kleinere left-stick inject (6-12 units) TRIGGERT Fortnite's rotational assist
                // - Geoptimaliseerde motion vult rotation pull aan → super smooth
                // - Gecontroleerde beweging voorkomt weapon fire delays
                // RESULTAAT: INGESCHAKELD - perfect samenspel tussen alle systemen!
                function update_assist_amplification(){
                    virtual_strafe_x = 0;
                    virtual_strafe_y = 0;
                    assist_engagement_signal = 0;
                    micro_orbit_radius = 0;
        
                    // HIPFIRE ENGAGEMENT state machine (runs even if the rest of the routine exits early)
                    g_total = 0;
                    if(!ads && !build_mode && !edit_mode && aim_on && !align_suppress_freeze){ // Removed magnet_lock_gate from here
                        g_total = (lock_confidence * 35 + bubble_lock_weight * 35 + magnet_capture_strength * 20 + assist_core_blend * 10) / 100;
                        if(hipfire_sticky_active){
                            g_total = g_total + 12;
                        }
                        if(r2_hipfire_instant){
                            g_total = g_total + 8;
                        }
                        if(bullet_correct_gain > 0){
                            g_total = g_total + 10;
                        }
                        if(ai_confidence_pct >= 60){
                            g_total = g_total + 6;
                        }
                        // Proactive pre-aim engagement boost
                        if(distance_pixels <= PRE_AIM_STICKY_ENGAGE_PX + 10 && input_velocity <= HIP_FAST_INPUT_GATE + 5){
                            g_total = g_total + 20; // Significant boost for proactive engagement
                        }
                        if(bubble_release_weight > 0){
                            g_total = g_total - (bubble_release_weight / 2);
                        }
                        if(search_release_pct > 0){
                            g_total = (g_total * (100 - search_release_pct)) / 100;
                        }
                        if(search_suppress_pct > 0){
                            g_total = (g_total * (100 - (search_suppress_pct / 2))) / 100;
                        }
                        if(g_total < 0){
                            g_total = 0;
                        }
                        if(g_total > 100){
                            g_total = 100;
                        }
                        if(input_velocity >= HIP_ENGAGE_RELEASE_INPUT){
                            g_total = 0;
                        }
                    }
        
                    if(g_total >= HIP_ENGAGE_SCORE_GATE){
                        hipfire_engaged = 1;
                        hipfire_engage_timer = HIP_ENGAGE_PERSIST_MS;
                        g_val = g_total - HIP_ENGAGE_SCORE_GATE;
                        if(g_val < 0) g_val = 0;
                        g_val = g_val * 3;
                        if(g_val > 100) g_val = 100;
                        hipfire_engage_strength = smooth_gain(hipfire_engage_strength, g_val, 45);
                    } else {
                        if(hipfire_engaged){
                            if(input_velocity >= HIP_ENGAGE_RELEASE_INPUT || !magnet_lock_gate || bubble_release_weight >= 70 || search_release_pct >= 25){
                                hipfire_engage_timer = 0;
                            } else {
                                hipfire_engage_timer = hipfire_engage_timer - delta;
                                if(hipfire_engage_timer < 0) hipfire_engage_timer = 0;
                            }
                            if(hipfire_engage_timer == 0){
                                hipfire_engaged = 0;
                                hipfire_engage_strength = smooth_gain(hipfire_engage_strength, 0, 70);
                            } else {
                                hipfire_engage_strength = smooth_gain(hipfire_engage_strength, 0, 12);
                            }
                        } else {
                            hipfire_engage_strength = smooth_gain(hipfire_engage_strength, 0, 30);
                        }
                    }
        
                    if(!hipfire_engaged){
                        hipfire_engage_timer = 0;
                        if(hipfire_engage_strength < 2){
                            hipfire_engage_strength = 0;
                        }
                    }
        
                    if(build_mode || edit_mode || align_suppress_freeze){
                        micro_orbit_index = 0;
                        micro_orbit_timer = 0;
                        micro_orbit_variation_timer = 0;
                        micro_orbit_direction = 1;
                        virtual_strafe_x_prev = 0;
                        virtual_strafe_y_prev = 0;
                        return;
                    }
        
                    if(panic_triggered > 0 || freedom_release_active){
                        micro_orbit_index = 0;
                        micro_orbit_timer = 0;
                        micro_orbit_variation_timer = 0;
                        micro_orbit_direction = 1;
                        virtual_strafe_x_prev = 0;
                        virtual_strafe_y_prev = 0;
                        return;
                    }
        
                    if(!magnet_lock_gate && !(oneshot_mode && !ads && (shooting || hipfire_sticky_active))){
                        micro_orbit_index = 0;
                        micro_orbit_timer = 0;
                        micro_orbit_variation_timer = 0;
                        micro_orbit_direction = 1;
                        virtual_strafe_x_prev = 0;
                        virtual_strafe_y_prev = 0;
                        return;
                    }
        
                    if(lock_confidence < 48 && !(oneshot_mode && !ads && shooting)){
                        micro_orbit_index = 0;
                        micro_orbit_timer = 0;
                        micro_orbit_variation_timer = 0;
                        micro_orbit_direction = 1;
                        virtual_strafe_x_prev = 0;
                        virtual_strafe_y_prev = 0;
                        return;
                    }
        
                    if(input_velocity > 34){
                        if(!(hipfire_engaged && input_velocity <= HIP_ENGAGE_INPUT_LIMIT)){
                            micro_orbit_index = 0;
                            micro_orbit_timer = 0;
                            micro_orbit_variation_timer = 0;
                            micro_orbit_direction = 1;
                            virtual_strafe_x_prev = 0;
                            virtual_strafe_y_prev = 0;
                            return;
                        }
                    }
        
                    bubble_weight_factor = (zone_weight_ultra * 100 +
                                            zone_weight_close * 70 +
                                            zone_weight_mid * 45 +
                                            zone_weight_far * 25) / 100;
                    bubble_weight_factor = clamp_i(bubble_weight_factor, 0, 100);
        
                    g_val = clamp_i(lock_confidence, 0, 100);
                    g_temp = clamp_i(magnet_capture_strength, 0, 100);
                    assist_engagement_signal = (g_val * 50 + bubble_weight_factor * 30 + g_temp * 20) / 100;
                    if(assist_engagement_signal < 18) assist_engagement_signal = 18;
                    if(assist_engagement_signal > 100) assist_engagement_signal = 100;
        
                    if(oneshot_mode && !ads){
                        assist_engagement_signal = clamp_i(assist_engagement_signal + 15, 25, 100);
                    } else if(ads){
                        assist_engagement_signal = (assist_engagement_signal * 85) / 100;
                    }
        
                    if(hipfire_engaged){
                        g_chars = HIP_ENGAGE_SIGNAL_BONUS + (hipfire_engage_strength * 12) / 100;
                        assist_engagement_signal = clamp_i(assist_engagement_signal + g_chars, 18, 100);
                    }
        
                    if(micro_orbit_direction == 0){
                        micro_orbit_direction = 1;
                    }
        
                    micro_orbit_timer = micro_orbit_timer - delta;
                    if(micro_orbit_timer <= 0){
                        micro_orbit_index = micro_orbit_index + micro_orbit_direction;
                        if(micro_orbit_index >= 16) micro_orbit_index = 0;
                        if(micro_orbit_index < 0) micro_orbit_index = 15;
        
                        g_chars = smoothness_orbit_timer_ms;
                        g_chars = g_chars - (assist_engagement_signal * smoothness_scale_pct) / 600;
                        if(hipfire_engaged && g_chars > 4){
                            g_chars = g_chars - 2;
                        }
                        if(g_chars < 6) g_chars = 6;
                        g_temp = smoothness_orbit_timer_ms + 18;
                        if(g_chars > g_temp) g_chars = g_temp;
                        micro_orbit_timer = g_chars;
                    }
        
                    micro_orbit_variation_timer = micro_orbit_variation_timer - delta;
                    if(micro_orbit_variation_timer <= 0){
                        if(abs(lx) > 12){
                            if(lx >= 0){
                                micro_orbit_direction = 1;
                            } else {
                                micro_orbit_direction = -1;
                            }
                        } else if(abs(ry) > abs(rx) && abs(ry) > 12){
                            if(ry >= 0){
                                micro_orbit_direction = 1;
                            } else {
                                micro_orbit_direction = -1;
                            }
                        } else if(waveform_rand_range(0, 1) == 0){
                            micro_orbit_direction = -micro_orbit_direction;
                        }
                        if(micro_orbit_direction == 0) micro_orbit_direction = 1;
        
                        g_chars = 120 - (assist_engagement_signal * 60) / 100;
                        if(g_chars < 40) g_chars = 40;
                        if(g_chars > 140) g_chars = 140;
                        micro_orbit_variation_timer = g_chars;
                    }
        
                    micro_orbit_radius = 8 + (assist_engagement_signal * 18) / 100;
                    if(magnet_capture_active){
                        micro_orbit_radius = micro_orbit_radius + (magnet_capture_strength * 5) / 100;
                    }
                    if(oneshot_mode && !ads){
                        micro_orbit_radius = micro_orbit_radius + 3;
                    }
                    if(hipfire_sticky_active && !ads){
                        micro_orbit_radius = micro_orbit_radius + 2;
                    }
        
                    g_val = smoothness_orbit_radius_pct;
                    micro_orbit_radius = (micro_orbit_radius * g_val) / 100;
        
                    if(hipfire_engaged){
                        g_total = HIP_ENGAGE_RADIUS_BONUS + (hipfire_engage_strength * HIP_ENGAGE_RADIUS_GAIN) / 100;
                        if(g_total > 0){
                            micro_orbit_radius = micro_orbit_radius + g_total;
                        }
                    }
        
                    if(micro_orbit_radius < 5) micro_orbit_radius = 5;
                    g_temp = 18;
                    if(hipfire_engaged){
                        g_temp = g_temp + HIP_ENGAGE_RADIUS_BONUS;
                        if(g_temp > 26) g_temp = 26;
                    }
                    if(micro_orbit_radius > g_temp) micro_orbit_radius = g_temp;
        
                    g_temp = micro_orbit_index;
                    g_expected = (cosLUT[g_temp] * micro_orbit_radius) / 100;
                    g_total = (sinLUT[g_temp] * micro_orbit_radius) / 100;
        
                    if(g_total > VERTICAL_CLAMP_MAX) g_total = VERTICAL_CLAMP_MAX;
                    if(g_total < -VERTICAL_CLAMP_MAX) g_total = -VERTICAL_CLAMP_MAX;
        
                    g_chars = smoothness_virtual_smooth_gain;
                    virtual_strafe_x_prev = smooth_gain(virtual_strafe_x_prev, g_expected, g_chars);
                    virtual_strafe_y_prev = smooth_gain(virtual_strafe_y_prev, g_total, g_chars);
        
                    virtual_strafe_x = virtual_strafe_x_prev;
                    virtual_strafe_y = virtual_strafe_y_prev;
        
                    g_total = abs(virtual_strafe_x) + abs(virtual_strafe_y);
                    if(g_total < 6){
                        if(micro_orbit_direction >= 0) virtual_strafe_x = 6;
                        else virtual_strafe_x = -6;
                    }
        
                    if(virtual_strafe_x > 12) virtual_strafe_x = 12;
                    if(virtual_strafe_x < -12) virtual_strafe_x = -12;
                    if(virtual_strafe_y > 9) virtual_strafe_y = 9;
                    if(virtual_strafe_y < -9) virtual_strafe_y = -9;
                }
        
                // ============== ROTATION PULSE CORE (PRIMARY MAGNETIC!) ==============
                // Dit is de KERN: left-stick bursts triggeren Fortnite's rotation assist
                // Slider controls: 0=OFF, slider scaling 0-200%
                // ============== CIRCULAR MAGNETIC AIM (TAYLOR DRIFT / ORBITAL) ==============
                // v60.1: AIMBOT LOGIC REWRITE - Independent Left Stick Generation
                // This forces Rotational Aim Assist to stay active 100% of the time by injecting
                // a micro-circular pattern into the movement stick, regardless of user input.
                function update_rotation_pulse(){
                    rotation_pulse_lx = 0;
                    rotation_pulse_ly = 0;
        
                    // Safety checks - ALLEEN build/edit mode, NIET aim_on (pre-aim pulses altijd actief!)
                    if(build_mode || edit_mode) return;
        
                    // Use pulse_magnitude from slider calc
                    g_val = pulse_magnitude; 
                    if(g_val < 20) g_val = 20; 
                    if(g_val > 30) g_val = 30;
        
                    // Generate Orbital Angle (Faster spin = smoother visual, better AA tick rate match)
                    rotation_pulse_timer = rotation_pulse_timer + ROTATION_PULSE_BASE; 
                    if(rotation_pulse_timer >= 360) rotation_pulse_timer = 0;
                    
                    // Convert angle to Index (0-15) for Lookup Table
                    g_temp = (rotation_pulse_timer * 16) / 360;
                    if(g_temp > 15) g_temp = 15;
        
                    // Generate Offsets using Sin/Cos LUT (Scaled 0-100)
                    rotation_pulse_lx = (g_val * cosLUT[g_temp]) / 100;
                    rotation_pulse_ly = (g_val * sinLUT[g_temp]) / 100;
        
                    // Stabilization: Tighten orbit during ADS to prevent "Spam/Shake" look
                    if(ads){
                        rotation_pulse_lx = (rotation_pulse_lx * 60) / 100;
                        rotation_pulse_ly = (rotation_pulse_ly * 60) / 100;
                    }
        
                    // Hipfire Boosts: Widen orbit for close range tracking
                    if(!ads && (oneshot_mode || hipfire_engaged)){
                        rotation_pulse_lx = (rotation_pulse_lx * 110) / 100;
                        rotation_pulse_ly = (rotation_pulse_ly * 110) / 100;
                    }
                    
                    // Safety Clamp
                    rotation_pulse_lx = clamp_i(rotation_pulse_lx, -32, 32);
                    rotation_pulse_ly = clamp_i(rotation_pulse_ly, -32, 32);
                }
        
        
                // =================== BITMAP DRAWING (PANDA AIM METHOD) ====================
                int __pictureWidth, __pictureX, __pictureHeight, __pictureY, __pictureBit, __pictureOffset, __pictureData;
                int __pictureX2, __pictureY2;
                function draw_picture(x, y) {
                    __pictureOffset = 1;
                    __pictureBit = 0;
                    __pictureWidth = zendaddy_logo[0];
                    __pictureHeight = zendaddy_logo[1];
                    for (__pictureY = 0; __pictureY < __pictureHeight; __pictureY++) {
                        __pictureY2 = y + __pictureY;
                        // CLAMP Y instead of wrapping (Cronus Zen firmware fix)
                        if (__pictureY2 < 0 || __pictureY2 >= 64) {
                            // Skip entire row if outside bounds
                            for (__pictureX = 0; __pictureX < __pictureWidth; __pictureX++) {
                                if (!__pictureBit) {
                                    __pictureBit = 16;
                                    __pictureOffset++;
                                    __pictureData = zendaddy_logo[__pictureOffset];
                                }
                                __pictureBit--;
                            }
                            continue;
                        }
                        for (__pictureX = 0; __pictureX < __pictureWidth; __pictureX++) {
                            if (!__pictureBit) {
                                __pictureBit = 16;
                                __pictureOffset++;
                                __pictureData = zendaddy_logo[__pictureOffset];
                            }
                            __pictureBit--;
                            __pictureX2 = x + __pictureX;
                            // CLAMP X instead of wrapping (Cronus Zen firmware fix)
                            if (__pictureX2 < 0 || __pictureX2 >= 128) {
                                continue;  // Skip pixel if outside bounds
                            }
                            pixel_oled(__pictureX2, __pictureY2, test_bit(__pictureData, __pictureBit));
                        }
                    }
                }
        
                // =================== OLED: SPLASH ====================
                function splash_draw(){
                    cls_oled(1);  // WHITE background - shows black outline!
        
                    // BIGGER ZENDADDY Logo - 120x64 pixels (25% larger!)
                    // X=(128-120)/2=4 (centered), Y=0 (top)
                    draw_picture(4, 0);
                }
        
        
        
        
                // ============== DRIFT-FREE SCALING (REDESIGNED!) ==============
                // CRITICAL: Slider 50 = 100% (NEUTRAL - preserves base values!)
                // 0 = 0%, 50 = 100%, 100 = 200%
                // This prevents drift: both ADS and hipfire scale RELATIVE to tuned bases
        
                // ============== DRIFT-FREE SCALING (REDESIGNED!) ==============
                // CRITICAL: Slider 50 = 100% (NEUTRAL - preserves base values!)
                // 0 = 0%, 50 = 100%, 100 = 200%
                // This prevents drift: both ADS and hipfire scale RELATIVE to tuned bases
        
                function apply_drift_free_scaling(base, slider_val){
                    if(slider_val == 0) return 0;  // Disabled
        
                    // Slider 50 = 100% (neutral!)
                    if(slider_val <= 50){
                        g_val = slider_val * 2;  // 0→50 maps to 0→100%
                    }
                    else {
                        g_val = 100 + ((slider_val - 50) * 2);  // 51→100 maps to 102→200%
                    }
        
                    return (base * g_val) / 100;
                }
        
                function apply_curve_strength_gain(value){
                    if(value <= 0) return value;
                    if(curve_mode == CURVE_MODE_EXPO) return (value * CURVE_EXPO_STRENGTH_GAIN) / 100;
                    return (value * CURVE_LINEAR_STRENGTH_GAIN) / 100;
                }
        
                function apply_curve_rotation_gain(value){
                    if(value <= 0) return value;
                    if(curve_mode == CURVE_MODE_EXPO) return (value * CURVE_EXPO_ROTATION_GAIN) / 100;
                    return (value * CURVE_LINEAR_ROTATION_GAIN) / 100;
                }
        
                function apply_curve_range_gain(value){
                    if(value <= 0) return value;
                    if(curve_mode == CURVE_MODE_EXPO) return (value * CURVE_EXPO_RANGE_GAIN) / 100;
                    return (value * CURVE_LINEAR_RANGE_GAIN) / 100;
                }
        
                function apply_slider_scaling(){
                    if(ads){
                        current_strength_slider = slider_ads_strength;
                        current_rotation_slider = slider_ads_rotation;
                    } else {
                        current_strength_slider = slider_hip_strength;
                        current_rotation_slider = slider_hip_rotation;
                    }
        
                    strength_scale_pct = apply_curve_strength_gain(apply_drift_free_scaling(100, current_strength_slider));
                    rotation_scale_pct = apply_curve_rotation_gain(apply_drift_free_scaling(100, current_rotation_slider));
                }
        
                function update_smoothness_scales(){
                    smoothness_scale_pct = clamp_i(slider_smoothness, 0, 100);
                    smoothness_noise_pct = 100 - smoothness_scale_pct;
        
                    // Slider 0 = raw (aggressive), 100 = ultra smooth
                    smoothness_orbit_timer_ms = lerp_pct(2, 8, smoothness_scale_pct);
                    smoothness_orbit_radius_pct = lerp_pct(130, 60, smoothness_scale_pct);
                    smoothness_virtual_smooth_gain = lerp_pct(68, 32, smoothness_scale_pct);
                    smoothness_idle_jitter_pct = lerp_pct(100, 18, smoothness_scale_pct);
                }
        
                function update_curve_mode_state(){
                    if(slider_curve_mode >= 50){
                        curve_mode = CURVE_MODE_EXPO;
                    } else {
                        curve_mode = CURVE_MODE_LINEAR;
                    }
                }
        
                function waveform_seed(seed){
                    if(seed == 0) seed = 1;
                    waveform_rng_state = seed & 0x7FFF;
                    if(waveform_rng_state == 0) waveform_rng_state = 12345;
                }
        
                function waveform_rand(){
                    waveform_rng_state = (waveform_rng_state * 214013 + 2531011) & 0x7FFF;
                    return waveform_rng_state;
                }
        
                function waveform_rand_range(min_val, max_val){
                    if(max_val <= min_val) return min_val;
                    // Gebruik globals g_total (span) en g_fill (rnd) i.v.m. GPC beperkingen
                    g_total = max_val - min_val + 1; // span
                    g_fill = waveform_rand() % g_total; // rnd
                    return min_val + g_fill;
                }
        
                function waveform_rand_signed(range_val){
                    if(range_val <= 0) return 0;
                    return waveform_rand_range(0, range_val * 2) - range_val;
                }
        
                function update_weapon_profile_detection(){
                    weapon_detect_score[WEAPON_PROFILE_AR] = 45;
                    weapon_detect_score[WEAPON_PROFILE_ONESHOT] = 12;
                    weapon_detect_score[WEAPON_PROFILE_SNIPER] = 12;
        
                    if(ads){
                        weapon_detect_score[WEAPON_PROFILE_AR] = weapon_detect_score[WEAPON_PROFILE_AR] + 20;
                        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 10;
                    }
                    if(oneshot_mode){
                        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 55;
                    }
                    if(sniper_mode){
                        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 60;
                    }
                    if(hipfire_sticky_active){
                        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 18;
                    }
                    if(aerial_mode){
                        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 12;
                        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 8;
                    }
                    if(hyper_burst_active){
                        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 10;
                    }
                    if(distance_pixels >= BUBBLE_ZONE_FAR){
                        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 12;
                    } else if(distance_pixels <= BUBBLE_ZONE_CLOSE){
                        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 10;
                    }
        
                    if(shot_interval > 0){
                        if(shot_interval <= WEAPON_AR_TIME){
                            weapon_detect_score[WEAPON_PROFILE_AR] = weapon_detect_score[WEAPON_PROFILE_AR] + 22;
                        } else if(shot_interval >= WEAPON_SNIPER_TIME){
                            weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 22;
                        } else if(shot_interval >= WEAPON_SHOTGUN_TIME){
                            weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 24;
                        }
                    }
        
                    if(ads && shot_timer > 0 && shot_timer <= WEAPON_QUICK_SCOPE){
                        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 15;
                    }
        
                    g_total = 0;
                    while(g_total < WEAPON_PROFILE_COUNT){
                        weapon_detect_score[g_total] = clamp_i(weapon_detect_score[g_total], 0, 100);
                        weapon_profile_confidence[g_total] = smooth_gain(weapon_profile_confidence[g_total], weapon_detect_score[g_total], 30);
                        g_total = g_total + 1;
                    }
        
                    g_val = weapon_profile_target;
                    if(g_val < 0 || g_val >= WEAPON_PROFILE_COUNT){
                        g_val = WEAPON_PROFILE_AR;
                    }
                    g_temp = weapon_profile_confidence[g_val];
        
                    g_total = 0;
                    while(g_total < WEAPON_PROFILE_COUNT){
                        if(weapon_profile_confidence[g_total] > g_temp + 6){
                            g_val = g_total;
                            g_temp = weapon_profile_confidence[g_total];
                        }
                        g_total = g_total + 1;
                    }
        
                    weapon_profile_target = g_val;
                }
        
                function forced_fire_reset(){
                    forced_fire_override = 0;
                    forced_fire_release_timer = 0;
                    forced_fire_pulse_timer = 0;
                    forced_fire_reassert_timer = 0;
                    forced_fire_input_active = 0;
                    forced_fire_active = 0;
                    forced_fire_armed = 0;
                    forced_fire_has_physical = 0;
                }
        
                function update_forced_fire(){
                    if(!forced_fire_enabled){
                        forced_fire_reset();
                        return;
                    }
        
                    if(menu_mode || build_mode || edit_mode || !aim_on){
                        forced_fire_reset();
                        return;
                    }
        
                    if(event_press(BTN_SHOOT) && raw_r2_physical >= FORCED_FIRE_TRIGGER_LEVEL){
                        forced_fire_armed = 1;
                        if(oneshot_mode){
                            forced_fire_pulse_timer = FORCED_FIRE_PULSE_ONESHOT;
                        } else {
                            forced_fire_pulse_timer = FORCED_FIRE_PULSE_REGULAR;
                        }
                    }
        
                    if(event_release(BTN_SHOOT)){
                        forced_fire_armed = 0;
                    }
        
                    g_total = forced_fire_active;
        
                    g_val = raw_r2_physical;
                    forced_fire_input_active = 0;
                    if(g_val >= FORCED_FIRE_TRIGGER_LEVEL){
                        forced_fire_input_active = 1;
                        forced_fire_release_timer = FORCED_FIRE_RELEASE_HOLD;
                        forced_fire_reassert_timer = FORCED_FIRE_RELEASE_HOLD;
                        forced_fire_has_physical = 1;
                    }
        
                    if(forced_fire_release_timer > 0){
                        forced_fire_release_timer = forced_fire_release_timer - delta;
                        if(forced_fire_release_timer < 0) forced_fire_release_timer = 0;
                    }
        
                    if(forced_fire_pulse_timer > 0){
                        forced_fire_pulse_timer = forced_fire_pulse_timer - delta;
                        if(forced_fire_pulse_timer < 0) forced_fire_pulse_timer = 0;
                    }
        
                    if(forced_fire_reassert_timer > 0){
                        forced_fire_reassert_timer = forced_fire_reassert_timer - delta;
                        if(forced_fire_reassert_timer < 0) forced_fire_reassert_timer = 0;
                    }
        
                    if(g_total && forced_fire_armed && !forced_fire_input_active && forced_fire_release_timer == 0 && forced_fire_pulse_timer == 0 && forced_fire_reassert_timer == 0){
                        if(oneshot_mode){
                            forced_fire_pulse_timer = FORCED_FIRE_PULSE_ONESHOT;
                            forced_fire_reassert_timer = FORCED_FIRE_PULSE_ONESHOT;
                        } else {
                            forced_fire_pulse_timer = FORCED_FIRE_PULSE_REGULAR;
                            forced_fire_reassert_timer = FORCED_FIRE_PULSE_REGULAR;
                        }
                    }
        
                    if(g_val < (FORCED_FIRE_TRIGGER_LEVEL - 6) && forced_fire_armed == 0 && forced_fire_release_timer == 0){
                        forced_fire_pulse_timer = 0;
                    }
        
                    if(!forced_fire_input_active && forced_fire_has_physical && forced_fire_release_timer == 0 && forced_fire_pulse_timer == 0 && forced_fire_reassert_timer == 0){
                        forced_fire_has_physical = 0;
                        forced_fire_armed = 0;
                    }
        
                    if(!forced_fire_input_active){
                        forced_fire_override = 0;
                        forced_fire_active = 0;
                        forced_fire_has_physical = 0;
                        forced_fire_armed = 0;
                        forced_fire_release_timer = 0;
                        forced_fire_pulse_timer = 0;
                        forced_fire_reassert_timer = 0;
                        return;
                    }
        
                    forced_fire_active = 1;
                    forced_fire_override = 0;
                    if(raw_r2_physical < FORCED_FIRE_PRESS_VALUE){
                        forced_fire_override = 1;
                    }
                }
        
                function toggle_subsystem(mask){
                    subsystem_flags = subsystem_flags ^ mask;
                }
        
        
                function get_zone_slider_value(zone){
                    if(zone <= 1) return slider_close;
                    if(zone == 2) return slider_medium;
                    return slider_far;
                }
        
                // GEMINI STEP 2: THE SUM - DETECTING IN-GAME SLOWDOWN
                function update_native_assist_sensing(){
                    native_probe_rx = 0;
                    native_probe_ry = 0;
                    
                    // Capture previous frames to calculate "The Sum (Delta)"
                    native_prev_raw_rx[2] = native_prev_raw_rx[1];
                    native_prev_raw_rx[1] = native_prev_raw_rx[0];
                    native_prev_raw_rx[0] = raw_rx;
                    
                    native_prev_raw_ry[2] = native_prev_raw_ry[1];
                    native_prev_raw_ry[1] = native_prev_raw_ry[0];
                    native_prev_raw_ry[0] = raw_ry;
                    
                    native_delta_frames = native_delta_frames + 1;
                    if(native_delta_frames > 3) native_delta_frames = 3;
                    
                    // Only process detection if Search Pulse is active
                    if(pulse_magnitude > 0 && !magnet_capture_active && native_delta_frames >= 3){
                        // Calculate Expected Movement (Pulse + Input Trend)
                        g_val = (native_prev_raw_rx[1] - native_prev_raw_rx[2]); // Trend X
                        g_temp = (native_prev_raw_ry[1] - native_prev_raw_ry[2]); // Trend Y
                        
                        // Calculate Actual Movement (Current - Previous)
                        g_chars = (raw_rx - native_prev_raw_rx[1]); // Actual X
                        g_total = (raw_ry - native_prev_raw_ry[1]); // Actual Y
                        
                        // "The Sum": Difference between expected and actual
                        // If native AA slows us down, Actual < Expected
                        g_expected = abs(g_val) + abs(g_temp); // Expected Mag
                        g_fill = abs(g_chars) + abs(g_total);  // Actual Mag
                        
                        // Detection Threshold: If Actual is significantly less than Expected
                        // But we must account for user stopping. 
                        // We check if user INPUT is still applied but OUTPUT (in game context) is perceived as slowing?
                        // Since we can't read Game Output, we infer:
                        // If Pulse is pushing, but user is counter-acting or holding steady in a specific way that matches "tracking behavior"
                        
                        // SIMULATED DETECTION:
                        // If Search Pulse is ACTIVE and user input is STEADY (Tracking) -> LOCK
                        if((aim_error_variance < 5) && (input_velocity < 15) && (input_velocity > 2)){
                            // We are tracking steadily while pulse is shaking. 
                            // Assume we found something.
                            native_signal_stack = native_signal_stack + 1;
                        } else {
                            if(native_signal_stack > 0) native_signal_stack = native_signal_stack - 1;
                        }
                        
                        // If we have a stack of detection signals
                        if(native_signal_stack >= NATIVE_SIGNAL_STACK_TARGET){
                            // TRIGGER GEMINI STEP 3: LOCK
                            magnet_capture_active = 1;
                            magnet_capture_strength = 100; // Instant Max
                            magnet_capture_hold_timer = NATIVE_GLUE_PERSIST_MS;
                            native_capture_gate = 1;
                            
                            // Apply Aggressive Correction (x1000 Logic)
                            lock_confidence = 100;
                            target_locked = 1;
                            aim_state_resistance_pct = 300; // Max resist
                        }
                    }
                }
        
                function apply_overdrive_boosts(){
                    overdrive_bias_rx = 0;
                    overdrive_bias_ry = 0;
                    overdrive_rotation_cap = (OVERDRIVE_ROT_CAP * rotation_scale_pct) / 100;
                    if(overdrive_rotation_cap < OVERDRIVE_ROT_CAP) overdrive_rotation_cap = OVERDRIVE_ROT_CAP;
                    if(overdrive_rotation_cap > 60) overdrive_rotation_cap = 60;
        
                    g_val = 0;
                    if(native_capture_gate && magnet_lock_gate && !ads && aim_on){
                        g_val = 1;
                    }
                    // Hip auto-correct v8.9: amplifies bullet correction when hip oneshot/magnet engagement is detected.
                    // Multi-source gating (oneshot/magnet/engage/sticky) keeps the crosshair glued without affecting free-look states.
                    if(!ads && bullet_correct_gain > 0){
                        g_val = 1;
                    }
                    if(!ads && hipfire_glue_weight > 40){
                        g_val = 1;
                    }
        
                    if(g_val){
                        overdrive_active = 1;
                        g_temp = OVERDRIVE_PERSIST_MS;
                        if(hipfire_sticky_active || hipfire_engaged){
                            g_temp = g_temp + 120;
                        }
                        if(overdrive_timer < g_temp) overdrive_timer = g_temp;
                    }
        
                    if(overdrive_timer > 0){
                        overdrive_timer = overdrive_timer - delta;
                        if(overdrive_timer < 0) overdrive_timer = 0;
                    }
        
                    if(overdrive_active){
                        if(overdrive_timer == 0 || panic_triggered > 0 || freedom_release_active || input_velocity >= OVERDRIVE_RELEASE_JERK_GATE){
                            overdrive_active = 0;
                            overdrive_timer = 0;
                        }
                    }
        
                    overdrive_scale_pct = rotation_scale_pct;
                    if(overdrive_scale_pct < OVERDRIVE_SLIDER_MIN) overdrive_scale_pct = OVERDRIVE_SLIDER_MIN;
                    if(overdrive_scale_pct > OVERDRIVE_SLIDER_MAX) overdrive_scale_pct = OVERDRIVE_SLIDER_MAX;
        
                    if(!overdrive_active){
                        overdrive_rotation_pct = OVERDRIVE_ROT_MULT_BASE;
                        overdrive_bias_scale = 0;
                        return;
                    }
        
                    if(curve_mode == CURVE_MODE_EXPO){
                        overdrive_curve_gain = OVERDRIVE_EXPO_CURVE_GAIN;
                    } else {
                        overdrive_curve_gain = OVERDRIVE_LINEAR_CURVE_GAIN;
                    }
        
                    overdrive_rotation_pct = (overdrive_curve_gain * overdrive_scale_pct) / 100;
                    if(overdrive_rotation_pct < OVERDRIVE_ROT_MULT_BASE) overdrive_rotation_pct = OVERDRIVE_ROT_MULT_BASE;
                    if(overdrive_rotation_pct > OVERDRIVE_ROT_MULT_MAX) overdrive_rotation_pct = OVERDRIVE_ROT_MULT_MAX;
        
                    assist_rotation_blend = clamp_i((assist_rotation_blend * overdrive_rotation_pct) / 100, 0, 100);
                    aim_state_resistance_pct = clamp_i(aim_state_resistance_pct + (overdrive_scale_pct / 3), 40, 240);
                    hipfire_resistance_bonus = clamp_i(hipfire_resistance_bonus + (overdrive_scale_pct / 4), 0, 160);
        
                    g_val = clamp_i(overdrive_scale_pct, 50, 100);
                    if(slowdown_factor > OVERDRIVE_SLOWDOWN_FLOOR){
                        slowdown_factor = lerp_pct(slowdown_factor, OVERDRIVE_SLOWDOWN_FLOOR, g_val);
                    }
        
                    momentum_x = (momentum_x * OVERDRIVE_MOMENTUM_GAIN) / 100;
                    momentum_y = (momentum_y * OVERDRIVE_MOMENTUM_GAIN) / 100;
        
                    overdrive_bias_scale = (OVERDRIVE_BIAS_BLEND * overdrive_scale_pct) / 100;
                    overdrive_bias_scale = clamp_i(overdrive_bias_scale, 40, 140);
        
                    g_temp = predict_offset_x - pixel_offset_x;
                    g_chars = predict_offset_y - pixel_offset_y;
                    overdrive_bias_rx = (g_temp * overdrive_bias_scale) / 140;
                    overdrive_bias_ry = (g_chars * overdrive_bias_scale) / 160;
        
                    if(ai_confidence_pct > 0){
                        g_total = (ai_output_rx * overdrive_bias_scale) / 220;
                        g_expected = (ai_output_ry * overdrive_bias_scale) / 220;
                        overdrive_bias_rx = overdrive_bias_rx + g_total;
                        overdrive_bias_ry = overdrive_bias_ry + g_expected;
                    }
        
                    if(ballistic_active > 0){
                        g_val = (ballistic_travel_offset_x * BALLISTIC_OVERDRIVE_BLEND) / 100;
                        g_val = g_val / BALLISTIC_STICK_DIVISOR;
                        overdrive_bias_rx = overdrive_bias_rx + (g_val * ballistic_active) / 100;
        
                        g_temp = (ballistic_drop_offset * BALLISTIC_OVERDRIVE_BLEND) / 100;
                        g_temp = g_temp / BALLISTIC_STICK_DIVISOR;
                        overdrive_bias_ry = overdrive_bias_ry - (g_temp * ballistic_active) / 100;
                    }
        
                    overdrive_bias_rx = clamp_i(overdrive_bias_rx, -overdrive_rotation_cap, overdrive_rotation_cap);
                    overdrive_bias_ry = clamp_i(overdrive_bias_ry, -overdrive_rotation_cap, overdrive_rotation_cap);
        
                    if(align_suppress_freeze){
                        overdrive_bias_rx = 0;
                        overdrive_bias_ry = 0;
                    }
        
                    if(search_release_pct > 0){
                        g_val = lerp_pct(100, UE_SEARCH_RELEASE_ROT, search_release_pct);
                        overdrive_bias_rx = (overdrive_bias_rx * g_val) / 100;
                        overdrive_bias_ry = (overdrive_bias_ry * g_val) / 100;
                    }
                    if(search_output_pct < 100){
                        overdrive_bias_rx = (overdrive_bias_rx * search_output_pct) / 100;
                        overdrive_bias_ry = (overdrive_bias_ry * search_output_pct) / 100;
                    }
                }
        
                function update_sticky_edge_weight(){
                    if(sticky_edge_flip_timer > 0){
                        sticky_edge_flip_timer = sticky_edge_flip_timer - delta;
                        if(sticky_edge_flip_timer < 0) sticky_edge_flip_timer = 0;
                    }
                    if(sticky_edge_timer > 0 && !sticky_edge_active){
                        sticky_edge_timer = sticky_edge_timer - delta;
                        if(sticky_edge_timer < 0) sticky_edge_timer = 0;
                    }
        
                    sticky_edge_weight = 0;
                    if(distance_pixels > bubble_zone_edges[4] + STICKY_EDGE_MARGIN){
                        sticky_edge_recent_sign = 0;
                        if(sticky_edge_flip_timer == 0){
                            sticky_edge_flip_count = 0;
                        }
                        sticky_edge_active = 0;
                        sticky_edge_boost = 0;
                        sticky_edge_snap_boost = 0;
                        return;
                    }
        
                    g_temp = 0;
                    while(g_temp < 5){
                        g_val = bubble_zone_edges[g_temp];
                        g_p = distance_pixels - g_val;
                        if(g_p < 0) g_p = 0 - g_p;
                        if(g_p <= STICKY_EDGE_MARGIN){
                            sticky_edge_weight = 100 - ((g_p * 100) / STICKY_EDGE_MARGIN);
                            break;
                        }
                        g_temp = g_temp + 1;
                    }
        
                    if(sticky_edge_weight == 0 && distance_pixels <= STICKY_EDGE_MARGIN){
                        sticky_edge_weight = 100 - ((distance_pixels * 100) / STICKY_EDGE_MARGIN);
                    }
                    if(sticky_edge_weight < 0) sticky_edge_weight = 0;
                    if(sticky_edge_weight > 100) sticky_edge_weight = 100;
        
                    g_expected = 0; // current_sign
                    if(distance_delta > 1) g_expected = 1;
                    else if(distance_delta < -1) g_expected = -1;
        
                    if(sticky_edge_weight >= 50 && g_expected != 0){
                        if(g_expected != sticky_edge_recent_sign){
                            if(sticky_edge_flip_timer == 0){
                                sticky_edge_flip_count = 1;
                            } else {
                                sticky_edge_flip_count = sticky_edge_flip_count + 1;
                                if(sticky_edge_flip_count > 4) sticky_edge_flip_count = 4;
                            }
                            sticky_edge_flip_timer = 140;
                            sticky_edge_recent_sign = g_expected;
                        } else if(sticky_edge_flip_timer == 0){
                            sticky_edge_flip_count = clamp_i(sticky_edge_flip_count - 1, 0, 4);
                        }
                    } else if(sticky_edge_weight < 25){
                        if(sticky_edge_flip_timer == 0){
                            sticky_edge_flip_count = 0;
                            sticky_edge_recent_sign = 0;
                        }
                    }
        
                    if(sticky_edge_flip_timer == 0 && sticky_edge_flip_count > 0){
                        sticky_edge_flip_count = clamp_i(sticky_edge_flip_count - 1, 0, 4);
                    }
        
                    sticky_edge_active = (sticky_edge_weight >= 55 && sticky_edge_flip_count >= 2);
                    if(sticky_edge_active){
                        sticky_edge_timer = sticky_edge_timer + delta;
                        if(sticky_edge_timer > 220) sticky_edge_timer = 220;
                    }
        
                    g_tboost = 0; // ramp_pct
                    if(sticky_edge_timer > 0){
                        g_tboost = (sticky_edge_timer * 100) / 160;
                        if(g_tboost > 100) g_tboost = 100;
                    }
        
                    g_val = 30 + (sticky_edge_flip_count * 12); // flip_scale, using g_val
                    sticky_edge_boost = (sticky_edge_weight * g_val * g_tboost) / 10000;
                    sticky_edge_boost = clamp_i(sticky_edge_boost, 12, 60);
        
                    g_temp = 40 + (sticky_edge_flip_count * 15); // snap_scale, using g_temp
                    sticky_edge_snap_boost = (sticky_edge_weight * g_temp * g_tboost) / 10000;
                    sticky_edge_snap_boost = clamp_i(sticky_edge_snap_boost, 10, 70);
        
                    if(!sticky_edge_active){
                        sticky_edge_boost = (sticky_edge_weight * STICKY_EDGE_GAIN) / 120;
                        sticky_edge_snap_boost = (sticky_edge_weight * STICKY_EDGE_SNAP_GAIN) / 120;
                    }
                }
        
                function slowdown_event_reset(){
                    slowdown_ratio_metric = 100;
                    slowdown_signal = 100;
                    slowdown_event_timer = 0;
                    slowdown_decay_timer = 0;
                    slowdown_depth_pct = 0;
                    slowdown_event_active = 0;
                    slowdown_led_state = 0;
                }
        
                function slowdown_event_preupdate(){
                    if(slowdown_event_timer > 0){
                        slowdown_event_timer = slowdown_event_timer - delta;
                        if(slowdown_event_timer < 0) slowdown_event_timer = 0;
                    }
                    if(slowdown_decay_timer > 0){
                        slowdown_decay_timer = slowdown_decay_timer - delta;
                        if(slowdown_decay_timer < 0) slowdown_decay_timer = 0;
                    }
                    if(slowdown_event_timer == 0 && slowdown_decay_timer == 0){
                        slowdown_event_active = 0;
                        slowdown_depth_pct = smooth_gain(slowdown_depth_pct, 0, 18);
                    } else {
                        slowdown_event_active = 1;
                    }
                    slowdown_led_state = slowdown_event_active;
                }
        
                function slowdown_event_release_check(){
                    if(slowdown_event_active){
                        if(panic_triggered > 0 || input_velocity > 32 || aim_error_pixels > 32){
                            slowdown_event_timer = 0;
                            slowdown_decay_timer = 0;
                            slowdown_event_active = 0;
                        }
                    }
                    if(slowdown_event_timer == 0 && slowdown_decay_timer == 0){
                        slowdown_depth_pct = smooth_gain(slowdown_depth_pct, 0, 18);
                        slowdown_event_active = 0;
                    }
                    slowdown_led_state = slowdown_event_active;
                }
        
                function slowdown_event_process_signal(){
                    g_val = abs(raw_rx) + abs(raw_ry) + 1;
                    g_temp = abs(final_rx) + abs(final_ry) + 1;
                    slowdown_ratio_metric = (g_val * 100) / g_temp;
                    if(slowdown_ratio_metric > 250) slowdown_ratio_metric = 250;
        
                    g_chars = clamp_i(native_curve_metric, 60, 160) - 60;
                    if(g_chars < 0) g_chars = 0;
                    if(g_chars > 100) g_chars = 100;
        
                    g_total = slowdown_ratio_metric;
                    if(g_total <= 100){
                        g_total = 100;
                    } else {
                        g_total = 200 - g_total;
                        if(g_total < 0) g_total = 0;
                    }
                    if(g_total > 100) g_total = 100;
        
                    g_expected = clamp_i(slowdown_factor, 0, 100);
        
                    slowdown_signal = (g_chars * 40 + g_total * 35 + g_expected * 25) / 100;
                    slowdown_signal = clamp_i(slowdown_signal, 0, 100);
        
                    if(slowdown_signal <= 70 && input_velocity <= 26 && aim_error_pixels <= 28){
                        slowdown_event_timer = 40;
                        slowdown_decay_timer = 120;
                        slowdown_event_active = 1;
                    }
        
                    if(slowdown_event_active){
                        g_fill = clamp_i(((70 - slowdown_signal) * 125) / 100, 0, 100);
                        if(g_fill > slowdown_depth_pct){
                            slowdown_depth_pct = g_fill;
                        } else {
                            slowdown_depth_pct = smooth_gain(slowdown_depth_pct, g_fill, 18);
                        }
                    }
        
                    if(slowdown_event_timer == 0 && slowdown_decay_timer > 0){
                        slowdown_depth_pct = smooth_gain(slowdown_depth_pct, 0, 12);
                    }
        
                    if(slowdown_event_timer == 0 && slowdown_decay_timer == 0){
                        slowdown_event_active = 0;
                    }
        
                    slowdown_led_state = slowdown_event_active;
                }
        
                // ============== INPUT VELOCITY TRACKER (ADAPTIVE!) ==============
                // Measure how fast USER is moving stick (not Fortnite's output!)
                // Fast input = corrections → disable resistance (vrije beweging)
                // Slow input = tracking → enable resistance (sticky)
                function update_input_velocity(){
                    // Re-read FRESH rx/ry values to ensure current frame data
                    g_val = get_val(AXIS_RX);
                    g_temp = get_val(AXIS_RY);
        
                    // Apply deadzone
                    if(abs(g_val) < DEADZONE_BASE) g_val = 0;
                    if(abs(g_temp) < DEADZONE_BASE) g_temp = 0;
        
                    // Calculate raw input delta (absolute change per frame)
                    input_velocity = abs(g_val - prev_rx) + abs(g_temp - prev_ry);
        
                    // Store current for next frame
                    prev_rx = g_val;
                    prev_ry = g_temp;
        
                    if(input_velocity >= FREEDOM_RELEASE_THRESHOLD && lock_confidence < 35 && assist_core_blend < 45){
                        freedom_release_timer = FREEDOM_RELEASE_RECOVER;
                    }
        
                    if(freedom_release_timer > 0){
                        freedom_release_timer = freedom_release_timer - delta;
                        if(freedom_release_timer < 0) freedom_release_timer = 0;
                    }
        
                    freedom_release_active = (freedom_release_timer > 0);
                    if(freedom_release_active){
                        freedom_release_target = 100;
                    } else {
                        freedom_release_target = 0;
                    }
        
                    g_expected = 0;
                    if(auto_aim_overrun_active) g_expected = 1;
                    if(bullet_correct_gain > 0) g_expected = 1;
                    if(magnet_capture_active) g_expected = 1;
        
                    if(g_expected && freedom_release_active){
                        freedom_release_timer = 0;
                        freedom_release_active = 0;
                        freedom_release_blend = 0;
                        freedom_release_target = 0;
                    }
        
                    // 🚨 PANIC MODE: Instant disable at extreme speeds (360 flicks, super-fast tracking)
                    if(input_velocity >= INPUT_VELOCITY_PANIC){
                        if(!g_expected){
                            resistance_active = 0;  // FULL DISABLE - zero interference!
                            velocity_hysteresis_active = 0;
                            return;
                        }
                    }
        
                    // CRITICAL: Only allow resistance INSIDE bubble when locked!
                    // This prevents "magnetic repulsion" during target acquisition
                    // Check BOTH lock status AND true pixel distance (not processed stick values!)
                    if(!g_expected){
                        if(!magnet_lock_gate || distance_pixels > STICK_RESISTANCE_THRESHOLD){
                            resistance_active = 0;  // FORCE DISABLE outside bubble!
                            velocity_hysteresis_active = 0;
                            return;
                        }
        
                        // Additional safety: if we somehow got here with large distance, force disable
                        if(!magnet_lock_gate && distance_pixels > 20){
                            resistance_active = 0;
                            velocity_hysteresis_active = 0;
                            return;
                        }
                    }
        
                    // ✅ DUAL-THRESHOLD HYSTERESIS (Architect approved!)
                    // ENABLE threshold (low) vs DISABLE threshold (also low) creates smooth buffer
                    // FAST thresholds for instant override
                    g_val = INPUT_VELOCITY_ENABLE_HIP;      // 15 units - enable assist
                    g_temp = INPUT_VELOCITY_DISABLE_HIP;    // 8 units - disable assist
                    g_tboost = INPUT_VELOCITY_FAST_HIP;     // 65 units - instant disable
        
                    if(ads){
                        g_val = INPUT_VELOCITY_ENABLE_ADS;   // 20 units
                        g_temp = INPUT_VELOCITY_DISABLE_ADS; // 12 units
                        g_tboost = INPUT_VELOCITY_FAST_ADS;  // 70 units
                    }
        
                    // Check for FAST movement first - instant disable
                    if(!g_expected && input_velocity >= g_tboost){
                        velocity_hysteresis_active = 0;
                        resistance_active = 0;
                        return;
                    }
        
                    // Hysteresis state machine
                    if(g_expected){
                        velocity_hysteresis_active = 1;
                        resistance_active = 1;
                        return;
                    }
        
                    if(velocity_hysteresis_active){
                        // Currently active - disable if velocity drops BELOW disable threshold
                        if(input_velocity < g_temp){
                            velocity_hysteresis_active = 0;
                            resistance_active = 0;
                        }
                        else {
                            resistance_active = 1;  // Keep active
                        }
                    }
                    else {
                        // Currently disabled - enable if velocity drops BELOW enable threshold
                        if(input_velocity < g_val){
                            velocity_hysteresis_active = 1;
                            resistance_active = 1;
                        }
                    }
                }
        
                function update_hip_fast_tracking(){
                    if(ads || !aim_on || build_mode || edit_mode){
                        hip_fast_track_active = 0;
                        hip_fast_track_timer = 0;
                        return;
                    }
        
                    if(!magnet_lock_gate && !hipfire_sticky_active && !hipfire_engaged){
                        if(hip_fast_track_timer > 0){
                            hip_fast_track_timer = hip_fast_track_timer - delta;
                            if(hip_fast_track_timer < 0) hip_fast_track_timer = 0;
                        }
                        hip_fast_track_active = 0;
                        return;
                    }
        
                    g_val = input_velocity;
        
                    if(g_val >= HIP_FAST_INPUT_GATE){
                        hip_fast_track_active = 1;
                        hip_fast_track_timer = HIP_FAST_TIMER_BONUS;
                        return;
                    }
        
                    if(hip_fast_track_active){
                        if(g_val >= (HIP_FAST_INPUT_GATE - HIP_FAST_INPUT_GRACE)){
                            hip_fast_track_timer = HIP_FAST_TIMER_BONUS;
                            return;
                        }
                        if(hip_fast_track_timer > 0){
                            hip_fast_track_timer = hip_fast_track_timer - delta;
                            if(hip_fast_track_timer > 0){
                                return;
                            }
                        }
                        hip_fast_track_active = 0;
                        hip_fast_track_timer = 0;
                        return;
                    }
        
                    if(g_val >= (HIP_FAST_INPUT_GATE - HIP_FAST_INPUT_GRACE)){
                        hip_fast_track_active = 1;
                        hip_fast_track_timer = HIP_FAST_TIMER_BONUS;
                        return;
                    }
        
                    if(hip_fast_track_timer > 0){
                        hip_fast_track_timer = hip_fast_track_timer - delta;
                        if(hip_fast_track_timer < 0) hip_fast_track_timer = 0;
                    }
                }
        
                function update_ballistic_compensation(){
                    g_val = clamp_i(distance_pixels, 0, BALLISTIC_RANGE_HARD_CAP);
                    if(!aim_on || build_mode || edit_mode || g_val == 0){
                        ballistic_drop_offset = smooth_gain(ballistic_drop_offset, 0, 28);
                        ballistic_travel_offset_x = smooth_gain(ballistic_travel_offset_x, 0, 28);
                        ballistic_active = smooth_gain(ballistic_active, 0, BALLISTIC_ACTIVE_RELEASE_GAIN);
                        return;
                    }
        
                    g_temp = (g_val * 100) / BALLISTIC_RANGE_HARD_CAP;
                    if(g_temp > 100) g_temp = 100;
        
                    g_chars = weapon_profile_current;
                    if(sniper_mode){
                        g_chars = WEAPON_PROFILE_SNIPER;
                    } else if(oneshot_mode){
                        g_chars = WEAPON_PROFILE_ONESHOT;
                    }
        
                    if(g_chars == WEAPON_PROFILE_SNIPER){
                        g_total = BALLISTIC_SNIPER_DROP_NEAR;
                        g_expected = BALLISTIC_SNIPER_DROP_FAR;
                        g_fill = BALLISTIC_TRAVEL_GAIN_SNIPER;
                    } else if(g_chars == WEAPON_PROFILE_ONESHOT){
                        g_total = BALLISTIC_ONESHOT_DROP_NEAR;
                        g_expected = BALLISTIC_ONESHOT_DROP_FAR;
                        g_fill = BALLISTIC_TRAVEL_GAIN_ONESHOT;
                    } else {
                        g_total = BALLISTIC_AR_DROP_NEAR;
                        g_expected = BALLISTIC_AR_DROP_FAR;
                        g_fill = BALLISTIC_TRAVEL_GAIN_AR;
                    }
        
                    g_p = g_total + ((g_expected - g_total) * g_temp) / 100;
        
                    g_chars = clamp_i(enemy_speed_mag, 0, 160);
                    g_p = g_p + (g_chars * BALLISTIC_SPEED_GAIN) / 160;
        
                    if(bullet_correct_timer > 0 || shooting){
                        ballistic_drop_offset = smooth_gain(ballistic_drop_offset, g_p, 22);
                    } else {
                        ballistic_drop_offset = smooth_gain(ballistic_drop_offset, 0, 32);
                    }
        
                    g_total = (enemy_velocity_blend_x * g_fill) / 100;
                    g_expected = (enemy_accel_blend_x * BALLISTIC_SPEED_GAIN) / 220;
                    g_total = g_total + g_expected;
        
                    if(bullet_correct_timer > 0 || shooting){
                        ballistic_travel_offset_x = smooth_gain(ballistic_travel_offset_x, g_total, 22);
                    } else {
                        ballistic_travel_offset_x = smooth_gain(ballistic_travel_offset_x, 0, 32);
                    }
        
                    ballistic_drop_offset = clamp_i(ballistic_drop_offset, 0, BALLISTIC_VERTICAL_CAP);
                    ballistic_travel_offset_x = clamp_i(ballistic_travel_offset_x, 0 - BALLISTIC_VERTICAL_CAP, BALLISTIC_VERTICAL_CAP);
        
                    g_chars = ballistic_travel_offset_x;
                    if(g_chars < 0) g_chars = 0 - g_chars;
                    if(ballistic_drop_offset > g_chars) g_chars = ballistic_drop_offset;
                    g_chars = (g_chars * 100) / BALLISTIC_VERTICAL_CAP;
                    if(g_chars > 100) g_chars = 100;
        
                    if(bullet_correct_timer > 0 || shooting){
                        ballistic_active = smooth_gain(ballistic_active, g_chars, BALLISTIC_ACTIVE_SMOOTH_GAIN);
                    } else {
                        ballistic_active = smooth_gain(ballistic_active, 0, BALLISTIC_ACTIVE_RELEASE_GAIN);
                    }
            ballistic_active = clamp_i(ballistic_active, 0, 100);
        }
        
                // =============== OLED MENU =========================
                function render_menu(){
                    if(active_func==0) g_val = slider_hip_strength;
                    else if(active_func==1) g_val = slider_hip_rotation;
                    else if(active_func==2) g_val = slider_ads_strength;
                    else if(active_func==3) g_val = slider_ads_rotation;
                    else if(active_func==4) g_val = slider_smoothness;
                    else if(active_func==5) g_val = slider_close;
                    else if(active_func==6) g_val = slider_medium;
                    else if(active_func==7) g_val = slider_far;
                    else {
                        if(curve_mode == CURVE_MODE_EXPO){
                            g_val = 100;
                        } else {
                            g_val = 0;
                        }
                    }
        
                    cls_oled(0);
        
                    // SLIDER TITEL - GECENTREERD (9px per char incl spacing!)
                    if(active_func==0){
                        // HIP STR
                        putc_oled(1,72);putc_oled(2,73);putc_oled(3,80);putc_oled(4,32);
                        putc_oled(5,83);putc_oled(6,84);putc_oled(7,82);
                        g_chars = 7;
                    }
                    else if(active_func==1){
                        // HIP ROT
                        putc_oled(1,72);putc_oled(2,73);putc_oled(3,80);putc_oled(4,32);
                        putc_oled(5,82);putc_oled(6,79);putc_oled(7,84);
                        g_chars = 7;
                    }
                    else if(active_func==2){
                        // ADS STR
                        putc_oled(1,65);putc_oled(2,68);putc_oled(3,83);putc_oled(4,32);
                        putc_oled(5,83);putc_oled(6,84);putc_oled(7,82);
                        g_chars = 7;
                    }
                    else if(active_func==3){
                        // ADS ROT
                        putc_oled(1,65);putc_oled(2,68);putc_oled(3,83);putc_oled(4,32);
                        putc_oled(5,82);putc_oled(6,79);putc_oled(7,84);
                        g_chars = 7;
                    }
                    else if(active_func==4){
                        // SMOOTHNESS (10 chars)
                        putc_oled(1,83);putc_oled(2,77);putc_oled(3,79);putc_oled(4,79);
                        putc_oled(5,84);putc_oled(6,72);putc_oled(7,78);putc_oled(8,69);
                        putc_oled(9,83);putc_oled(10,83);
                        g_chars = 10;
                    }
                    else if(active_func==5){
                        // CLOSE (5 chars)
                        putc_oled(1,67);putc_oled(2,76);putc_oled(3,79);putc_oled(4,83);putc_oled(5,69);
                        g_chars = 5;
                    }
                    else if(active_func==6){
                        // MEDIUM (6 chars)
                        putc_oled(1,77);putc_oled(2,69);putc_oled(3,68);putc_oled(4,73);
                        putc_oled(5,85);putc_oled(6,77);
                        g_chars = 6;
                    }
                    else if(active_func==7){
                        // FAR (3 chars)
                        putc_oled(1,70);putc_oled(2,65);putc_oled(3,82);
                        g_chars = 3;
                    }
                    else {
                        if(slider_curve_mode >= 50){
                            putc_oled(1,69);putc_oled(2,88);putc_oled(3,80);putc_oled(4,79);
                            g_chars = 4;
                        } else {
                            putc_oled(1,76);putc_oled(2,73);putc_oled(3,78);putc_oled(4,69);putc_oled(5,65);putc_oled(6,82);
                            g_chars = 6;
                        }
                    }
        
                    // FONT=1 (MEDIUM) is 11px breed volgens officiële docs!
                    if(g_chars > 0){
                        g_temp = (128 - (g_chars * 11)) / 2;
        
                        // TITEL: Y=2 (font 18px + bold 1px = 19px, centered in ruimte boven)
                        puts_oled(g_temp, 2, 1, g_chars, 1);
                        puts_oled(g_temp, 3, 1, g_chars, 1);  // Bold
                    }
        
                    // BAR: Y=24-43 (20px hoog, outline 2px, gelijke spacing boven/onder)
                    rect_oled(12, 24, 104, 2, 1, 1);   // Top outline
                    rect_oled(12, 42, 104, 2, 1, 1);   // Bottom outline
                    rect_oled(12, 24, 2, 20, 1, 1);    // Left outline
                    rect_oled(114, 24, 2, 20, 1, 1);   // Right outline
        
                    // 10 BLOCKS: 8x12px, 2px spacing, Y=28 (binnen bar)
                    if(active_func == 8){
                        g_total = 16;
                        g_chars = 48;
                        rect_oled(g_total, 28, g_chars, 12, 1, 0);
                        rect_oled(g_total + g_chars, 28, g_chars, 12, 1, 0);
                        if(slider_curve_mode < 50){
                            rect_oled(g_total + 1, 29, g_chars - 2, 10, 1, 1);
                        } else {
                            rect_oled(g_total + g_chars + 1, 29, g_chars - 2, 10, 1, 1);
                        }
                    } else {
                        g_fill = (g_val * 10) / 100;
                        g_temp = (g_val * 10) % 100;
        
                        g_chars = 0;
                        while(g_chars < 10){
                            g_expected = 16 + (g_chars * 10);
        
                            if(g_chars < g_fill){
                                rect_oled(g_expected, 28, 8, 12, 1, 1);
                            }
                            else if(g_chars == g_fill && g_temp > 0){
                                g_p = (g_temp * 8) / 100;
                                if(g_p > 0){
                                    rect_oled(g_expected, 28, g_p, 12, 1, 1);
                                }
                            }
                            g_chars = g_chars + 1;
                        }
                    }
        
                    if(active_func != 8){
                        if(g_val == 100){
                            putc_oled(1,49);putc_oled(2,48);putc_oled(3,48);putc_oled(4,37);
                            g_temp = (128 - (4 * 11)) / 2;
                            puts_oled(g_temp, 45, 1, 4, 1);
                            puts_oled(g_temp, 46, 1, 4, 1);
                        }
                        else if(g_val >= 10){
                            putc_oled(1,48+(g_val/10));putc_oled(2,48+(g_val%10));putc_oled(3,37);
                            g_temp = (128 - (3 * 11)) / 2;
                            puts_oled(g_temp, 45, 1, 3, 1);
                            puts_oled(g_temp, 46, 1, 3, 1);
                        }
                        else {
                            putc_oled(1,48+g_val);putc_oled(2,37);
                            g_temp = (128 - (2 * 11)) / 2;
                            puts_oled(g_temp, 45, 1, 2, 1);
                            puts_oled(g_temp, 46, 1, 2, 1);
                        }
                    }
        
                    // LED indicators
                    set_led(LED_1,0); set_led(LED_2,0); set_led(LED_3,0); set_led(LED_4,0);
                    if(active_func <= 1) set_led(LED_1,1);
                    else if(active_func <= 3) set_led(LED_2,1);
                    else if(active_func <= 6) set_led(LED_3,1);
                    else set_led(LED_4,1);
                }
        
                // ============== AIM ASSIST CORE =====================
                function ultimate_master(){
                    apply_slider_scaling();
                    update_smoothness_scales();
            slowdown_event_preupdate();
        
                    hipfire_resistance_bonus = 0;
                    ads_lock_steady_active = 0;
                    micro_x = 0; // Reset micro variables
                    micro_y = 0;
                    // 🔴 HARD STOP: DISABLE IN BUILD/EDIT MODE
                    if(build_mode || edit_mode){
                        combo_stop(UltimateMaster);  // Stop combo explicitly!
                        return;  // Exit immediately - zero processing!
                    }
        
                    // ===== v2.0 IDLE & MOVEMENT TRACKING =====
                    // --- PHASE F: IDLE & MOVEMENT TRACKING (ANTI-DETECTION JITTER) ---
                    // Recalculates intervals based on slider/smoothness and regenerates timers.
                    g_val = smoothness_noise_pct; // Inverse smoothness for stealth factor
        
                    // Update idle pull interval
                    if(idle_timer >= idle_pull_interval){
                        g_temp = (STEALTH_IDLE_JITTER * g_val) / 100;
                        idle_pull_interval = IDLE_AUTO_PULL_TIME + waveform_rand_signed(g_temp);
                        if(idle_pull_interval < 60) idle_pull_interval = 60;
                    }
        
                    // Track camera input voor idle auto-pull
                    if(abs(rx) > 5 || abs(ry) > 5){
                        idle_timer = 0;  // Reset bij camera movement
                    } else {
                        if(idle_timer < idle_pull_interval) idle_timer = idle_timer + delta;
                    }
        
                    // Update movement gate interval
                    if(movement_timer >= movement_gate_interval){
                        g_temp = (STEALTH_MOVEMENT_JITTER * g_val) / 100;
                        movement_gate_interval = MOVEMENT_GATE_TIME + waveform_rand_signed(g_temp);
                        if(movement_gate_interval < 80) movement_gate_interval = 80;
                    }
        
                    // Track movement input (V-Sync)
                    if(abs(lx) > 10 || abs(ly) > 10){
                        if(movement_timer < movement_gate_interval) movement_timer = movement_timer + delta;
                    } else {
                        movement_timer = 0;  // Reset zonder movement
                    }
                    // -----------------------------------------------------------------
        
                    // ===== NIEUWE SCREEN-SPACE SYSTEMS! =====
                    update_screen_space();
                    update_weighted_zones();
                    update_assist_amplification();  // ASSIST AMPLIFICATION - work WITH Fortnite's assist!
                    update_rotation_gate();
                    update_predictive_aim_legacy();
                    update_ai_tracking_engine();
                    update_native_assist_sensing();
        
                    // Oude systems
                    update_bubble_state();
                    get_current_range();
                    if(current_range == 0) range_slider = slider_close;
                    else if(current_range == 1) range_slider = slider_medium;
                    else range_slider = slider_far;
                    range_scale_pct = apply_curve_range_gain(apply_drift_free_scaling(100, range_slider));
                    update_target_lock();
                    update_magnet_capture();
                    update_bubble_center_lock();
                    compute_unreal_search_release();
                    compute_unreal_search_suppress();
                    update_super_blends();
                    update_momentum_accumulator();
                    update_cone_engagement();
                    // Bullet correction v8.9: AI super confidence, magnet capture, oneshot hipfire, or engage/sticky glue spin up a sustained predictive offset.
                    // Direct blend plus slowdown collapse keep the reticle glued through user drag while HIP_AUTOCORRECT gating protects free-look pivots.
                    if(bullet_correct_timer > 0){
                        bullet_correct_timer = bullet_correct_timer - delta;
                        if(bullet_correct_timer < 0) bullet_correct_timer = 0;
                        g_val = (bullet_correct_timer * bullet_correct_strength) / AI_BULLET_CORRECT_WINDOW;
                        if(g_val > AI_BULLET_CORRECT_MAX) g_val = AI_BULLET_CORRECT_MAX;
                        g_chars = AI_BULLET_CORRECT_DECAY;
                        if(!ads && oneshot_mode){
                            g_chars = HIP_AUTOCORRECT_DECAY_GAIN;
                        }
                        bullet_correct_gain = smooth_gain(bullet_correct_gain, g_val, g_chars);
                        bullet_correct_offset_x = smooth_gain(bullet_correct_offset_x, bullet_correct_target_x, 50 + (ai_confidence_pct / 2));
                        bullet_correct_offset_y = smooth_gain(bullet_correct_offset_y, bullet_correct_target_y, 50 + (ai_confidence_pct / 2));
        
                        // Near-miss hitbox correction: If error 8-25px, apply 1.5x bias
                        if(aim_error_pixels > 8 && aim_error_pixels < 25 && shooting){
                            g_temp = 150;  // 1.5x bias
                            bullet_correct_offset_x = (bullet_correct_offset_x * g_temp) / 100;
                            bullet_correct_offset_y = (bullet_correct_offset_y * g_temp) / 100;
                        }
                    } else {
                        bullet_correct_gain = smooth_gain(bullet_correct_gain, 0, AI_BULLET_CORRECT_DECAY);
                        bullet_correct_offset_x = smooth_gain(bullet_correct_offset_x, 0, AI_BULLET_CORRECT_DECAY);
                        bullet_correct_offset_y = smooth_gain(bullet_correct_offset_y, 0, AI_BULLET_CORRECT_DECAY);
                        bullet_correct_strength = 0;
                    }
        
                    // Forgiveness micro-snap on shot near-miss (<20px error)
                    if(shooting && aim_error_pixels < 20 && aim_error_pixels > 0){
                        g_val = 50;  // 50% snap strength
                        snap_x = ((0 - stabilized_rx) * g_val) / 100;
                        snap_y = ((0 - stabilized_ry) * g_val) / 100;
                        stabilized_rx = stabilized_rx + snap_x;
                        stabilized_ry = stabilized_ry + snap_y;
                    }
                    bullet_correct_offset_x = clamp_i(bullet_correct_offset_x, -AI_PREDICT_CLAMP_X * 3, AI_PREDICT_CLAMP_X * 3);
                    bullet_correct_offset_y = clamp_i(bullet_correct_offset_y, -AI_PREDICT_CLAMP_Y * 3, AI_PREDICT_CLAMP_Y * 3);
        
                    if(hip_fast_track_active){
                        if(bullet_correct_timer < HIP_FAST_TIMER_BONUS){
                            bullet_correct_timer = HIP_FAST_TIMER_BONUS;
                        }
                        bullet_correct_gain = clamp_i(bullet_correct_gain + HIP_FAST_BULLET_GAIN, 0, AI_BULLET_CORRECT_MAX);
                        if(bullet_correct_strength < AI_BULLET_CORRECT_GAIN){
                            bullet_correct_strength = clamp_i(bullet_correct_strength + (HIP_FAST_BULLET_GAIN * 4), 0, AI_BULLET_CORRECT_GAIN);
                        }
                        if(bullet_correct_target_x == 0 && bullet_correct_target_y == 0){
                            bullet_correct_target_x = clamp_i(predict_offset_x - pixel_offset_x, -AI_PREDICT_CLAMP_X * 3, AI_PREDICT_CLAMP_X * 3);
                            bullet_correct_target_y = clamp_i(predict_offset_y - pixel_offset_y, -AI_PREDICT_CLAMP_Y * 3, AI_PREDICT_CLAMP_Y * 3);
                        }
                    }
        
                    if(bullet_correct_gain > 0){
                        bullet_correct_gain = clamp_i((bullet_correct_gain * assist_scale_bullet_pct) / 100, 0, AI_BULLET_CORRECT_MAX);
        
                        // Smooth super-magnet blend so bullet correction has sustained muscle without harsh jitter.
                        // This maintains continuous pull instead of the old pulse-only system.
                        g_val = (bullet_correct_gain * 60) / AI_BULLET_CORRECT_MAX;
                        if(g_val < 15) g_val = 15;
                        if(g_val > 80) g_val = 80;
                        g_temp = (bullet_correct_offset_x * bullet_correct_gain) / 3;
                        g_temp = clamp_i(g_temp, -180, 180);
                        bullet_correct_blend_x = smooth_gain(bullet_correct_blend_x, g_temp, 45 + g_val);
                        g_chars = (bullet_correct_offset_y * bullet_correct_gain) / 3;
                        g_chars = clamp_i(g_chars, -180, 180);
                        bullet_correct_blend_y = smooth_gain(bullet_correct_blend_y, g_chars, 45 + g_val);
                        if(search_release_pct > 0){
                            g_val = lerp_pct(100, UE_SEARCH_RELEASE_BIAS, search_release_pct);
                            bullet_correct_gain = (bullet_correct_gain * g_val) / 100;
                            bullet_correct_offset_x = (bullet_correct_offset_x * g_val) / 100;
                            bullet_correct_offset_y = (bullet_correct_offset_y * g_val) / 100;
                        }
                    } else {
                        bullet_correct_blend_x = smooth_gain(bullet_correct_blend_x, 0, 24);
                        bullet_correct_blend_y = smooth_gain(bullet_correct_blend_y, 0, 24);
                    }
                    update_strafe_detection();
                    update_input_velocity();
                    update_hip_fast_tracking();
                    update_hip_prelock_fast();
                    update_ballistic_compensation();
                    freedom_release_blend = smooth_gain(freedom_release_blend, freedom_release_target, 12);
                    update_assist_core();
                    // detect_assist_state(); // DEPRECATED by vPro state machine
                    update_zd_state_machine();
        
                    if(hipfire_engaged){
                        g_val = HIP_ENGAGE_ASSIST_BONUS;
                        if(g_val > 0){
                            assist_core_blend = clamp_i(assist_core_blend + g_val, 0, 100);
                            assist_slowdown_blend = clamp_i(assist_slowdown_blend + g_val, 0, 100);
                        }
                        g_temp = (hipfire_engage_strength * HIP_ENGAGE_ROT_BONUS) / 100;
                        if(g_temp > 0){
                            assist_rotation_blend = clamp_i(assist_rotation_blend + g_temp, 0, 100);
                        }
                        g_chars = (hipfire_engage_strength * HIP_ENGAGE_SNAP_BONUS) / 100;
                        if(g_chars > 0){
                            assist_snap_blend = clamp_i(assist_snap_blend + g_chars, 0, 100);
                        }
                        g_total = (hipfire_engage_strength * HIP_ENGAGE_RESIST_GAIN) / 100;
                        if(g_total > 0){
                            aim_state_resistance_pct = clamp_i(aim_state_resistance_pct + g_total, 40, 220);
                        }
                    }
        
                    g_temp = 0;
                    if(magnet_lock_gate && lock_confidence >= UE_ALIGN_LOCK_CONF_GATE && distance_pixels <= UE_ALIGN_LOCK_RADIUS){
                        if(aim_error_variance <= UE_ALIGN_LOCK_VARIANCE_GATE && input_velocity <= UE_ALIGN_LOCK_INPUT_GATE && !freedom_release_active){
                            g_temp = lock_confidence - UE_ALIGN_LOCK_CONF_GATE;
                            if(g_temp < 0) g_temp = 0;
                            if(g_temp > 40) g_temp = 40;
                            g_val = UE_ALIGN_LOCK_RADIUS - distance_pixels;
                            if(g_val < 0) g_val = 0;
                            if(g_val > UE_ALIGN_LOCK_RADIUS) g_val = UE_ALIGN_LOCK_RADIUS;
                            g_temp = g_temp + (g_val * 6);
                            if(g_temp > 100) g_temp = 100;
                        }
                    }
                    align_lock_strength = smooth_gain(align_lock_strength, g_temp, UE_ALIGN_LOCK_STILLNESS_GAIN);
                    if(align_lock_strength < 2) align_lock_strength = 0;
                    if(align_lock_strength > 0){
                        align_lock_active = 1;
                    } else {
                        align_lock_active = 0;
                    }
        
                    if(search_suppress_pct > 0){
                        g_val = lerp_pct(100, UE_SEARCH_SUPPRESS_CORE, search_suppress_pct);
                        assist_core_blend = (assist_core_blend * g_val) / 100;
                        g_temp = 100 - search_suppress_pct;
                        if(g_temp < 0) g_temp = 0;
                        assist_slowdown_blend = (assist_slowdown_blend * g_temp) / 100;
                        assist_rotation_blend = (assist_rotation_blend * g_temp) / 100;
                        assist_snap_blend = (assist_snap_blend * g_temp) / 100;
                        if(ai_confidence_pct > 0){
                            ai_confidence_pct = (ai_confidence_pct * g_temp) / 100;
                        }
                    }
        
                    if(search_release_pct > 0){
                        g_val = lerp_pct(100, UE_SEARCH_RELEASE_CORE, search_release_pct);
                        assist_core_blend = (assist_core_blend * g_val) / 100;
                        g_temp = lerp_pct(100, UE_SEARCH_RELEASE_SLOW, search_release_pct);
                        assist_slowdown_blend = (assist_slowdown_blend * g_temp) / 100;
                        g_chars = lerp_pct(100, UE_SEARCH_RELEASE_ROT, search_release_pct);
                        assist_rotation_blend = (assist_rotation_blend * g_chars) / 100;
                        g_total = lerp_pct(100, UE_SEARCH_RELEASE_SNAP, search_release_pct);
                        assist_snap_blend = (assist_snap_blend * g_total) / 100;
                        g_expected = lerp_pct(100, UE_SEARCH_RELEASE_AI, search_release_pct);
                        ai_confidence_pct = (ai_confidence_pct * g_expected) / 100;
                    }
        
                    if(ads && magnet_lock_gate && lock_confidence >= UE_ADS_LOCK_CONF_GATE){
                        if(input_velocity <= AIM_STABILITY_INPUT_GATE && aim_error_pixels <= AIM_STABILITY_ERROR_GATE){
                            ads_lock_steady_active = 1;
                        }
                    }
        
                    update_alignment_scalers();
                    compute_alignment_suppression();
        
                    assist_core_blend = clamp_i((assist_core_blend * assist_alignment_pct) / 100, 0, 100);
                    assist_core_blend = clamp_i((assist_core_blend * assist_release_pct) / 100, 0, 100);
                    assist_slowdown_blend = clamp_i((assist_slowdown_blend * assist_scale_slowdown_pct) / 100, 0, 100);
                    assist_rotation_blend = clamp_i((assist_rotation_blend * assist_scale_rotation_pct) / 100, 0, 100);
                    assist_rotation_blend = clamp_i((assist_rotation_blend * rotation_scale_pct) / 100, 0, 100);
                    assist_snap_blend = clamp_i((assist_snap_blend * assist_scale_snap_pct) / 100, 0, 100);
                    aim_state_resistance_pct = clamp_i((aim_state_resistance_pct * assist_scale_resist_pct) / 100, 40, 200);
        
                    if(magnet_lock_gate && native_capture_gate && lock_confidence >= LOCK_STRENGTH_ROTATION && !freedom_release_active){
                        assist_slowdown_blend = clamp_i((assist_slowdown_blend * (100 + LOCK_REINFORCE_SLOWDOWN)) / 100, 0, 100);
                        assist_rotation_blend = clamp_i((assist_rotation_blend * (100 + LOCK_REINFORCE_ROTATION)) / 100, 0, 100);
                        assist_snap_blend = clamp_i((assist_snap_blend * (100 + LOCK_REINFORCE_SNAP)) / 100, 0, 100);
                        aim_state_resistance_pct = clamp_i((aim_state_resistance_pct * (100 + LOCK_REINFORCE_RESIST)) / 100, 40, 240);
                    }
                    if(snap_super_blend_pct > 0){
                        assist_snap_blend = clamp_i(assist_snap_blend + snap_super_blend_pct, 0, 100);
                    }
                    if(magnet_super_slowdown_pct > 0){
                        assist_slowdown_blend = clamp_i(assist_slowdown_blend + magnet_super_slowdown_pct, 0, 100);
                    }
                    if(magnet_super_rotation_pct > 0){
                        assist_rotation_blend = clamp_i(assist_rotation_blend + magnet_super_rotation_pct, 0, 100);
                    }
                    if(magnet_super_resist_bonus > 0){
                        aim_state_resistance_pct = clamp_i(aim_state_resistance_pct + magnet_super_resist_bonus, 40, 220);
                    }
        
                    // Bubble-weighted tuning to center the new lock metrics across subsystems
                    g_val = clamp_i(bubble_lock_weight, 0, 100);
                    g_temp = clamp_i(100 - bubble_release_weight, 40, 120);
                    g_expected = 90 + (g_val * 18) / 100;
                    if(!ads){
                        if(oneshot_mode){
                            g_expected = g_expected + 8;
                        } else {
                            g_expected = g_expected + 4;
                        }
                    }
                    if(magnet_capture_active){
                        g_expected = g_expected + (magnet_capture_strength / 3);
                    }
                    g_expected = (g_expected * g_temp) / 100;
                    g_expected = clamp_i(g_expected, 60, 150);
                    assist_rotation_blend = clamp_i((assist_rotation_blend * g_expected) / 100, 0, 100);
        
                    g_total = 105 + (bubble_core_weight * 20) / 100 - (bubble_release_weight * 35) / 100;
                    if(!ads){
                        g_total = g_total + 6;
                    }
                    if(hipfire_sticky_active){
                        g_total = g_total + 10;
                    }
                    g_total = clamp_i(g_total, 55, 145);
                    assist_slowdown_blend = clamp_i((assist_slowdown_blend * g_total) / 100, 0, 100);
        
                    g_chars = 92 + (bubble_edge_weight * 12) / 100;
                    g_chars = clamp_i(g_chars, 60, 135);
                    assist_snap_blend = clamp_i((assist_snap_blend * g_chars) / 100, 0, 100);
        
                    update_weapon_profile();
                    apply_weapon_profile_scaling();
                    apply_recoil_modulation(); // Apply recoil modulation after scaling
                    update_sticky_edge_weight();
                    if(magnet_capture_active){
                        assist_slowdown_blend = clamp_i(assist_slowdown_blend + magnet_capture_slowdown_boost, 0, 100);
                        assist_rotation_blend = clamp_i(assist_rotation_blend + magnet_capture_rotation_boost, 0, 100);
                        assist_snap_blend = clamp_i(assist_snap_blend + magnet_capture_snap_boost, 0, 100);
                    }
                    if(ai_confidence_pct >= AI_CONFIDENCE_SUPER_GATE){
                        assist_rotation_blend = clamp_i(assist_rotation_blend + MAGNET_CAPTURE_SUPER_BONUS, 0, 100);
                        assist_slowdown_blend = clamp_i(assist_slowdown_blend + MAGNET_CAPTURE_SUPER_BONUS, 0, 100);
                        if(magnet_capture_active){
                            magnet_capture_rotation_boost = magnet_capture_rotation_boost + MAGNET_CAPTURE_SUPER_BONUS;
                            magnet_capture_snap_boost = magnet_capture_snap_boost + MAGNET_CAPTURE_SUPER_BONUS;
                        }
            slowdown_event_release_check();
                    }
                    if(magnet_lock_gate && input_velocity <= STICKINESS_INPUT_GATE && !freedom_release_active && !align_suppress_freeze){
                        assist_slowdown_blend = clamp_i(assist_slowdown_blend + STICKINESS_SLOWDOWN_BONUS, 0, 100);
                        assist_rotation_blend = clamp_i(assist_rotation_blend + STICKINESS_ROTATION_BONUS, 0, 100);
                        aim_state_resistance_pct = clamp_i(aim_state_resistance_pct + STICKINESS_RESIST_BONUS, 40, 220);
                    }
                    if(bullet_correct_gain > 0){
                        assist_rotation_blend = clamp_i(assist_rotation_blend + (bullet_correct_gain * 2), 0, 100);
                        assist_snap_blend = clamp_i(assist_snap_blend + (bullet_correct_gain * 2), 0, 100);
                    }
                    if(align_suppress_bullet_scale < 100){
                        bullet_correct_gain = (bullet_correct_gain * align_suppress_bullet_scale) / 100;
                        bullet_correct_offset_x = (bullet_correct_offset_x * align_suppress_bullet_scale) / 100;
                        bullet_correct_offset_y = (bullet_correct_offset_y * align_suppress_bullet_scale) / 100;
                        bullet_correct_blend_x = (bullet_correct_blend_x * align_suppress_bullet_scale) / 100;
                        bullet_correct_blend_y = (bullet_correct_blend_y * align_suppress_bullet_scale) / 100;
                    }
                    if(align_suppress_rotation_scale < 100){
                        assist_rotation_blend = (assist_rotation_blend * align_suppress_rotation_scale) / 100;
                    }
                    if(align_suppress_snap_scale < 100){
                        assist_snap_blend = (assist_snap_blend * align_suppress_snap_scale) / 100;
                    }
                    // Using g_chars for distance_delta_abs to remove local variable declaration
                    g_chars = distance_delta;
                    if(g_chars < 0) g_chars = 0 - g_chars;
                    if(freedom_release_blend > 0 || !magnet_lock_gate){
                        resistance_glue_active = 0;
                        resistance_glue_timer = 0;
                        resistance_glue_gain = 0;
                    } else if(resistance_glue_active){
                        if(input_velocity > 18 || aim_error_variance > 18 || g_chars > 8 || lock_confidence < 60){
                            resistance_glue_active = 0;
                            resistance_glue_timer = 0;
                            resistance_glue_gain = 0;
                        } else {
                            resistance_glue_timer = resistance_glue_timer + delta;
                            if(resistance_glue_timer > 450) resistance_glue_timer = 450;
                            resistance_glue_gain = (resistance_glue_timer * 28) / 450;
                            if(resistance_glue_gain > 28) resistance_glue_gain = 28;
                        }
                    } else if(lock_confidence >= 72 && aim_error_avg <= 8 && g_chars <= 4 && input_velocity <= 12){
                        resistance_glue_active = 1;
                        resistance_glue_timer = 120;
                        resistance_glue_gain = 12;
                    }
        
                    if(ads_lock_steady_active){
                        assist_rotation_blend = (assist_rotation_blend * UE_ADS_LOCK_ROT_DAMP) / 100;
                        assist_slowdown_blend = (assist_slowdown_blend * UE_ADS_LOCK_CENTER_BLEND) / 100;
                        assist_snap_blend = (assist_snap_blend * UE_ADS_LOCK_CENTER_BLEND) / 100;
                    }
        
                    // compute_unreal_slowdown_target();  // DISABLED - stub function not needed
                zone_blend_pct = soft_step(distance_pixels, bubble_zone_edges[0], bubble_zone_edges[4]);
                    calculate_pulse_magnitude();  // SMOOTH MAGNITUDE - slider-based!
                    update_rotation_pulse();      // ROTATION TRIGGER PULSE - magnetic aim!
        
                        // ========= SLOWDOWN BLENDING =========
                    slowdown_factor = 100;
                    zone_index = bubble_zone - 1;
                    if(zone_index < 0) zone_index = 0;
                    if(zone_index > 4) zone_index = 4;
        
                base_slowdown = slowdown_zone_map[zone_index];
                base_slowdown = (base_slowdown * weapon_gain_slowdown_mix) / 100;
                base_slowdown = lerp_pct(base_slowdown, ue_slowdown_target, UE_SLOWDOWN_CURVE_BLEND);
                base_slowdown = clamp_i(base_slowdown, 10, 100);
        
        
                    if(lock_confidence > 0){
                        assist_slowdown_blend = smooth_gain(assist_slowdown_blend, assist_core_blend, 16);
                        if(input_velocity >= INPUT_VELOCITY_PANIC){
                            assist_slowdown_blend = assist_slowdown_blend / 3;
                        }
                        if(hyper_burst_active){
                            slowdown_factor = HYPER_BURST_SLOWDOWN;
                        } else {
                            slowdown_factor = lerp_pct(100, base_slowdown, assist_slowdown_blend);
                            slowdown_factor = lerp_pct(slowdown_factor, base_slowdown / 2, zone_blend_pct);
                            if(ads && bubble_zone > 0){
                                slowdown_factor = (slowdown_factor * ADS_SLOWDOWN_FACTOR) / 100;
                                slowdown_factor = (slowdown_factor * weapon_gain_ads_slowdown_mix) / 100;
                            }
                            slowdown_factor = (slowdown_factor * range_scale_pct) / 100;
                            // V4.0 FIX: Was using ROTATION slider for STRENGTH scaling. Corrected to use current_strength_slider.
                            slowdown_factor = (slowdown_factor * strength_scale_pct) / 100;
                            slowdown_factor = lerp_pct(slowdown_factor, ue_slowdown_target, UE_SLOWDOWN_CURVE_BLEND);
        
                            if(bullet_correct_gain > 0){
                                // Force slowdown collapse so camera latches during corrective pulls.
                                g_val = (bullet_correct_gain * 100) / AI_BULLET_CORRECT_MAX;
                                if(g_val > 100) g_val = 100;
                                g_temp = slowdown_factor / 6;
                                if(g_temp < 1) g_temp = 1;
                                if(!ads && oneshot_mode){
                                    g_temp = slowdown_factor / 10;
                                    if(g_temp < 1) g_temp = 1;
                                }
                                slowdown_factor = lerp_pct(slowdown_factor, g_temp, g_val);
                            }
                        }
                    }
                    else {
                        slowdown_factor = lerp_pct(100, base_slowdown, assist_last_proximity_score / 2);
                    }
        
                    if(search_release_pct > 0){
                        g_val = lerp_pct(100, UE_SEARCH_RELEASE_SLOW, search_release_pct);
                        slowdown_factor = (slowdown_factor * g_val + 100 * (100 - g_val)) / 100;
                    }
        
                    if(sticky_edge_weight > 0){
                        assist_slowdown_blend = smooth_gain(assist_slowdown_blend, assist_core_blend, 16);
                        if(input_velocity >= INPUT_VELOCITY_PANIC){
                            assist_slowdown_blend = assist_slowdown_blend / 3;
                        }
                        if(hyper_burst_active){
                            slowdown_factor = HYPER_BURST_SLOWDOWN;
                        } else {
                            slowdown_factor = lerp_pct(100, base_slowdown, assist_slowdown_blend);
                            slowdown_factor = lerp_pct(slowdown_factor, base_slowdown / 2, zone_blend_pct);
                            if(ads && bubble_zone > 0){
                                slowdown_factor = (slowdown_factor * ADS_SLOWDOWN_FACTOR) / 100;
                                slowdown_factor = (slowdown_factor * weapon_gain_ads_slowdown_mix) / 100;
                            }
                                slowdown_factor = (slowdown_factor * range_scale_pct) / 100;
                                // V4.0 FIX: Was using ROTATION slider for STRENGTH scaling. Corrected to use current_strength_slider via precomputed drift-free scaling.
                                slowdown_factor = (slowdown_factor * strength_scale_pct) / 100;
                            slowdown_factor = lerp_pct(slowdown_factor, ue_slowdown_target, UE_SLOWDOWN_CURVE_BLEND);
        
                            if(bullet_correct_gain > 0){
                                // Force slowdown collapse so camera latches during corrective pulls.
                                g_val = (bullet_correct_gain * 100) / AI_BULLET_CORRECT_MAX;
                                if(g_val > 100) g_val = 100;
                                g_temp = slowdown_factor / 6;
                                if(g_temp < 1) g_temp = 1;
                                if(!ads && oneshot_mode){
                                    g_temp = slowdown_factor / 10;
                                    if(g_temp < 1) g_temp = 1;
                                }
                                slowdown_factor = lerp_pct(slowdown_factor, g_temp, g_val);
                            }
                        }
                    }
                    else {
                        slowdown_factor = lerp_pct(100, base_slowdown, assist_last_proximity_score / 2);
                    }
        
                    if(sticky_edge_weight > 0){
                        g_expected = sticky_edge_boost; // slowdown_edge_gain
                        g_val = sticky_edge_boost / 2;  // rotation_edge_gain
                        g_temp = sticky_edge_snap_boost; // snap_edge_gain
        
                        if(!sticky_edge_active){
                            g_expected = (sticky_edge_weight * STICKY_EDGE_GAIN) / 100;
                            g_val = g_expected / 2;
                            g_temp = (sticky_edge_weight * STICKY_EDGE_SNAP_GAIN) / 100;
                        }
        
                        g_fill = clamp_i(100 + g_expected, 90, 150);
                        slowdown_factor = (slowdown_factor * g_fill) / 100;
        
                        assist_rotation_blend = clamp_i(assist_rotation_blend + g_val, 0, 100);
                        assist_snap_blend = clamp_i(assist_snap_blend + g_temp, 0, 100);
                    } else {
                        if(sticky_edge_timer > 0){
                            sticky_edge_timer = sticky_edge_timer - (delta * 2);
                            if(sticky_edge_timer < 0) sticky_edge_timer = 0;
                        }
                    }
        
                    hipfire_glue_weight = 0;
                    hipfire_glue_slow_target = 0;
                    hipfire_glue_rot_bonus = 0;
                    hipfire_glue_snap_bonus = 0;
                    hipfire_glue_resist_gain = 0;
                    hipfire_glue_resist_cap = 0;
        
                    hipfire_glue_candidate = (!ads && (magnet_lock_gate || hipfire_sticky_active || hipfire_engaged || native_capture_gate || native_signal_stack > 0 || hip_prelock_fast_active || bullet_correct_gain > 0));
        
                    if(hipfire_glue_candidate){
                        if(hipfire_sticky_active && oneshot_mode){
                            g_val = HIP_STICKY_INTENSITY_BASE;
                            g_val = clamp_i(g_val + (lock_confidence / 2), 0, 100);
                            g_val = clamp_i(g_val + (bubble_lock_weight * 3) / 5, 0, 100);
                            g_val = (g_val * (100 - (bubble_release_weight / 2))) / 100;
                            hipfire_sticky_weight = (g_val * strength_scale_pct) / 100;
                            if(!magnet_lock_gate){
                                hipfire_sticky_weight = (hipfire_sticky_weight * 80) / 100;
                            }
                            if(hipfire_sticky_weight > 100) hipfire_sticky_weight = 100;
                            if(bullet_correct_gain > 0){
                                hipfire_sticky_weight = (hipfire_sticky_weight * HIP_ONESHOT_SUPER_GAIN) / 100;
                            }
                            if(hipfire_sticky_weight > 100) hipfire_sticky_weight = 100;
        
                            hipfire_glue_weight = hipfire_sticky_weight;
                            hipfire_glue_slow_target = HIP_STICKY_SLOWDOWN_TARGET;
                            hipfire_glue_rot_bonus = HIP_STICKY_ROTATION_BONUS;
                            hipfire_glue_snap_bonus = HIP_STICKY_SNAP_BONUS;
                            hipfire_glue_resist_gain = HIP_STICKY_RESIST_GAIN;
                            hipfire_glue_resist_cap = 72;
                        } else if(magnet_lock_gate && lock_confidence >= UE_HIP_GLUE_LOCK_GATE){
                            g_val = clamp_i(lock_confidence - UE_HIP_GLUE_LOCK_GATE, 0, 42);
                            g_val = g_val + (magnet_capture_strength * UE_HIP_GLUE_MAG_BONUS) / 100;
                            g_val = g_val + (ai_confidence_pct / 3);
                            g_val = g_val + (sticky_edge_weight / 3);
                            g_val = (g_val * (100 - (bubble_release_weight / 2))) / 100;
                            if(g_val < 0) g_val = 0;
                            hipfire_glue_weight = (g_val * strength_scale_pct) / 100;
                            hipfire_glue_weight = clamp_i(hipfire_glue_weight, 0, 100);
                            if(bullet_correct_gain > 0){
                                hipfire_glue_weight = clamp_i(hipfire_glue_weight + (bullet_correct_gain / 2), 0, 100);
                            }
                            hipfire_glue_slow_target = UE_HIP_GLUE_SLOWDOWN_TARGET;
                            hipfire_glue_rot_bonus = UE_HIP_GLUE_ROT_BONUS;
                            hipfire_glue_snap_bonus = UE_HIP_GLUE_SNAP_BONUS;
                            hipfire_glue_resist_gain = UE_HIP_GLUE_RESIST_GAIN;
                            hipfire_glue_resist_cap = 64;
                        } else if(distance_pixels <= HIP_PRELOCK_DISTANCE + HIP_PRELOCK_GRACE_PX){
                            g_val = HIP_PRELOCK_WEIGHT_MIN;
                            g_temp = HIP_PRELOCK_DISTANCE - distance_pixels;
                            if(g_temp > 0){
                                g_val = g_val + (g_temp * HIP_PRELOCK_STRENGTH_GAIN) / HIP_PRELOCK_DISTANCE;
                            } else {
                                g_chars = HIP_PRELOCK_GRACE_PX + g_temp;
                                if(g_chars < 0) g_chars = 0;
                                // HIP_PRELOCK_GRACE_PX is always 35, so division is safe
                                g_val = g_val + (g_chars * HIP_PRELOCK_STRENGTH_GAIN) / HIP_PRELOCK_GRACE_PX;
                            }
                            if(native_signal_stack > 0){
                                g_total = native_signal_stack * HIP_PRELOCK_STACK_WEIGHT;
                                if(g_total > HIP_PRELOCK_STACK_WEIGHT * 3) g_total = HIP_PRELOCK_STACK_WEIGHT * 3;
                                g_val = g_val + g_total;
                            }
                            // v60.2: ALWAYS ASSUME STICKY TARGET FOR MAX WEIGHT
                            g_val = g_val + HIP_PRELOCK_STACK_WEIGHT * 2; 
                            
                            if(hipfire_sticky_active){
                                g_val = g_val + HIP_PRELOCK_STACK_WEIGHT;
                            }
                            if(hipfire_engaged){
                                g_val = g_val + (hipfire_engage_strength * HIP_PRELOCK_STACK_WEIGHT) / 100;
                            }
                            if(cone_engage_weight > 0){
                                g_val = g_val + (cone_engage_weight * HIP_PRELOCK_STACK_WEIGHT) / 100;
                            }
                            g_chars = abs(momentum_x) + abs(momentum_y);
                            if(g_chars > 0){
                                g_total = UE_MOMENTUM_CAP + UE_MOMENTUM_CAP;
                                if(g_total < 1) g_total = 1;
                                if(g_chars > g_total) g_chars = g_total;
                                g_val = g_val + (g_chars * HIP_PRELOCK_STACK_WEIGHT) / g_total;
                            }
                            if(oneshot_mode){
                                g_val = g_val + HIP_PRELOCK_STACK_WEIGHT;
                            }
                            if(input_velocity >= HIP_ENGAGE_RELEASE_INPUT){
                                g_val = HIP_PRELOCK_WEIGHT_MIN;
                            }
                            if(hip_prelock_fast_active){
                                g_chars = clamp_i(hip_prelock_fast_timer, 0, HIP_PRELOCK_FAST_TIMER_MS);
                                if(g_chars > 0){
                                    g_val = g_val + (g_chars * HIP_PRELOCK_FAST_WEIGHT_BONUS) / HIP_PRELOCK_FAST_TIMER_MS;
                                }
                            }
                            g_val = clamp_i(g_val, HIP_PRELOCK_WEIGHT_MIN, HIP_PRELOCK_WEIGHT_MAX);
        
                            hipfire_glue_weight = (g_val * strength_scale_pct) / 100;
                            hipfire_glue_slow_target = HIP_PRELOCK_SLOW_TARGET;
                            hipfire_glue_rot_bonus = HIP_PRELOCK_ROT_BONUS;
                            hipfire_glue_snap_bonus = HIP_PRELOCK_SNAP_BONUS;
                            hipfire_glue_resist_gain = HIP_PRELOCK_RESIST_GAIN;
                            hipfire_glue_resist_cap = HIP_PRELOCK_RESIST_CAP;
        
                            if(hip_prelock_fast_active){
                                g_chars = clamp_i(hip_prelock_fast_timer, 0, HIP_PRELOCK_FAST_TIMER_MS);
                                if(g_chars > 0){
                                    g_total = (g_chars * HIP_PRELOCK_FAST_ROT_BONUS) / HIP_PRELOCK_FAST_TIMER_MS;
                                    hipfire_glue_rot_bonus = hipfire_glue_rot_bonus + g_total;
        
                                    g_expected = (g_chars * HIP_PRELOCK_FAST_SNAP_BONUS) / HIP_PRELOCK_FAST_TIMER_MS;
                                    hipfire_glue_snap_bonus = hipfire_glue_snap_bonus + g_expected;
        
                                    g_total = (g_chars * HIP_PRELOCK_FAST_RESIST_GAIN) / HIP_PRELOCK_FAST_TIMER_MS;
                                    hipfire_glue_resist_gain = hipfire_glue_resist_gain + g_total;
                                    if(hipfire_glue_resist_gain > hipfire_glue_resist_cap){
                                        hipfire_glue_resist_gain = hipfire_glue_resist_cap;
                                    }
                                }
                            }
                        } else if(hipfire_engaged){
                            g_val = HIP_ENGAGE_GLUE_BONUS + (hipfire_engage_strength * HIP_ENGAGE_GLUE_GAIN) / 100;
                            if(g_val < 0) g_val = 0;
                            hipfire_glue_weight = (g_val * strength_scale_pct) / 100;
                            if(hipfire_glue_weight > 100) hipfire_glue_weight = 100;
                            hipfire_glue_slow_target = UE_HIP_GLUE_SLOWDOWN_TARGET;
                            hipfire_glue_rot_bonus = UE_HIP_GLUE_ROT_BONUS;
                            hipfire_glue_snap_bonus = UE_HIP_GLUE_SNAP_BONUS;
                            hipfire_glue_resist_gain = UE_HIP_GLUE_RESIST_GAIN;
                            hipfire_glue_resist_cap = UE_HIP_GLUE_RESIST_CAP;
                        }
                    }
        
                    if(!magnet_lock_gate && !native_capture_gate && distance_pixels > HIP_PRELOCK_DISTANCE){
                        if(!hipfire_glue_candidate && hip_glue_persist_timer == 0){
                            hipfire_glue_weight = 0;
                            hip_glue_persist_timer = 0;
                        }
                    }
        
                    if(!ads && hipfire_engaged){
                        g_val = HIP_ENGAGE_GLUE_BONUS + (hipfire_engage_strength * HIP_ENGAGE_GLUE_GAIN) / 100;
                        if(g_val < 0) g_val = 0;
                        if(hipfire_glue_weight < g_val){
                            hipfire_glue_weight = g_val;
                        }
                        if(hipfire_glue_slow_target == 0){
                            hipfire_glue_slow_target = HIP_STICKY_SLOWDOWN_TARGET;
                        }
                        g_temp = (hipfire_engage_strength * HIP_ENGAGE_ROT_BONUS) / 100;
                        if(hipfire_glue_rot_bonus < g_temp){
                            hipfire_glue_rot_bonus = g_temp;
                        }
                        g_chars = (hipfire_engage_strength * HIP_ENGAGE_SNAP_BONUS) / 100;
                        if(hipfire_glue_snap_bonus < g_chars){
                            hipfire_glue_snap_bonus = g_chars;
                        }
                        g_total = (hipfire_engage_strength * HIP_ENGAGE_RESIST_GAIN) / 100;
                        if(hipfire_glue_resist_gain < g_total){
                            hipfire_glue_resist_gain = g_total;
                        }
                        if(hipfire_glue_resist_cap < HIP_ENGAGE_RESIST_CAP){
                            hipfire_glue_resist_cap = HIP_ENGAGE_RESIST_CAP;
                        }
                    }
        
                    if(hip_velocity_glue_floor > 0 && hip_velocity_glue_floor > hipfire_glue_weight){
                        hipfire_glue_weight = hip_velocity_glue_floor;
                    }
                    if(hipfire_glue_weight > 100) hipfire_glue_weight = 100;
        
                    if(!ads){
                    if(hip_fast_track_active || hip_prelock_fast_active){
                        g_val = HIP_FAST_TIMER_BONUS;
                        if(hip_prelock_fast_active && g_val < HIP_PRELOCK_FAST_TIMER_MS){
                            g_val = HIP_PRELOCK_FAST_TIMER_MS;
                        }
                        if(bullet_correct_timer < g_val){
                            bullet_correct_timer = g_val;
                        }
                        g_temp = HIP_FAST_BULLET_GAIN;
                    if(hip_prelock_fast_active){
                        if(hip_prelock_fast_timer > 0){
                            g_total = (hip_prelock_fast_timer * HIP_PRELOCK_FAST_WEIGHT_BONUS) / HIP_PRELOCK_FAST_TIMER_MS;
                            if(g_total < 0) g_total = 0;
                            hipfire_glue_weight = hipfire_glue_weight + g_total;
                            if(hipfire_glue_weight > 100) hipfire_glue_weight = 100;
        
                            g_expected = (hip_prelock_fast_timer * HIP_PRELOCK_FAST_ROT_BONUS) / HIP_PRELOCK_FAST_TIMER_MS;
                            hipfire_glue_rot_bonus = hipfire_glue_rot_bonus + g_expected;
        
                            g_chars = (hip_prelock_fast_timer * HIP_PRELOCK_FAST_SNAP_BONUS) / HIP_PRELOCK_FAST_TIMER_MS;
                            hipfire_glue_snap_bonus = hipfire_glue_snap_bonus + g_chars;
        
                            g_total = (hip_prelock_fast_timer * HIP_PRELOCK_FAST_RESIST_GAIN) / HIP_PRELOCK_FAST_TIMER_MS;
                            hipfire_glue_resist_gain = hipfire_glue_resist_gain + g_total;
                            if(hipfire_glue_resist_gain > hipfire_glue_resist_cap){
                                hipfire_glue_resist_gain = hipfire_glue_resist_cap;
                            }
                        }
                    }
                        if(hipfire_glue_resist_gain < HIP_FAST_RESIST_GAIN){
                            hipfire_glue_resist_gain = HIP_FAST_RESIST_GAIN;
                        }
                        if(hipfire_glue_resist_cap < HIP_FAST_RESIST_CAP){
                            hipfire_glue_resist_cap = HIP_FAST_RESIST_CAP;
                        }
                        hipfire_resistance_bonus = clamp_i(hipfire_resistance_bonus + HIP_FAST_RESIST_GAIN, 0, HIP_FAST_RESIST_CAP);
                        assist_core_blend = clamp_i(assist_core_blend + HIP_FAST_ASSIST_BONUS, 0, 100);
                        assist_rotation_blend = clamp_i(assist_rotation_blend + HIP_FAST_ROT_BONUS, 0, 100);
                        assist_snap_blend = clamp_i(assist_snap_blend + HIP_FAST_SNAP_BONUS, 0, 100);
                        aim_state_resistance_pct = clamp_i(aim_state_resistance_pct + HIP_FAST_RESIST_GAIN, 40, 240);
                    }
        
                    if(hipfire_glue_weight > 0){
                            g_val = UE_HIP_GLUE_PERSIST_MS;
                            if(!magnet_lock_gate && !hipfire_sticky_active){
                                g_val = HIP_PRELOCK_PERSIST_MS;
                            }
                            hip_glue_persist_timer = g_val;
                            hip_glue_persist_weight = hipfire_glue_weight;
                            hip_glue_persist_slow_target = hipfire_glue_slow_target;
                            hip_glue_persist_rot_bonus = hipfire_glue_rot_bonus;
                            hip_glue_persist_snap_bonus = hipfire_glue_snap_bonus;
                            hip_glue_persist_resist_gain = hipfire_glue_resist_gain;
                            hip_glue_persist_resist_cap = hipfire_glue_resist_cap;
                        } else {
                    if(hip_glue_persist_timer > 0){
                        hip_glue_persist_timer = hip_glue_persist_timer - delta;
                        if(!magnet_lock_gate && !native_capture_gate){
                            hip_glue_persist_timer = hip_glue_persist_timer - delta;
                        }
                        if(hip_glue_persist_timer < 0) hip_glue_persist_timer = 0;
                    }
                    if(hip_glue_persist_timer > 0){
                        g_chars = UE_HIP_GLUE_RELEASE_VEL;
                        if(magnet_capture_active){
                            g_chars = g_chars + 28 + (magnet_capture_strength / 3);
                        }
                        if(hipfire_sticky_active || hipfire_engaged){
                            g_chars = g_chars + 18;
                        }
                        if(g_chars > 180) g_chars = 180;
                        if(input_velocity <= g_chars){
                            g_val = (hip_glue_persist_timer * 100) / UE_HIP_GLUE_PERSIST_MS;
                            if(g_val < 0) g_val = 0;
                            if(g_val > 100) g_val = 100;
                            hipfire_glue_weight = (hip_glue_persist_weight * g_val) / 100;
                            hipfire_glue_slow_target = hip_glue_persist_slow_target;
                            hipfire_glue_rot_bonus = hip_glue_persist_rot_bonus;
                            hipfire_glue_snap_bonus = hip_glue_persist_snap_bonus;
                            hipfire_glue_resist_gain = hip_glue_persist_resist_gain;
                            hipfire_glue_resist_cap = hip_glue_persist_resist_cap;
                        } else {
                            hip_glue_persist_timer = 0;
                        }
                    }
                        }
                    } else {
                        hip_glue_persist_timer = 0;
                    }
        
                    g_total = hipfire_glue_weight;
                    if(g_total < 0) g_total = 0;
                    if(g_total > 100) g_total = 100;
                    g_temp = g_total;
                    if(hip_glue_persist_weight > g_temp){
                        g_temp = (g_temp * 60 + hip_glue_persist_weight * 40) / 100;
                    }
                    if(hip_velocity_glue_floor > g_temp){
                        g_temp = hip_velocity_glue_floor;
                    }
                    g_chars = abs(momentum_x) + abs(momentum_y);
                    if(g_chars > 0){
                        g_expected = UE_MOMENTUM_CAP + UE_MOMENTUM_CAP;
                        if(g_chars > g_expected) g_chars = g_expected;
                        g_temp = g_temp + (g_chars * 25) / g_expected;
                    }
                    if(cone_engage_weight > 0){
                        g_temp = g_temp + (cone_engage_weight * 8) / 100;
                    }
                    if(g_temp > 100) g_temp = 100;
                    g_val = 48 + (hipfire_engaged * 12);
                    hipfire_glue_weight = smooth_gain(hipfire_glue_weight, g_temp, g_val);
        
                    if(!ads && !magnet_lock_gate && hipfire_glue_candidate){
                        g_val = 0;
                        if(hipfire_sticky_active) g_val = 1;
                        if(hipfire_engaged) g_val = 1;
                        if(hip_prelock_fast_active) g_val = 1;
                        if(hip_glue_persist_timer > 0) g_val = 1;
                        if(g_val && hipfire_glue_weight < HIP_STICKY_INTENSITY_MIN){
                            hipfire_glue_weight = HIP_STICKY_INTENSITY_MIN;
                        }
                        if(hipfire_glue_rot_bonus < HIP_PRELOCK_ROT_BONUS){
                            hipfire_glue_rot_bonus = HIP_PRELOCK_ROT_BONUS;
                        }
                        if(hipfire_glue_slow_target == 0 || hipfire_glue_slow_target > HIP_PRELOCK_SLOW_TARGET){
                            hipfire_glue_slow_target = HIP_PRELOCK_SLOW_TARGET;
                        }
                    }
        
                    if(!ads && r2_assist_timer > 0){
                        g_expected = 48 + (hipfire_engage_strength / 3);
                        if(g_expected > 78) g_expected = 78;
                        if(hipfire_glue_weight < g_expected){
                            hipfire_glue_weight = g_expected;
                        }
                        if(hipfire_glue_slow_target == 0){
                            hipfire_glue_slow_target = UE_HIP_GLUE_SLOWDOWN_TARGET;
                        }
                        if(hipfire_glue_rot_bonus < UE_HIP_GLUE_ROT_BONUS){
                            hipfire_glue_rot_bonus = UE_HIP_GLUE_ROT_BONUS;
                        }
                        if(hipfire_glue_snap_bonus < UE_HIP_GLUE_SNAP_BONUS){
                            hipfire_glue_snap_bonus = UE_HIP_GLUE_SNAP_BONUS;
                        }
                        if(hipfire_glue_resist_gain < UE_HIP_GLUE_RESIST_GAIN){
                            hipfire_glue_resist_gain = UE_HIP_GLUE_RESIST_GAIN;
                        }
                        if(hipfire_glue_resist_cap < UE_HIP_GLUE_RESIST_CAP){
                            hipfire_glue_resist_cap = UE_HIP_GLUE_RESIST_CAP;
                        }
                    }
        
                    if(hipfire_glue_weight > 0){
                        g_chars = abs(momentum_x) + abs(momentum_y);
                        if(g_chars > 0){
                            g_expected = UE_MOMENTUM_CAP + UE_MOMENTUM_CAP;
                            if(g_chars > g_expected) g_chars = g_expected;
                            g_temp = (g_chars * 22) / g_expected;
                            if(g_temp > 24) g_temp = 24;
                            hipfire_glue_rot_bonus = hipfire_glue_rot_bonus + g_temp;
                            hipfire_glue_snap_bonus = hipfire_glue_snap_bonus + (g_temp * 3) / 4;
                            hipfire_glue_resist_gain = hipfire_glue_resist_gain + (g_temp / 2);
                        }
                        if(hipfire_glue_rot_bonus > 160) hipfire_glue_rot_bonus = 160;
                        if(hipfire_glue_snap_bonus > 160) hipfire_glue_snap_bonus = 160;
                        if(hipfire_glue_resist_gain > 120) hipfire_glue_resist_gain = 120;
                        if(subsystem_flags & SUBSYSTEM_SLOWDOWN){
                            slowdown_factor = lerp_pct(slowdown_factor, hipfire_glue_slow_target, hipfire_glue_weight);
                        }
                        if(subsystem_flags & SUBSYSTEM_ROTATION){
                            g_val = hipfire_glue_rot_bonus;
                            if(cone_engage_weight > 0){
                                g_temp = UE_CONE_ROT_MULT - 100;
                                if(g_temp < 0) g_temp = 0;
                                g_val = (g_val * (100 + (g_temp * cone_engage_weight) / 100)) / 100;
                            }
                            assist_rotation_blend = clamp_i(assist_rotation_blend + ((g_val * hipfire_glue_weight) / 100), 0, 100);
                        }
                        if((subsystem_flags & SUBSYSTEM_SNAP) && hipfire_glue_snap_bonus > 0){
                            g_chars = hipfire_glue_snap_bonus;
                            if(cone_engage_weight > 0){
                                g_temp = UE_CONE_SNAP_MULT - 100;
                                if(g_temp < 0) g_temp = 0;
                                g_chars = (g_chars * (100 + (g_temp * cone_engage_weight) / 100)) / 100;
                            }
                            assist_snap_blend = clamp_i(assist_snap_blend + ((g_chars * hipfire_glue_weight) / 100), 0, 100);
                        }
                        if(subsystem_flags & SUBSYSTEM_RESISTANCE){
                            g_val = (hipfire_glue_resist_gain * hipfire_glue_weight) / 100;
                            hipfire_resistance_bonus = hipfire_resistance_bonus + g_val;
                            if(cone_engage_weight > 0 && hipfire_resistance_bonus < UE_CONE_RESIST_FLOOR){
                                hipfire_resistance_bonus = UE_CONE_RESIST_FLOOR;
                            }
                            if(hipfire_resistance_bonus < UE_HIP_RESIST_FLOOR){
                                hipfire_resistance_bonus = UE_HIP_RESIST_FLOOR;
                            }
                            g_chars = hipfire_glue_resist_cap;
                            if(hipfire_engaged && g_chars < HIP_ENGAGE_RESIST_CAP){
                                g_chars = HIP_ENGAGE_RESIST_CAP;
                            }
                            if(g_chars > 0 && hipfire_resistance_bonus > g_chars){
                                hipfire_resistance_bonus = g_chars;
                            }
                        }
                        if(magnet_super_resist_bonus > 0){
                            hipfire_resistance_bonus = hipfire_resistance_bonus + magnet_super_resist_bonus;
                            g_chars = hipfire_glue_resist_cap;
                            if(hipfire_engaged && g_chars < HIP_ENGAGE_RESIST_CAP){
                                g_chars = HIP_ENGAGE_RESIST_CAP;
                            }
                            if(g_chars > 0 && hipfire_resistance_bonus > g_chars){
                                hipfire_resistance_bonus = g_chars;
                            }
                        }
                        if(cone_engage_weight > 0 && hipfire_resistance_bonus < UE_CONE_RESIST_FLOOR){
                            hipfire_resistance_bonus = UE_CONE_RESIST_FLOOR;
                        }
                    }
        
                    if(!(subsystem_flags & SUBSYSTEM_SLOWDOWN)){
                        slowdown_factor = 100;
                    }
        
                    if(freedom_release_blend > 0){
                        g_val = (FREEDOM_RELEASE_SLOWDOWN * freedom_release_blend) / 100; // release_slow_pct
                        g_temp = (FREEDOM_RELEASE_ROTATION * freedom_release_blend) / 100; // release_rot_pct
                        g_p = (FREEDOM_RELEASE_SNAP * freedom_release_blend) / 100; // release_snap_pct
                        if(g_val > 100) g_val = 100;
                        if(g_temp > 100) g_temp = 100;
                        if(g_p > 100) g_p = 100;
                        slowdown_factor = lerp_pct(slowdown_factor, 100, g_val);
                        assist_slowdown_blend = (assist_slowdown_blend * (100 - g_val)) / 100;
                        assist_rotation_blend = (assist_rotation_blend * (100 - g_temp)) / 100;
                        assist_snap_blend = (assist_snap_blend * (100 - g_p)) / 100;
                        if(assist_slowdown_blend < 0) assist_slowdown_blend = 0;
                        if(assist_rotation_blend < 0) assist_rotation_blend = 0;
                        if(assist_snap_blend < 0) assist_snap_blend = 0;
                    }
        
                    g_temp = clamp_i(enemy_speed_mag, 0, 160);
                    g_expected = SPEED_DYNAMIC_MAX - ((SPEED_DYNAMIC_MAX - SPEED_DYNAMIC_MIN) * g_temp) / 160;
                    if(g_expected < SPEED_DYNAMIC_MIN) g_expected = SPEED_DYNAMIC_MIN;
                    if(g_expected > SPEED_DYNAMIC_MAX) g_expected = SPEED_DYNAMIC_MAX;
                    slowdown_factor = (slowdown_factor * g_expected) / 100;
                if(magnet_capture_active){
                    slowdown_factor = (slowdown_factor * (100 + magnet_capture_slowdown_boost)) / 100;
                }
        
                if(ai_confidence_pct >= AI_SNAP_CONFIDENCE_GATE){
                    g_val = 100 - AI_MAGNET_SLOWDOWN_BONUS;
                    if(g_val < 10) g_val = 10;
                    slowdown_factor = (slowdown_factor * g_val) / 100;
                    if(slowdown_factor < 4) slowdown_factor = 4;
                }
        
                slowdown_factor = (slowdown_factor * align_suppress_slowdown_scale) / 100;
                if(align_suppress_freeze){
                    slowdown_factor = clamp_i(slowdown_factor, 0, 6);
                } else if(slowdown_factor < 2){
                    slowdown_factor = 2;
                }
        
                apply_overdrive_boosts();
        
                stabilized_rx = (rx * slowdown_factor) / 100;
                    stabilized_ry = (ry * slowdown_factor) / 100;
        
                    if(native_probe_active && !ads){
                        stabilized_rx = stabilized_rx + native_probe_rx;
                        stabilized_ry = stabilized_ry + native_probe_ry;
                    }
        
                    // DAMPING CURVE - voorkom zero-crossing wobble
                    if(magnet_lock_gate && input_mag <= LOCK_THRESHOLD){
                        // Als we dicht bij center zijn, extra damping
                        if(abs(stabilized_rx) <= DAMPING_THRESHOLD){
                            stabilized_rx = (stabilized_rx * DAMPING_FACTOR) / 100;  // 45% damping
                        }
                        if(abs(stabilized_ry) <= DAMPING_THRESHOLD){
                            stabilized_ry = (stabilized_ry * DAMPING_FACTOR) / 100;  // 45% damping
                        }
                    }
        
                    // ========= ROTATION PULL (VEEL ZWAKKER!) =========
                    rotation_x = 0;
                    rotation_y = 0;
        
                    // Rotation ALLEEN bij CONFIRMED tracking (zeer strikt!)
        
                    if((subsystem_flags & SUBSYSTEM_ROTATION) && assist_rotation_blend > 0 && bubble_zone_stable > 0){
                        g_temp = rotation_pull_hip_map[clamp_i(bubble_zone - 1, 0, 3)];
                        if(ads) g_temp = rotation_pull_ads_map[clamp_i(bubble_zone - 1, 0, 3)];
        
                        rotation_factor = (g_temp * (50 + assist_rotation_blend)) / 100;
                        rotation_factor = (rotation_factor * weapon_gain_rotation_mix) / 100;
                        if(ads){
                            rotation_factor = (rotation_factor * weapon_gain_ads_rotation_mix) / 100;
                        }
                        rotation_factor = clamp_i(rotation_factor, 4, 40);
                        rotation_factor = (rotation_factor * 5) / 2;
        
                        g_temp = (0 - stabilized_rx) * assist_rotation_blend;
                        rotation_x = g_temp / (rotation_factor * 20);
                        g_temp = (0 - stabilized_ry) * assist_rotation_blend;
                        rotation_y = g_temp / (rotation_factor * 20);
        
                        rotation_x = clamp_i(rotation_x, -12, 12);
                        rotation_y = clamp_i(rotation_y, -10, 10);
        
                        if(idle_timer >= IDLE_AUTO_PULL_TIME && movement_timer >= MOVEMENT_GATE_TIME &&
                        (r2_assist_timer >= 150 || r2_assist_fade_timer > 0) && !ads && !hyper_burst_active && !flick_detected){
                            g_temp = (AUTO_PULL_STRENGTH * assist_core_blend * weapon_gain_autopull_mix) / 10000;
                            g_temp = (g_temp * aim_state_auto_pull_pct) / 100;
                            if(search_release_pct > 0){
                                g_p = 100 - search_release_pct;
                                g_temp = (g_temp * g_p) / 100;
                            }
                            g_temp = clamp_i(g_temp, 0, 150);
                            auto_pull_x = ((0 - stabilized_rx) * g_temp) / 100;
                            auto_pull_y = ((0 - stabilized_ry) * g_temp) / 100;
                            rotation_x = rotation_x + auto_pull_x;
                            rotation_y = rotation_y + auto_pull_y;
                        }
        
                        if(magnet_capture_active){
                            snap_factor = (snap_factor * (100 + magnet_capture_snap_boost)) / 100;
                        }
                        if(current_range == 0) range_slider = slider_close;
                        else if(current_range == 1) range_slider = slider_medium;
                        else range_slider = slider_far;
                        range_scale_pct = apply_curve_range_gain(apply_drift_free_scaling(100, range_slider));
        
                    if(sticky_edge_weight > 0){
                            rotation_x = (rotation_x * (100 + STICKY_EDGE_GAIN)) / 100;
                            rotation_y = (rotation_y * (100 + STICKY_EDGE_GAIN)) / 100;
                        }
                        if(freedom_release_active && !auto_aim_overrun_active){
                            rotation_x = (rotation_x * (100 - FREEDOM_RELEASE_ROTATION)) / 100;
                            rotation_y = (rotation_y * (100 - FREEDOM_RELEASE_ROTATION)) / 100;
                        }
                        if(magnet_capture_active){
                            rotation_x = (rotation_x * (100 + magnet_capture_rotation_boost)) / 100;
                            rotation_y = (rotation_y * (100 + magnet_capture_rotation_boost)) / 100;
                        }
                        if(ai_confidence_pct > 0){
                            g_temp = (ai_output_rx * AI_ROTATION_BLEND_PCT) / 100;
                            g_chars = (ai_output_ry * AI_ROTATION_BLEND_PCT) / 100;
                            if(search_release_pct > 0){
                                g_total = lerp_pct(100, UE_SEARCH_RELEASE_AI, search_release_pct);
                                g_temp = (g_temp * g_total) / 100;
                                g_chars = (g_chars * g_total) / 100;
                            }
                            if(ads_lock_steady_active){
                                g_temp = (g_temp * UE_ADS_LOCK_AI_BLEND) / 100;
                                g_chars = (g_chars * UE_ADS_LOCK_AI_BLEND) / 100;
                            }
                            rotation_x = rotation_x + g_temp;
                            rotation_y = rotation_y + g_chars;
                        }
                        if(magnet_capture_active || ai_confidence_pct >= AI_SNAP_CONFIDENCE_GATE){
                            g_temp = (ai_output_rx * AI_MAGNET_ROT_BONUS) / 100;
                            g_chars = (ai_output_ry * AI_MAGNET_ROT_BONUS) / 100;
                            if(search_release_pct > 0){
                                g_total = lerp_pct(100, UE_SEARCH_RELEASE_AI, search_release_pct);
                                g_temp = (g_temp * g_total) / 100;
                                g_chars = (g_chars * g_total) / 100;
                            }
                            if(ads_lock_steady_active){
                                g_temp = (g_temp * UE_ADS_LOCK_AI_BLEND) / 100;
                                g_chars = (g_chars * UE_ADS_LOCK_AI_BLEND) / 100;
                            }
                            rotation_x = rotation_x + g_temp;
                            rotation_y = rotation_y + g_chars;
                        }
                        if(ai_confidence_pct >= AI_RESIST_CONF_GAIN){
                            g_val = (enemy_dir_x * AI_STRAFE_PUSH_GAIN) / 100;
                            g_temp = (enemy_dir_y * AI_STRAFE_PUSH_GAIN) / 140;
                            if(search_release_pct > 0){
                                g_expected = lerp_pct(100, UE_SEARCH_RELEASE_AI, search_release_pct);
                                g_val = (g_val * g_expected) / 100;
                                g_temp = (g_temp * g_expected) / 100;
                            }
                            rotation_x = rotation_x + g_val;
                            rotation_y = rotation_y + g_temp;
                        }
                        if(search_release_pct > 0){
                            g_expected = lerp_pct(100, UE_SEARCH_RELEASE_ROT, search_release_pct);
                            rotation_x = (rotation_x * g_expected) / 100;
                            rotation_y = (rotation_y * g_expected) / 100;
                        }
        
                        if(bullet_correct_gain > 0){
                            g_temp = (bullet_correct_gain * bubble_lock_weight) / 100;
                            if(g_temp < 0) g_temp = 0;
                            g_temp = (g_temp * (100 - bubble_release_weight)) / 100;
                            if(!ads){
                                g_temp = (g_temp * 80) / 100;
                                if(oneshot_mode){
                                    g_temp = (g_temp * HIP_ONESHOT_SUPER_GAIN) / 140;
                                }
                            } else {
                                g_temp = (g_temp * 110) / 100;
                            }
                            if(g_temp > bullet_correct_gain) g_temp = bullet_correct_gain;
                            g_p = (bullet_correct_offset_x * g_temp) / 12;
                            g_fill = (bullet_correct_offset_y * g_temp) / 14;
                            if(ads_lock_steady_active){
                                g_p = (g_p * UE_ADS_LOCK_BULLET_BLEND) / 100;
                                g_fill = (g_fill * UE_ADS_LOCK_BULLET_BLEND) / 100;
                            }
                            rotation_x = rotation_x + g_p;
                            rotation_y = rotation_y + g_fill;
                        }
        
                        // apply_unreal_rotation_scalers();  // DISABLED - stub function not needed
                        rotation_x = (rotation_x * rotation_scale_pct) / 100;
                        rotation_y = (rotation_y * rotation_scale_pct) / 100;
                    if(align_suppress_freeze){
                        g_val = 28;
                        if(hipfire_engaged){
                            g_val = g_val + 12 + (hipfire_engage_strength / 4);
                        }
                        if(hipfire_sticky_active){
                            g_val = g_val + 8;
                        }
                        if(cone_engage_weight > 0){
                            g_val = g_val + (cone_engage_weight / 3);
                        }
                        if(magnet_capture_active){
                            g_val = g_val + (magnet_capture_strength / 5);
                        }
                        if(g_val > 78) g_val = 78;
                        if(g_val < 18) g_val = 18;
                        g_temp = 100 - g_val;
                        if(g_temp < 14) g_temp = 14;
                        g_chars = (torque_persist_x * g_temp) / 100;
                        g_total = (torque_persist_y * g_temp) / 100;
                        rotation_x = (rotation_x * g_val) / 100 + g_chars;
                        rotation_y = (rotation_y * g_val) / 100 + g_total;
                    } else if(align_suppress_rotation_scale < 100){
                        rotation_x = (rotation_x * align_suppress_rotation_scale) / 100;
                        rotation_y = (rotation_y * align_suppress_rotation_scale) / 100;
                    }
                    if(ads_lock_steady_active){
                            rotation_x = (rotation_x * UE_ADS_LOCK_ROT_DAMP) / 100;
                            rotation_y = (rotation_y * UE_ADS_LOCK_ROT_DAMP) / 100;
                        }
                        if(input_velocity <= AIM_STABILITY_INPUT_GATE && aim_error_pixels <= AIM_STABILITY_ERROR_GATE){
                            if(ads){
                                g_val = ADS_ROTATION_SUPPRESS_PCT;
                                if(magnet_lock_gate && lock_confidence >= 65){
                                    g_val = UE_ADS_LOCK_ROT_SUPPRESS;
                                }
                            } else {
                                g_val = HIP_ROTATION_SUPPRESS_PCT;
                            }
                            if(g_val > 0){
                                rotation_x = (rotation_x * (100 - g_val)) / 100;
                                rotation_y = (rotation_y * (100 - g_val)) / 100;
                            }
                        }
        
                        g_temp = 15;
                        g_chars = 12;
                        if(bullet_correct_gain > 0){
                            g_total = (bullet_correct_gain * 9) / 4;
                            if(g_total > 48) g_total = 48;
                            g_temp = g_temp + g_total;
                            g_expected = (bullet_correct_gain * 7) / 4;
                            if(g_expected > 40) g_expected = 40;
                            g_chars = g_chars + g_expected;
                            if(!ads && oneshot_mode){
                                g_temp = (g_temp * HIP_ONESHOT_SUPER_GAIN) / 100;
                                g_chars = (g_chars * HIP_ONESHOT_SUPER_GAIN) / 100;
                            }
                            if(g_temp > 72) g_temp = 72;
                            if(g_chars > 58) g_chars = 58;
                        }
                        rotation_x = clamp_i(rotation_x, -g_temp, g_temp);
                        rotation_y = clamp_i(rotation_y, -g_chars, g_chars);
        
                        stabilized_rx = stabilized_rx + rotation_x;
                        stabilized_ry = stabilized_ry + rotation_y;
        
                        if(!ads && magnet_lock_gate && lock_confidence >= HIP_PULSE_SUPPRESS_LOCK){
                            g_expected = (HIP_AUTO_STEER_GAIN * lock_confidence) / 100;
                            if(g_expected < 12) g_expected = 12;
                            if(g_expected > 68) g_expected = 68;
                            if(sticky_edge_weight > 0){
                                g_temp = (HIP_AUTO_STEER_EDGE_BONUS * sticky_edge_weight) / 100;
                                g_expected = g_expected + g_temp;
                                if(g_expected > 78) g_expected = 78;
                            }
        
                            g_val = predict_offset_x - pixel_offset_x;
                            g_val = g_val + ((ai_output_rx * AI_AUTOSTEER_BLEND_PCT) / 100);
                            hip_auto_steer_x = (g_val * g_expected) / 100;
        
                            g_temp = predict_offset_y - pixel_offset_y;
                            g_temp = g_temp + ((ai_output_ry * AI_AUTOSTEER_BLEND_PCT) / 100);
                            hip_auto_steer_y = (g_temp * g_expected) / 120;
        
                            if(ballistic_active > 0){
                                g_total = (ballistic_travel_offset_x * BALLISTIC_HIP_AUTOSTEER_BLEND) / 100;
                                g_total = g_total / BALLISTIC_STICK_DIVISOR;
                                hip_auto_steer_x = hip_auto_steer_x + (g_total * ballistic_active) / 100;
        
                                g_expected = (ballistic_drop_offset * BALLISTIC_HIP_AUTOSTEER_BLEND) / 100;
                                g_expected = g_expected / BALLISTIC_STICK_DIVISOR;
                                hip_auto_steer_y = hip_auto_steer_y - (g_expected * ballistic_active) / 100;
                            }
        
                            hip_auto_steer_x = clamp_i(hip_auto_steer_x, -20, 20);
                            hip_auto_steer_y = clamp_i(hip_auto_steer_y, -16, 16);
        
                            if(align_suppress_glide_scale < 100){
                                hip_auto_steer_x = (hip_auto_steer_x * align_suppress_glide_scale) / 100;
                                hip_auto_steer_y = (hip_auto_steer_y * align_suppress_glide_scale) / 100;
                            }
        
                            if(search_release_pct > 0){
                                g_val = lerp_pct(100, UE_SEARCH_RELEASE_BIAS, search_release_pct);
                                hip_auto_steer_x = (hip_auto_steer_x * g_val) / 100;
                                hip_auto_steer_y = (hip_auto_steer_y * g_val) / 100;
                            }
        
                            if(align_suppress_freeze){
                                hip_auto_steer_x = 0;
                                hip_auto_steer_y = 0;
                            }
        
                            if(freedom_release_active){
                                hip_auto_steer_x = (hip_auto_steer_x * (100 - FREEDOM_RELEASE_ROTATION)) / 100;
                                hip_auto_steer_y = (hip_auto_steer_y * (100 - FREEDOM_RELEASE_ROTATION)) / 100;
                            }
        
                            stabilized_rx = stabilized_rx + hip_auto_steer_x;
                            stabilized_ry = stabilized_ry + hip_auto_steer_y;
                        }
        
                        if(!ads && magnet_lock_gate && lock_confidence >= HIP_GLIDE_LOCK_MIN){
                            g_val = predict_offset_x - pixel_offset_x;
                            g_val = g_val + ((ai_output_rx * AI_GLIDE_BLEND_PCT) / 100);
                            g_temp = predict_offset_y - pixel_offset_y;
                            g_temp = g_temp + ((ai_output_ry * AI_GLIDE_BLEND_PCT) / 100);
                            g_total = HIP_GLIDE_GAIN_BASE + (lock_confidence / 3);
                            if(g_total > 82) g_total = 82;
                            if(magnet_capture_active){
                                g_total = g_total + (magnet_capture_strength * HIP_GLIDE_GAIN_CAPTURE_BONUS) / 100;
                            }
                            if(g_total > 94) g_total = 94;
                            hip_glide_rx = smooth_gain(hip_glide_rx, g_val, g_total);
                            hip_glide_ry = smooth_gain(hip_glide_ry, g_temp, g_total);
                        } else {
                            hip_glide_rx = smooth_gain(hip_glide_rx, 0, HIP_GLIDE_DECAY_GAIN);
                            hip_glide_ry = smooth_gain(hip_glide_ry, 0, HIP_GLIDE_DECAY_GAIN);
                        }
        
                        if(ballistic_active > 0){
                            g_chars = (ballistic_travel_offset_x * BALLISTIC_HIP_GLIDE_BLEND) / 100;
                            g_chars = g_chars / BALLISTIC_STICK_DIVISOR;
                            hip_glide_rx = hip_glide_rx + (g_chars * ballistic_active) / 100;
        
                            g_total = (ballistic_drop_offset * BALLISTIC_HIP_GLIDE_BLEND) / 100;
                            g_total = g_total / BALLISTIC_STICK_DIVISOR;
                            hip_glide_ry = hip_glide_ry - (g_total * ballistic_active) / 100;
                        }
        
                        hip_glide_rx = clamp_i(hip_glide_rx, -18, 18);
                        hip_glide_ry = clamp_i(hip_glide_ry, -14, 14);
        
                        if(align_suppress_glide_scale < 100){
                            hip_glide_rx = (hip_glide_rx * align_suppress_glide_scale) / 100;
                            hip_glide_ry = (hip_glide_ry * align_suppress_glide_scale) / 100;
                        }
        
                        if(search_release_pct > 0){
                            g_val = lerp_pct(100, UE_SEARCH_RELEASE_BIAS, search_release_pct);
                            hip_glide_rx = (hip_glide_rx * g_val) / 100;
                            hip_glide_ry = (hip_glide_ry * g_val) / 100;
                        }
        
                        if(align_suppress_freeze){
                            hip_glide_rx = 0;
                            hip_glide_ry = 0;
                        }
        
                        stabilized_rx = stabilized_rx + hip_glide_rx;
                        stabilized_ry = stabilized_ry + hip_glide_ry;
        
                        if(bullet_correct_gain > 0){
                            g_chars = bubble_lock_weight;
                            if(g_chars < 0) g_chars = 0;
                            g_chars = (g_chars * (100 - bubble_release_weight)) / 100;
                            g_val = (bullet_correct_gain * g_chars) / 100;
                            if(!ads){
                                g_val = (g_val * 75) / 100;
                                if(oneshot_mode){
                                    g_val = (g_val * HIP_ONESHOT_SUPER_GAIN) / 140;
                                }
                            } else {
                                g_val = (g_val * 110) / 100;
                            }
                            if(g_val > bullet_correct_gain) g_val = bullet_correct_gain;
        
                            g_temp = (AI_BULLET_CORRECT_DIRECT_BLEND * g_chars) / 100;
                            if(g_temp > AI_BULLET_CORRECT_DIRECT_BLEND) g_temp = AI_BULLET_CORRECT_DIRECT_BLEND;
        
                        g_expected = (bullet_correct_blend_x * (g_temp + g_val)) / 140;
                        g_total = (bullet_correct_blend_y * (g_temp + g_val)) / 150;
        
                            if(ads_lock_steady_active){
                                g_p = (g_p * UE_ADS_LOCK_BULLET_BLEND) / 100;
                                g_fill = (g_fill * UE_ADS_LOCK_BULLET_BLEND) / 100;
                            }
                            if(search_release_pct > 0){
                                g_total = lerp_pct(100, UE_SEARCH_RELEASE_BIAS, search_release_pct);
                                g_p = (g_p * g_total) / 100;
                                g_fill = (g_fill * g_total) / 100;
                            }
        
                        if(!ads && !oneshot_mode){
                                g_expected = (g_expected * 70) / 100;
                                g_total = (g_total * 70) / 100;
                            }
        
                            if(search_release_pct > 0){
                                g_chars = lerp_pct(100, UE_SEARCH_RELEASE_BIAS, search_release_pct);
                                g_expected = (g_expected * g_chars) / 100;
                                g_total = (g_total * g_chars) / 100;
                            }
        
                            g_expected = clamp_i(g_expected, -60, 60);
                            g_total = clamp_i(g_total, -48, 48);
        
                                g_expected = (g_expected * align_suppress_bullet_scale) / 100;
                                g_total = (g_total * align_suppress_bullet_scale) / 100;
        
                            if(align_suppress_freeze){
                                g_expected = 0;
                                g_total = 0;
                            }
        
                            stabilized_rx = stabilized_rx + g_expected;
                            stabilized_ry = stabilized_ry + g_total;
                        }
                    }
                    else {
                        snap_ramp_timer = 0;
                    }
        
                    // Bubble center pull: injects the smoothed core offset directly into the stick so the reticle recenters without fighting user micro-corrections.
                    if(magnet_lock_gate && bubble_lock_weight > 0){
                        if(align_suppress_freeze){
                            bubble_center_pull_x = 0;
                            bubble_center_pull_y = 0;
                        }
                        if(ads_lock_steady_active){
                            g_temp = (bubble_center_pull_x * UE_ADS_LOCK_CENTER_BLEND) / 100;
                            g_chars = (bubble_center_pull_y * UE_ADS_LOCK_CENTER_BLEND) / 100;
                            stabilized_rx = stabilized_rx + g_temp;
                            stabilized_ry = stabilized_ry + g_chars;
                        } else {
                            stabilized_rx = stabilized_rx + bubble_center_pull_x;
                            stabilized_ry = stabilized_ry + bubble_center_pull_y;
                        }
                    }
        
                    if(overdrive_bias_rx != 0 || overdrive_bias_ry != 0){
                        stabilized_rx = stabilized_rx + overdrive_bias_rx;
                        stabilized_ry = stabilized_ry + overdrive_bias_ry;
                    }
        
                    // ========= v2.0 PROGRESSIVE SNAP (150ms delay!) =========
                    snap_x = 0;
                    snap_y = 0;
        
                    // DELAY-AWARE: snap alleen actief NA 150ms delay (sync met Fortnite delayed tracking)
                    if((subsystem_flags & SUBSYSTEM_SNAP) && magnet_lock_gate && lock_strength >= SNAP_MIN_LOCK && bubble_zone_stable > 0 && bubble_zone_stable <= 3 && r2_assist_timer >= 150){
                        // HYPER-BURST snap!
                        if(hyper_burst_active){
                            snap_factor = HYPER_BURST_SNAP;  // 60px mega snap!
                            snap_ramp_timer = SNAP_RAMP_TIME;  // Instant max
                        }
                        // ONE-SHOT krijgt INSTANT ramp!
                        else if(oneshot_mode) {
                            if(bubble_zone_stable == 1) snap_factor = SNAP_STRENGTH_ULTRA;
                            else if(bubble_zone_stable == 2) snap_factor = SNAP_STRENGTH_CLOSE;
                            else snap_factor = SNAP_STRENGTH_MEDIUM;
                            snap_ramp_timer = SNAP_RAMP_TIME;  // Instant max
                        }
                        else {
                            // Basis strength op zone
                            if(bubble_zone == 1) snap_factor = SNAP_STRENGTH_ULTRA;
                            else if(bubble_zone == 2) snap_factor = SNAP_STRENGTH_CLOSE;
                            else snap_factor = SNAP_STRENGTH_MEDIUM;
        
                            // Progressive ramp-up (120ms smooth)
                            if(snap_ramp_timer < SNAP_RAMP_TIME){
                                g_val = delta;
                                g_temp = snap_super_ramp_bonus + snap_magnet_ramp_bonus;
                                if(g_temp > 0){
                                    g_val = (g_val * (100 + g_temp)) / 100;
                                    if(g_val < delta) g_val = delta;
                                    if(g_val > delta * 6) g_val = delta * 6;
                                }
                                snap_ramp_timer = snap_ramp_timer + g_val;
                                // Quadratic ease-in voor natuurlijk gevoel
                                ramp_pct = (snap_ramp_timer * 100) / SNAP_RAMP_TIME;
                                ramp_pct = (ramp_pct * ramp_pct) / 100;  // Square voor ease
                                snap_factor = (snap_factor * ramp_pct) / 100;
                            }
        
                            snap_factor = (snap_factor * (50 + range_slider)) / 100;
                        }
                        snap_factor = (snap_factor * weapon_gain_snap_mix) / 100;
                        if(snap_factor > 220) snap_factor = 220;
                        if(snap_factor < 10) snap_factor = 10;
        
                        g_val = bubble_outer_radius - bubble_inner_radius;
                        if(g_val < 1) g_val = 1;
                        g_temp = distance_pixels - bubble_inner_radius;
                        if(g_temp < 0) g_temp = 0;
                        if(g_temp > g_val) g_temp = g_val;
                        g_expected = (g_temp * 100) / g_val;
                        snap_stage = 0;
                        if(g_expected >= SNAP_STAGE_TWO) snap_stage = 2;
                        else if(g_expected >= SNAP_STAGE_ONE) snap_stage = 1;
        
                        if(snap_stage == 1){
                            snap_factor = (snap_factor * 120) / 100;
                        }
                        else if(snap_stage == 2){
                            snap_factor = (snap_factor * 150) / 100;
                        }
        
                        if(snap_super_gain_pct > 0){
                            snap_factor = snap_factor + snap_super_gain_pct;
                            if(snap_factor > UE_SNAP_SUPER_CAP) snap_factor = UE_SNAP_SUPER_CAP;
                        }
        
                        if(ai_confidence_pct >= AI_SNAP_CONFIDENCE_GATE){
                            snap_factor = (snap_factor * 140) / 100;
                            snap_ramp_timer = SNAP_RAMP_TIME;
                        }
                        if(sticky_edge_weight > 0){
                            snap_factor = (snap_factor * (100 + STICKY_EDGE_SNAP_GAIN)) / 100;
                        }
                        if(freedom_release_active){
                            snap_factor = (snap_factor * (100 - FREEDOM_RELEASE_SNAP)) / 100;
                        }
        
                        snap_x = ((0 - stabilized_rx) * lock_strength) / 100;
                        snap_y = ((0 - stabilized_ry) * lock_strength) / 100;
        
                        if(sticky_edge_weight > 0){
                            snap_x = (snap_x * (100 + STICKY_EDGE_SNAP_GAIN)) / 100;
                            snap_y = (snap_y * (100 + STICKY_EDGE_SNAP_GAIN)) / 100;
                        }
                        if(freedom_release_active){
                            snap_x = (snap_x * (100 - FREEDOM_RELEASE_SNAP)) / 100;
                            snap_y = (snap_y * (100 - FREEDOM_RELEASE_SNAP)) / 100;
                        }
        
                        snap_x = (snap_x * align_suppress_snap_scale) / 100;
                        snap_y = (snap_y * align_suppress_snap_scale) / 100;
        
                        if(snap_x > snap_factor) snap_x = snap_factor;
                        if(snap_x < 0 - snap_factor) snap_x = 0 - snap_factor;
                        if(snap_y > snap_factor) snap_y = snap_factor;
                        if(snap_y < 0 - snap_factor) snap_y = 0 - snap_factor;
        
                        stabilized_rx = stabilized_rx + snap_x;
                        stabilized_ry = stabilized_ry + snap_y;
                    }
        
                    // ========= MICRO SEARCH =========
                    micro_search_x = 0;
                    micro_search_y = 0;
        
                    if(!magnet_lock_gate && bubble_zone == 0 && input_mag < MICRO_ACTIVE_THRESH){
                        g_temp = MICRO_RADIUS_SEARCH;
        
                        // Deadzone slider is removed. This feature is not active.
        
                        micro_angle = micro_angle + MICRO_SPEED_SEARCH;
                        if(micro_angle >= 360) micro_angle = micro_angle - 360;
        
                        // ✅ SMOOTH CIRCULAR MOTION - Lookup table instead of piecewise linear!
                        // Convert angle (0-360) to index (0-15)
                        g_val = (micro_angle * 16) / 360;
                        if(g_val > 15) g_val = 15;  // Safety clamp
        
                        // Use lookup tables for smooth sin/cos
                        micro_search_x = (g_temp * cosLUT[g_val]) / 100;
                        micro_search_y = (g_temp * sinLUT[g_val]) / 100;
                    }
        
                    // Map computed micro search offsets into active micro orbit output
                    micro_x = micro_search_x;
                    micro_y = micro_search_y;
        
                    if(align_suppress_freeze){
                        micro_x = 0;
                        micro_y = 0;
                    }
        
                    // ========= AERIAL/TRICKSHOT BOOST =========
                    aerial_offset_y = 0;
        
                    if(jumping || aerial_mode || trickshot_lock){
                        aerial_timer = aerial_timer + 1;
        
                        if(trickshot_lock || (jumping && input_mag <= 50)){
                            if(!target_locked && input_mag <= 50){
                                target_locked = 1;
                                lock_timer = 10;
                            }
        
                            if(target_locked){
                                snap_x = snap_x * 2;
                                snap_y = snap_y * 2;
                            }
        
                            rotation_x = rotation_x * 2;
                            rotation_y = rotation_y * 2;
        
                            fall_velocity = (aerial_timer * 15) / 10;
        
                            if(shooting){
                                aerial_offset_y = (fall_velocity * 20) / 100;
                            }
                            else {
                                aerial_offset_y = (fall_velocity * 30) / 100;
                            }
        
                            // Trickshot slider is removed, logic is now baseline.
                        }
                    }
                    else {
                        aerial_timer = 0;
                        fall_velocity = 0;
                    }
        
                    stabilized_ry = stabilized_ry + aerial_offset_y;
        
                    // ========= PREDICTIVE LAZY AIM BIAS =========
                    // Add predictive bias voor off-target hits!
                    if(align_suppress_freeze){
                        lazy_bias_x = 0;
                        lazy_bias_y = 0;
                    }
                    stabilized_rx = stabilized_rx + lazy_bias_x;
                    stabilized_ry = stabilized_ry + lazy_bias_y;
        
                    if(ai_confidence_pct > 0){
                        stabilized_rx = stabilized_rx + ai_output_rx;
                        stabilized_ry = stabilized_ry + ai_output_ry;
                    }
        
                    // ========= STICK RESISTANCE CORE (V4.5 TRUE MAGNETIC ADHESION!) =========
                    // v4.5: ULTRA STICKY - crosshair BLIJFT op enemy zelfs tijdens movement!
                    // Resistance actief tijdens ALLE tracking movements (niet alleen slow input)
                    // Dit is de FIX: assist blijft actief zelfs als je stick beweegt!
        
                    if((subsystem_flags & SUBSYSTEM_RESISTANCE) && current_strength_slider > 0 && magnet_lock_gate && !build_mode &&
                    (resistance_active || distance_pixels < 20) &&
                    input_velocity < 45){  // v4.5: VEEL HOGER voor true sticky tijdens tracking! (was 25)
                        // CRITICAL: Use REAL pixel distance, not processed stick output!
                        // Using stabilized_rx/ry was causing resistance outside bubble!
        
                        // TIGHT BUBBLE ONLY: distance_pixels < STICK_RESISTANCE_THRESHOLD (15px)
                        if(distance_pixels < STICK_RESISTANCE_THRESHOLD){
                            // Base strength from slider using NEW system (0=disabled, 50=100%, 100=200%)
                            g_expected = apply_drift_free_scaling(STICK_RESISTANCE_MAX, current_strength_slider);
                            g_expected = (g_expected * weapon_gain_resist_mix) / 100;
        
                            // SCALAR RESISTANCE: lock confidence, snap stage, and error stability
                            resistance_lock_scalar = clamp_i((lock_confidence * 120) / 100, 30, 100);
                            resistance_snap_scalar = clamp_i((snap_stage * 25), 50, 100);
                            resistance_error_scalar = 100 - soft_step(aim_error_avg, 5, 25);
                            resistance_error_scalar = clamp_i(resistance_error_scalar, 10, 100);
        
                            resistance_combined_pct = (resistance_lock_scalar * 40 + resistance_snap_scalar * 30 + resistance_error_scalar * 30) / 100;
                            resistance_combined_pct = clamp_i(resistance_combined_pct, 40, 120);
        
                            g_expected = (g_expected * resistance_combined_pct) / 100;
                            g_expected = g_expected + hipfire_resistance_bonus;
                            if(ai_confidence_pct >= AI_RESIST_CONF_GAIN){
                                g_total = ai_confidence_pct - AI_RESIST_CONF_GAIN;
                                if(g_total < 0) g_total = 0;
                                g_total = clamp_i(g_total, 0, 40);
                                g_expected = g_expected + g_total;
                            }
                            if(magnet_capture_active){
                                g_expected = g_expected + magnet_capture_resist_boost;
                            }
                            if(resistance_glue_active){
                                g_expected = g_expected + resistance_glue_gain;
                            }
                            g_expected = (g_expected * align_suppress_resist_scale) / 100;
                            g_expected = (g_expected * aim_state_resistance_pct) / 100;
                            if(bullet_correct_gain > 0 || hip_fast_track_active){
                                g_expected = (g_expected * 85) / 100;
                            }
                            if(g_expected > 82) g_expected = 82;
                            if(!ads && g_expected < UE_HIP_RESIST_FLOOR) g_expected = UE_HIP_RESIST_FLOOR;
                            if(g_expected < 5) g_expected = 5;
        
                            // GRADUAL FADE: closer to center = stronger damping
                            // Distance 0 = 100% of strength, distance 15 = 0%
                            g_temp = (STICK_RESISTANCE_THRESHOLD - distance_pixels) * 100 / STICK_RESISTANCE_THRESHOLD;
                            g_expected = (g_expected * g_temp) / 100;
        
                    // v4.5: ANTI-FEEDBACK LOOP - resistance blijft actief tijdens tracking!
                    // Veel minder gevoelig voor velocity changes = true sticky adhesion!
                    g_temp = INPUT_VELOCITY_DISABLE_HIP;
                    if(ads) g_temp = INPUT_VELOCITY_DISABLE_ADS;
        
                    // v4.5: Start fading VEEL HOGER voor maximum persistence tijdens tracking
                    if(input_velocity > 25){  // v4.5: HOGER threshold! (was 15)
                        g_val = 25;              // fade_start threshold
                        g_chars = g_tboost;      // fade_end threshold (fast-velocity gate)
                        if(g_chars <= g_val){
                            g_chars = g_val + 1;
                        }
                        g_p = g_chars - input_velocity;
                        if(g_p < 0) g_p = 0;
                        g_p = (g_p * 100) / (g_chars - g_val);
                        g_p = clamp_i(g_p, 0, 100);
                        g_expected = (g_expected * g_p) / 100;
                    }
        
                    // Apply smooth fading due to freedom release
                    if(freedom_release_blend > 0){
                        g_expected = (g_expected * (100 - freedom_release_blend)) / 100;
                    }
        
                    // Apply smooth damping (complement rotation pulse)
                    stabilized_rx = (stabilized_rx * (100 - g_expected)) / 100;
                    stabilized_ry = (stabilized_ry * (100 - g_expected)) / 100;
                        }
                    }
                    // Else: fast input detected - NO RESISTANCE (vrije correctie!)
        
                    // ========= ADD DITHERING (PHASE F ANTI-DETECTION) =========
                    g_val = smoothness_noise_pct; // Jitter strength inverse to smoothness slider
                    g_temp = (g_val * 8) / 100; // Base dither range
                    if(ads){
                        g_temp = (g_temp * (100 - ADS_DITHER_REDUCTION_PCT)) / 100;
                    } else {
                        g_temp = (g_temp * (100 - HIP_DITHER_REDUCTION_PCT)) / 100;
                    }
                    if(input_velocity <= AIM_STABILITY_INPUT_GATE && aim_error_pixels <= AIM_STABILITY_ERROR_GATE){
                        g_temp = (g_temp * 30) / 100;
                    }
                    if(ads && magnet_lock_gate && lock_confidence >= UE_ADS_LOCK_CONF_GATE){
                        g_temp = 0;
                    } else if(ads && magnet_lock_gate && lock_confidence >= 65){
                        g_temp = (g_temp * UE_ADS_LOCK_DITHER_SCALE) / 100;
                    }
                    if(align_lock_active){
                        g_temp = (g_temp * UE_ALIGN_LOCK_DITHER_SCALE) / 100;
                    }
                    g_temp = (g_temp * align_suppress_micro_scale) / 100;
                    if(g_temp < 1 && g_val > 0){
                        g_temp = 1;
                    }
                    g_p = waveform_rand_signed(g_temp);
                    g_fill = waveform_rand_signed(g_temp);
        
                /* COMBINE & OUTPUT - ATOMIC FIX v3 (ULTRA ISOLATION) */
                    // Stage micro + dither additions into specialized temp globals
                    g_val = micro_x + g_p; // g_val = micro_x + dither_x
                    g_temp = micro_y + g_fill; // g_temp = micro_y + dither_y
        
                    // Step 1: Initialize final output with stabilized input
                    final_rx = stabilized_rx;
                    final_ry = stabilized_ry;
        
                    // Step 2: Apply horizontal additions
                    final_rx = final_rx + g_val;
        
                    // Step 3: Apply vertical additions
                    final_ry = final_ry + g_temp;
        
                    if(input_velocity <= AIM_STABILITY_INPUT_GATE && aim_error_pixels <= AIM_STABILITY_ERROR_GATE){
                        if(ads){
                            final_rx = smooth_gain(final_rx_prev, final_rx, ADS_STABILITY_STIFFNESS);
                            final_ry = smooth_gain(final_ry_prev, final_ry, ADS_STABILITY_STIFFNESS);
                        } else {
                            final_rx = smooth_gain(final_rx_prev, final_rx, HIP_STABILITY_STIFFNESS);
                            final_ry = smooth_gain(final_ry_prev, final_ry, HIP_STABILITY_STIFFNESS);
                        }
                    }
                    if(ads && !magnet_lock_gate){
                        if(abs(rx) <= ADS_DRIFT_CANCEL_WINDOW && abs(ry) <= ADS_DRIFT_CANCEL_WINDOW && input_velocity <= ADS_DRIFT_CANCEL_VELOCITY){
                            final_rx = smooth_gain(final_rx, 0, ADS_DRIFT_CANCEL_BLEND);
                            final_ry = smooth_gain(final_ry, 0, ADS_DRIFT_CANCEL_BLEND);
                        }
                    }
        
                    if(search_release_pct > 0){
                        g_val = lerp_pct(100, UE_SEARCH_RELEASE_OUTPUT, search_release_pct);
                        final_rx = (final_rx * g_val + rx * (100 - g_val)) / 100;
                        final_ry = (final_ry * g_val + ry * (100 - g_val)) / 100;
                    }
                    if(search_output_pct < 100){
                        final_rx = (final_rx * search_output_pct) / 100;
                        final_ry = (final_ry * search_output_pct) / 100;
                    }
        
                    if(!ads && bullet_correct_gain > 0){
                        g_val = 0;
                        if(oneshot_mode) g_val = g_val + 2;
                        if(magnet_capture_active && lock_confidence >= HIP_AUTOCORRECT_LOCK_GATE) g_val = g_val + 1;
                        if(hipfire_engaged && lock_confidence >= HIP_AUTOCORRECT_LOCK_GATE) g_val = g_val + 1;
                        if(hipfire_sticky_active && lock_confidence >= HIP_AUTOCORRECT_LOCK_GATE) g_val = g_val + 1;
                        if(g_val > 0 && (lock_confidence >= HIP_AUTOCORRECT_LOCK_GATE || oneshot_mode)){
                            if(input_velocity <= HIP_AUTOCORRECT_RELEASE_VEL && aim_error_pixels <= HIP_PRELOCK_DISTANCE + 18){
                                g_temp = (bullet_correct_gain * HIP_AUTOCORRECT_PULL_GAIN) / 100;
                                if(g_temp < 12) g_temp = 12;
                                if(oneshot_mode){
                                    g_temp = (g_temp * HIP_ONESHOT_SUPER_GAIN) / 100;
                                } else {
                                    g_temp = g_temp + (magnet_capture_strength * HIP_AUTOCORRECT_PULL_GAIN) / 200;
                                    g_temp = g_temp + (ai_confidence_pct * HIP_AUTOCORRECT_PULL_GAIN) / 200;
                                }
                                if(g_temp > 150) g_temp = 150;
                                g_chars = HIP_AUTOCORRECT_FORCE_BLEND + g_temp + (g_val * 8);
                                g_chars = g_chars + (magnet_capture_strength * HIP_AUTOCORRECT_FORCE_BLEND) / 150;
                                if(g_chars > 220) g_chars = 220;
                                g_total = (bullet_correct_blend_x * g_chars) / 100;
                                g_expected = (bullet_correct_blend_y * g_chars) / 100;
                                final_rx = final_rx + g_total;
                                final_ry = final_ry + g_expected;
                                g_fill = HIP_AUTOCORRECT_RESIST_GAIN + (g_val * 4);
                                if(magnet_capture_active) g_fill = g_fill + (magnet_capture_strength / 8);
                                aim_state_resistance_pct = clamp_i(aim_state_resistance_pct + g_fill, 40, 240);
                            }
                        }
                    }
                if(align_suppress_freeze){
                    g_val = 18 + (torque_freeze_blend / 2);
                    if(hipfire_engaged){
                        g_val = g_val + (hipfire_engage_strength / 4);
                    }
                    if(hipfire_glue_weight > 0){
                        g_val = g_val + (hipfire_glue_weight / 5);
                    }
                    if(g_val > 72) g_val = 72;
                    if(g_val < 18) g_val = 18;
                    g_temp = 100 - g_val;
                    if(g_temp < 10) g_temp = 10;
                    g_chars = (torque_persist_x * g_temp) / 100;
                    g_total = (torque_persist_y * g_temp) / 100;
                    if(hipfire_engaged || hipfire_glue_weight > 0){
                        g_expected = (final_rx * g_val) / 100;
                        final_rx = smooth_gain(final_rx, g_expected + g_chars, 72);
                        g_expected = (final_ry * g_val) / 100;
                        final_ry = smooth_gain(final_ry, g_expected + g_total, 72);
                    } else {
                        final_rx = smooth_gain(final_rx, g_chars, 96);
                        final_ry = smooth_gain(final_ry, g_total, 96);
                    }
                }
        
                    if(hip_fast_track_active){
                        g_val = bubble_center_pull_x + hip_glide_rx + hip_auto_steer_x;
                        g_temp = bubble_center_pull_y + hip_glide_ry + hip_auto_steer_y;
                        if(bullet_correct_gain > 0){
                            g_val = g_val + (bullet_correct_blend_x / 2);
                            g_temp = g_temp + (bullet_correct_blend_y / 2);
                        }
                        final_rx = (final_rx * (100 - HIP_FAST_OUTPUT_BLEND) + g_val * HIP_FAST_OUTPUT_BLEND) / 100;
                        final_ry = (final_ry * (100 - HIP_FAST_OUTPUT_BLEND) + g_temp * HIP_FAST_OUTPUT_BLEND) / 100;
                    }
        
                    if(align_lock_active){
                        g_val = 100 - align_lock_strength;
                        if(g_val < 4) g_val = 4;
                        final_rx = (final_rx * g_val) / 100;
                        final_ry = (final_ry * g_val) / 100;
                    }
        
                    if(ballistic_active > 0){
                        g_val = (ballistic_travel_offset_x * BALLISTIC_OUTPUT_BLEND) / 100;
                        g_val = g_val / BALLISTIC_STICK_DIVISOR;
                        final_rx = final_rx + (g_val * ballistic_active) / 100;
        
                        g_temp = (ballistic_drop_offset * BALLISTIC_OUTPUT_BLEND) / 100;
                        g_temp = g_temp / BALLISTIC_STICK_DIVISOR;
                        final_ry = final_ry - (g_temp * ballistic_active) / 100;
                    }
        
                    if(AUTO_AIM_OVERRUN_ENABLE){
                        if(magnet_lock_gate || ai_confidence_pct >= AUTO_AIM_LOCK_THRESHOLD || bullet_correct_gain > 0){
                            auto_aim_overrun_active = 1;
                            auto_aim_timer = AUTO_AIM_FALLOFF_MS;
                        } else if(auto_aim_timer > 0){
                            auto_aim_timer = auto_aim_timer - delta;
                            if(auto_aim_timer <= 0){
                                auto_aim_timer = 0;
                                auto_aim_overrun_active = 0;
                            }
                        }
                        if(auto_aim_overrun_active){
                            target_locked = 1;
                            if(lock_confidence < AUTO_AIM_LOCK_THRESHOLD + 36){
                                lock_confidence = AUTO_AIM_LOCK_THRESHOLD + 36;
                            }
                            if(!magnet_capture_active){
                                magnet_capture_hold_timer = AUTO_AIM_FALLOFF_MS;
                                magnet_capture_strength = smooth_gain(magnet_capture_strength, 100, MAGNET_CAPTURE_RAMP_GAIN);
                            } else if(magnet_capture_hold_timer < AUTO_AIM_FALLOFF_MS){
                                magnet_capture_hold_timer = AUTO_AIM_FALLOFF_MS;
                            }
                            g_val = lock_confidence + ai_confidence_pct + magnet_capture_strength;
                            if(g_val < AUTO_AIM_LOCK_THRESHOLD) g_val = AUTO_AIM_LOCK_THRESHOLD;
                            if(hipfire_engaged) g_val = g_val + hipfire_engage_strength;
                            if(bullet_correct_gain > 0) g_val = g_val + bullet_correct_gain;
                            if(g_val > 260) g_val = 260;
                            g_temp = (g_val * AUTO_AIM_FORCE_GAIN) / 100;
                            if(g_temp > 100) g_temp = 100;
                            if(g_temp < 85) g_temp = 85;
        
                            g_chars = predict_offset_x - pixel_offset_x;
                            g_total = bubble_center_pull_x + ai_output_rx + (bullet_correct_blend_x / 2) + hip_auto_steer_x + hip_glide_rx;
                            if(ballistic_active > 0) g_total = g_total + (ballistic_travel_offset_x / 2);
                            if(overdrive_bias_rx != 0) g_total = g_total + overdrive_bias_rx;
                            g_chars = g_chars + g_total;
                            g_chars = clamp_i(g_chars, 0 - AUTO_AIM_MAX_OUTPUT, AUTO_AIM_MAX_OUTPUT);
                            final_rx = (final_rx * (100 - g_temp) + g_chars * g_temp) / 100;
        
                            g_expected = predict_offset_y - pixel_offset_y - ballistic_drop_offset;
                            g_fill = bubble_center_pull_y + ai_output_ry + (bullet_correct_blend_y / 2) + hip_auto_steer_y + hip_glide_ry;
                            if(overdrive_bias_ry != 0) g_fill = g_fill + overdrive_bias_ry;
                            g_expected = g_expected + g_fill;
                            g_expected = clamp_i(g_expected, 0 - AUTO_AIM_MAX_OUTPUT, AUTO_AIM_MAX_OUTPUT);
                            final_ry = (final_ry * (100 - g_temp) + g_expected * g_temp) / 100;
        
                            if(slowdown_factor > AUTO_AIM_SLOWDOWN_CAP) slowdown_factor = AUTO_AIM_SLOWDOWN_CAP;
                            if(ads){
                                if(slowdown_factor > 1) slowdown_factor = 1;
                            } else if(slowdown_factor > 2){
                                slowdown_factor = 2;
                            }
                            assist_core_blend = clamp_i(assist_core_blend + 20, 0, 100);
                            assist_rotation_blend = clamp_i(assist_rotation_blend + 20, 0, 100);
                            assist_snap_blend = clamp_i(assist_snap_blend + 28, 0, 100);
                        }
                    }
        
                    g_total = abs(final_rx) + abs(final_ry);
                    if(g_total > 100){
                        final_rx = (final_rx * 100) / g_total;
                        final_ry = (final_ry * 100) / g_total;
                    }
        
                    if(cone_engage_weight > 0 && !ads){
                        g_val = lerp_pct(100, UE_CONE_STICK_CLAMP, cone_engage_weight);
                        if(g_val < UE_CONE_STICK_CLAMP) g_val = UE_CONE_STICK_CLAMP;
                        if(final_rx > g_val) final_rx = g_val;
                        if(final_rx < 0 - g_val) final_rx = 0 - g_val;
                        if(final_ry > g_val) final_ry = g_val;
                        if(final_ry < 0 - g_val) final_ry = 0 - g_val;
                    }
        
                    if(jerk_damper_active){
                        if(final_rx > UE_JERK_STICK_CLAMP) final_rx = UE_JERK_STICK_CLAMP;
                        if(final_rx < 0 - UE_JERK_STICK_CLAMP) final_rx = 0 - UE_JERK_STICK_CLAMP;
                        if(final_ry > UE_JERK_STICK_CLAMP) final_ry = UE_JERK_STICK_CLAMP;
                        if(final_ry < 0 - UE_JERK_STICK_CLAMP) final_ry = 0 - UE_JERK_STICK_CLAMP;
                    }
        
                    if(overdrive_rotation_cap > 0){
                        g_val = overdrive_rotation_cap;
                        if(final_rx > g_val) final_rx = g_val;
                        if(final_rx < 0 - g_val) final_rx = 0 - g_val;
                        if(final_ry > g_val) final_ry = g_val;
                        if(final_ry < 0 - g_val) final_ry = 0 - g_val;
                    }
        
                    if(final_rx > 100) final_rx = 100;
                    if(final_rx < -100) final_rx = -100;
                    if(final_ry > 100) final_ry = 100;
                    if(final_ry < -100) final_ry = -100;
        
                    hip_override_strength = 0;
                    if(!ads && magnet_lock_gate){
                        hip_override_metric = (rx * (predict_offset_x - pixel_offset_x)) + (ry * (predict_offset_y - pixel_offset_y));
                        if(hip_override_metric < -HIP_LOCK_OVERRIDE_THRESHOLD){
                            hip_override_strength = clamp_i((-hip_override_metric) / 8, 0, 100);
                        }
                        if(hip_override_strength > HIP_LOCK_OVERRIDE_MAX) hip_override_strength = HIP_LOCK_OVERRIDE_MAX;
                        if(hip_override_strength > 0){
                            final_rx = lerp_pct(final_rx, 0, hip_override_strength);
                            final_ry = lerp_pct(final_ry, 0, hip_override_strength);
                        }
                    }
        
                    if(ads && magnet_lock_gate){
                        if(ads_lock_steady_active){
                            ads_lock_integrator_rx = smooth_gain(ads_lock_integrator_rx, final_rx, UE_ADS_LOCK_STEADY_BLEND);
                            ads_lock_integrator_ry = smooth_gain(ads_lock_integrator_ry, final_ry, UE_ADS_LOCK_STEADY_BLEND);
                            final_rx_prev = smooth_gain(final_rx_prev, ads_lock_integrator_rx, UE_ADS_LOCK_STIFFNESS);
                            final_ry_prev = smooth_gain(final_ry_prev, ads_lock_integrator_ry, UE_ADS_LOCK_STIFFNESS);
                        } else {
                            ads_lock_integrator_rx = final_rx;
                            ads_lock_integrator_ry = final_ry;
                            final_rx_prev = smooth_gain(final_rx_prev, final_rx, UE_ADS_LOCK_STIFFNESS);
                            final_ry_prev = smooth_gain(final_ry_prev, final_ry, UE_ADS_LOCK_STIFFNESS);
                        }
                        final_rx = final_rx_prev;
                        final_ry = final_ry_prev;
                    } else if(ads){
                        ads_lock_integrator_rx = smooth_gain(ads_lock_integrator_rx, 0, ADS_DRIFT_CANCEL_BLEND);
                        ads_lock_integrator_ry = smooth_gain(ads_lock_integrator_ry, 0, ADS_DRIFT_CANCEL_BLEND);
                        final_rx_prev = smooth_gain(final_rx_prev, 0, ADS_DRIFT_CANCEL_BLEND);
                        final_ry_prev = smooth_gain(final_ry_prev, 0, ADS_DRIFT_CANCEL_BLEND);
                        final_rx = smooth_gain(final_rx, 0, ADS_DRIFT_CANCEL_BLEND);
                        final_ry = smooth_gain(final_ry, 0, ADS_DRIFT_CANCEL_BLEND);
                    } else if(!ads && magnet_lock_gate){
                        ads_lock_integrator_rx = final_rx;
                        ads_lock_integrator_ry = final_ry;
                        final_rx_prev = smooth_gain(final_rx_prev, final_rx, HIP_STICKY_STABILIZE_GAIN);
                        final_ry_prev = smooth_gain(final_ry_prev, final_ry, HIP_STICKY_STABILIZE_GAIN);
                        final_rx = final_rx_prev;
                        final_ry = final_ry_prev;
                    } else {
                        ads_lock_integrator_rx = final_rx;
                        ads_lock_integrator_ry = final_ry;
                        final_rx_prev = final_rx;
                        final_ry_prev = final_ry;
                    }
        
                    slowdown_event_process_signal();
        
                    if(!menu_mode){
                        set_led(LED_1, slowdown_led_state);
                    }
        
                    // ========= LEFT STICK OUTPUT (ROTATION PULSE INJECTION!) =========
                    if(search_release_pct > 0){
                        g_val = lerp_pct(100, UE_SEARCH_RELEASE_OUTPUT, search_release_pct);
                        rotation_pulse_lx = (rotation_pulse_lx * g_val) / 100;
                        rotation_pulse_ly = (rotation_pulse_ly * g_val) / 100;
                    }
                    if(search_output_pct < 100){
                        rotation_pulse_lx = (rotation_pulse_lx * search_output_pct) / 100;
                        rotation_pulse_ly = (rotation_pulse_ly * search_output_pct) / 100;
                    }
                    // Inject rotation trigger pulse into left stick
                    final_lx = lx + rotation_pulse_lx;
                    final_ly = ly + rotation_pulse_ly;
                    
                    // Deadzone bypass: Ensure output > deadzone often
                    if(abs(final_lx) < 10 && abs(final_ly) < 10 && aim_on && !build_mode && !edit_mode){
                        // If result is too small (stuck in deadzone), boost it slightly to trigger AA
                        if(rotation_pulse_lx > 0) final_lx = 12; else final_lx = -12;
                        if(rotation_pulse_ly > 0) final_ly = 12; else final_ly = -12;
                    }
        
                    // Clamp left stick
                    if(final_lx > 100) final_lx = 100;
                    if(final_lx < -100) final_lx = -100;
                    if(final_ly > 100) final_ly = 100;
                    if(final_ly < -100) final_ly = -100;
        
                    // Output both sticks
                    set_val(AXIS_RX, final_rx);
                    set_val(AXIS_RY, final_ry);
                    set_val(LX, final_lx);
                    set_val(LY, final_ly);
                }
        
                function update_hip_prelock_fast(){
                    if(ads || !aim_on || build_mode || edit_mode){
                        hip_prelock_fast_active = 0;
                        hip_prelock_fast_timer = 0;
                        return;
                    }
        
                    if(magnet_lock_gate){
                        hip_prelock_fast_active = 0;
                        hip_prelock_fast_timer = 0;
                        return;
                    }
        
                    g_val = 0;
                    if(native_capture_gate || native_signal_stack > 0){
                        g_val = 1;
                    }
                    if(!g_val){
                        hip_prelock_fast_active = 0;
                        hip_prelock_fast_timer = 0;
                        return;
                    }
        
                    g_temp = distance_pixels;
                    if(g_temp <= HIP_PRELOCK_DISTANCE){
                        if(input_velocity >= HIP_PRELOCK_FAST_INPUT_GATE){
                            hip_prelock_fast_active = 1;
                            hip_prelock_fast_timer = HIP_PRELOCK_FAST_TIMER_MS;
                        }
                    }
        
                    if(hip_prelock_fast_active){
                        if(g_temp > HIP_PRELOCK_DISTANCE + HIP_PRELOCK_GRACE_PX || input_velocity >= INPUT_VELOCITY_PANIC){
                            hip_prelock_fast_active = 0;
                            hip_prelock_fast_timer = 0;
                            return;
                        }
                        if(hip_prelock_fast_timer > 0){
                            hip_prelock_fast_timer = hip_prelock_fast_timer - delta;
                            if(hip_prelock_fast_timer < 0) hip_prelock_fast_timer = 0;
                        }
                        if(hip_prelock_fast_timer == 0){
                            hip_prelock_fast_active = 0;
                        }
                    }
                }
        
                // ============== ROTATION PULSE CORE (PRIMARY MAGNETIC!) ==============
                function calculate_pulse_magnitude(){
                    // LOGIC OVERHAUL: UNREAL ENGINE STICKY AIM (ALWAYS ON / BYPASS LOCK)
                    // Forces Rotational Aim Assist to be active whenever ADS/Firing
                    // Tuned for MAXIMUM ADHESION without SCREEN SHAKE (ADS Spam fix)
                    
                    pulse_magnitude = 0;
                    rotation_mag_offset = 0;
        
                    if(align_suppress_freeze){
                        return;
                    }
                    
                    if(!aim_on) {
                        return;
                    }
        
                    // FIX: Use global variables for GPC compatibility
                    if(ads) g_val = slider_ads_strength;
                    else    g_val = slider_hip_strength;
        
                    if(g_val == 0) return;
        
                    // Base Magnitude Calculation (Optimized for UE5)
                    // Minimum 21 is required to reliably trigger UE5 Aim Assist (Deadzone bypass)
                    g_temp = 21;
                    
                    // Scale with slider (50 = 100%, 100 = 150%)
                    g_temp = (g_temp * (50 + g_val)) / 100;
                    
                    // Engagement Boost (Firing / Magnet / Sticky)
                    // Boost magnitude slightly when engaging to ensure rotational AA kicks in
                    if(shooting || hipfire_engaged || magnet_capture_active || hipfire_sticky_active || target_locked){
                        g_temp = g_temp + 6;
                    }
                    
                    // Apply Minimal Jitter (Anti-Detection only, reduced to prevent screen shake)
                    g_chars = waveform_rand_signed(1); 
                    pulse_magnitude = g_temp + g_chars;
                    
                    // Ensure bounds - STRICT CLAMPING for perfect stability
                    if(pulse_magnitude < 20) pulse_magnitude = 20; // Never drop below deadzone
                    if(pulse_magnitude > 30) pulse_magnitude = 30; // Never exceed walking threshold
                }
        
                function toggle_aim_off() {
                    aim_on = 0;
                    combo_stop(UltimateMaster);
                    assist_pipeline_reset();
                    set_led(LED_4,0);  // v4.2: LED UIT = script UIT
                    forced_fire_reset();
                }
        
                // ======================= COMBO =======================
                // Polling at 2ms (500Hz) for minimum latency, as per vPro plan.
                combo UltimateMaster {
                    ultimate_master();
                    wait(2);
                }
        
