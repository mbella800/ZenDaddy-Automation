    weapon_recoil_yaw_gain[WEAPON_PROFILE_AR] = 36;
    weapon_recoil_yaw_gain[WEAPON_PROFILE_ONESHOT] = 28;
    weapon_recoil_yaw_gain[WEAPON_PROFILE_SNIPER] = 12;

    weapon_profile_current = WEAPON_PROFILE_AR;
