    enemy_velocity_y = 0;
    enemy_velocity_prev_x = 0;
    enemy_velocity_prev_y = 0;
    enemy_velocity_avg_x = 0;
    enemy_velocity_avg_y = 0;
    enemy_velocity_avg_prev_x = 0;
    enemy_velocity_avg_prev_y = 0;
    enemy_velocity_blend_x = 0;
    enemy_velocity_blend_y = 0;
    enemy_accel_x = 0;
    enemy_accel_y = 0;
    enemy_accel_avg_x = 0;
    enemy_accel_avg_y = 0;
