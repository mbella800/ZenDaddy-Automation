// ============== AIM ASSIST CORE =====================
void ultimate_master(){
    hipfire_resistance_bonus = 0;
    micro_x = 0; // Reset micro variables
    micro_y = 0;
    // 🔴 HARD STOP: DISABLE IN BUILD/EDIT MODE
    if(build_mode || edit_mode){
        combo_stop(UltimateMaster);  // Stop combo explicitly!
        return;  // Exit immediately - zero processing!
    }

    // ===== v2.0 IDLE & MOVEMENT TRACKING =====
    // --- PHASE F: IDLE & MOVEMENT TRACKING (ANTI-DETECTION JITTER) ---
    // Recalculates intervals based on smoothness and regenerates timers.
    g_val = clamp_i(100 - slider_smoothness, 0, 100); // Inverse smoothness for stealth factor

    // Update idle pull interval
    if(idle_timer >= idle_pull_interval){
        g_temp = (STEALTH_IDLE_JITTER * g_val) / 100;
        idle_pull_interval = IDLE_AUTO_PULL_TIME + waveform_rand_signed(g_temp);
        if(idle_pull_interval < 60) idle_pull_interval = 60;
    }

    // Track camera input voor idle auto-pull
    if(abs(rx) > 5 || abs(ry) > 5){
        idle_timer = 0;  // Reset bij camera movement
    } else {
        if(idle_timer < idle_pull_interval) idle_timer = idle_timer + delta;
    }

    // Update movement gate interval
    if(movement_timer >= movement_gate_interval){
        g_temp = (STEALTH_MOVEMENT_JITTER * g_val) / 100;
        movement_gate_interval = MOVEMENT_GATE_TIME + waveform_rand_signed(g_temp);
        if(movement_gate_interval < 80) movement_gate_interval = 80;
    }

    // Track movement input (V-Sync)
    if(abs(lx) > 10 || abs(ly) > 10){
        if(movement_timer < movement_gate_interval) movement_timer = movement_timer + delta;
    } else {
        movement_timer = 0;  // Reset zonder movement
    }
    // -----------------------------------------------------------------

    // ===== NIEUWE SCREEN-SPACE SYSTEMS! =====
    update_screen_space();
    update_weighted_zones();
    update_assist_amplification();  // ASSIST AMPLIFICATION - work WITH Fortnite's assist!
    update_rotation_gate();
    update_predictive_aim_legacy();

    // Oude systems
    update_bubble_state();
    get_current_range();
    update_target_lock();
    update_strafe_detection();
    update_input_velocity();
    freedom_release_blend = smooth_gain(freedom_release_blend, freedom_release_target, 12);
    update_assist_core();
    detect_assist_state();
    update_weapon_profile();
    apply_weapon_profile_scaling();
    apply_recoil_modulation(); // Apply recoil modulation after scaling
    update_sticky_edge_weight();
    // Using g_chars for distance_delta_abs to remove local variable declaration
    g_chars = distance_delta;
    if(g_chars < 0) g_chars = 0 - g_chars;
    if(freedom_release_blend > 0 || !target_locked){
        resistance_glue_active = 0;
        resistance_glue_timer = 0;
        resistance_glue_gain = 0;
    } else if(resistance_glue_active){
        if(input_velocity > 18 || aim_error_variance > 18 || g_chars > 8 || lock_confidence < 60){
            resistance_glue_active = 0;
            resistance_glue_timer = 0;
            resistance_glue_gain = 0;
        } else {
            resistance_glue_timer = resistance_glue_timer + delta;
            if(resistance_glue_timer > 450) resistance_glue_timer = 450;
            resistance_glue_gain = (resistance_glue_timer * 28) / 450;
            if(resistance_glue_gain > 28) resistance_glue_gain = 28;
        }
    } else if(lock_confidence >= 72 && aim_error_avg <= 8 && g_chars <= 4 && input_velocity <= 12){
        resistance_glue_active = 1;
        resistance_glue_timer = 120;
        resistance_glue_gain = 12;
    }
    zone_blend_pct = soft_step(distance_pixels, bubble_zone_edges[0], bubble_zone_edges[4]);
    calculate_pulse_magnitude();  // SMOOTH MAGNITUDE - slider-based!
    update_rotation_pulse();      // ROTATION TRIGGER PULSE - magnetic aim!

        // ========= SLOWDOWN BLENDING =========
    slowdown_factor = 100;
    zone_index = bubble_zone - 1;
    if(zone_index < 0) zone_index = 0;
    if(zone_index > 4) zone_index = 4;

    base_slowdown = slowdown_zone_map[zone_index];
    base_slowdown = (base_slowdown * weapon_gain_slowdown_mix) / 100;
    base_slowdown = clamp_i(base_slowdown, 10, 100);


    if(lock_confidence > 0){
        assist_slowdown_blend = smooth_gain(assist_slowdown_blend, assist_core_blend, 16);
        if(input_velocity >= INPUT_VELOCITY_PANIC){
            assist_slowdown_blend = assist_slowdown_blend / 3;
        }
        if(hyper_burst_active){
            slowdown_factor = HYPER_BURST_SLOWDOWN;
        } else {
            slowdown_factor = lerp_pct(100, base_slowdown, assist_slowdown_blend);
            slowdown_factor = lerp_pct(slowdown_factor, base_slowdown / 2, zone_blend_pct);
            if(ads && bubble_zone > 0){
                slowdown_factor = (slowdown_factor * ADS_SLOWDOWN_FACTOR) / 100;
                slowdown_factor = (slowdown_factor * weapon_gain_ads_slowdown_mix) / 100;
            }
            if(current_range == 0) g_val = slider_close;
            else if(current_range == 1) g_val = slider_medium;
            else g_val = slider_far;
            slowdown_factor = apply_drift_free_scaling(slowdown_factor, g_val);
            if(ads) {
                slowdown_factor = apply_drift_free_scaling(slowdown_factor, slider_ads_strength);
            } else {
                slowdown_factor = apply_drift_free_scaling(slowdown_factor, slider_hip_strength);
            }
        }
    }
    else {
        slowdown_factor = lerp_pct(100, base_slowdown, assist_last_proximity_score / 2);
    }

    if(sticky_edge_weight > 0){
        g_expected = sticky_edge_boost; // slowdown_edge_gain
        g_val = sticky_edge_boost / 2;  // rotation_edge_gain
        g_temp = sticky_edge_snap_boost; // snap_edge_gain

        if(!sticky_edge_active){
            g_expected = (sticky_edge_weight * STICKY_EDGE_GAIN) / 100;
            g_val = g_expected / 2;
            g_temp = (sticky_edge_weight * STICKY_EDGE_SNAP_GAIN) / 100;
        }

        g_fill = clamp_i(100 + g_expected, 90, 150);
        slowdown_factor = (slowdown_factor * g_fill) / 100;

        assist_rotation_blend = clamp_i(assist_rotation_blend + g_val, 0, 100);
        assist_snap_blend = clamp_i(assist_snap_blend + g_temp, 0, 100);
    } else {
        if(sticky_edge_timer > 0){
            sticky_edge_timer = sticky_edge_timer - (delta * 2);
            if(sticky_edge_timer < 0) sticky_edge_timer = 0;
        }
    }

    if(hipfire_sticky_active && !ads && oneshot_mode){
        hipfire_sticky_weight = HIP_STICKY_INTENSITY_BASE;
        hipfire_sticky_weight = clamp_i(hipfire_sticky_weight + (lock_confidence / 2), 0, 100);
        hipfire_sticky_weight = apply_drift_free_scaling(hipfire_sticky_weight, slider_hip_strength);
        if(hipfire_sticky_weight > 100) hipfire_sticky_weight = 100;

        if(subsystem_flags & SUBSYSTEM_SLOWDOWN){
            slowdown_factor = lerp_pct(slowdown_factor, HIP_STICKY_SLOWDOWN_TARGET, hipfire_sticky_weight);
        }
        if(subsystem_flags & SUBSYSTEM_ROTATION){
            assist_rotation_blend = clamp_i(assist_rotation_blend + ((HIP_STICKY_ROTATION_BONUS * hipfire_sticky_weight) / 100), 0, 100);
        }
        if(subsystem_flags & SUBSYSTEM_SNAP){
            assist_snap_blend = clamp_i(assist_snap_blend + ((HIP_STICKY_SNAP_BONUS * hipfire_sticky_weight) / 100), 0, 100);
        }
        if(subsystem_flags & SUBSYSTEM_RESISTANCE){
            hipfire_resistance_bonus = (HIP_STICKY_RESIST_GAIN * hipfire_sticky_weight) / 100;
            if(hipfire_resistance_bonus > 60) hipfire_resistance_bonus = 60;
        }
    }

    if(!(subsystem_flags & SUBSYSTEM_SLOWDOWN)){
        slowdown_factor = 100;
    }

    if(freedom_release_blend > 0){
        g_val = (FREEDOM_RELEASE_SLOWDOWN * freedom_release_blend) / 100; // release_slow_pct
        g_temp = (FREEDOM_RELEASE_ROTATION * freedom_release_blend) / 100; // release_rot_pct
        g_p = (FREEDOM_RELEASE_SNAP * freedom_release_blend) / 100; // release_snap_pct
        if(g_val > 100) g_val = 100;
        if(g_temp > 100) g_temp = 100;
        if(g_p > 100) g_p = 100;
        slowdown_factor = lerp_pct(slowdown_factor, 100, g_val);
        assist_slowdown_blend = (assist_slowdown_blend * (100 - g_val)) / 100;
        assist_rotation_blend = (assist_rotation_blend * (100 - g_temp)) / 100;
        assist_snap_blend = (assist_snap_blend * (100 - g_p)) / 100;
        if(assist_slowdown_blend < 0) assist_slowdown_blend = 0;
        if(assist_rotation_blend < 0) assist_rotation_blend = 0;
        if(assist_snap_blend < 0) assist_snap_blend = 0;
    }

    g_temp = clamp_i(enemy_speed_mag, 0, 160);
    g_expected = SPEED_DYNAMIC_MAX - ((SPEED_DYNAMIC_MAX - SPEED_DYNAMIC_MIN) * g_temp) / 160;
    if(g_expected < SPEED_DYNAMIC_MIN) g_expected = SPEED_DYNAMIC_MIN;
    if(g_expected > SPEED_DYNAMIC_MAX) g_expected = SPEED_DYNAMIC_MAX;
    slowdown_factor = (slowdown_factor * g_expected) / 100;

    stabilized_rx = (rx * slowdown_factor) / 100;
    stabilized_ry = (ry * slowdown_factor) / 100;

    // DAMPING CURVE - voorkom zero-crossing wobble
    if(target_locked && input_mag <= LOCK_THRESHOLD){
        // Als we dicht bij center zijn, extra damping
        if(abs(stabilized_rx) <= DAMPING_THRESHOLD){
            stabilized_rx = (stabilized_rx * DAMPING_FACTOR) / 100;  // 45% damping
        }
        if(abs(stabilized_ry) <= DAMPING_THRESHOLD){
            stabilized_ry = (stabilized_ry * DAMPING_FACTOR) / 100;  // 45% damping
        }
    }

    // ========= ROTATION PULL (VEEL ZWAKKER!) =========
    rotation_x = 0;
    rotation_y = 0;

    // Rotation ALLEEN bij CONFIRMED tracking (zeer strikt!)

    if((subsystem_flags & SUBSYSTEM_ROTATION) && assist_rotation_blend > 0 && bubble_zone_stable > 0){
        g_temp = rotation_pull_hip_map[clamp_i(bubble_zone - 1, 0, 3)];
        if(ads) g_temp = rotation_pull_ads_map[clamp_i(bubble_zone - 1, 0, 3)];

        rotation_factor = (g_temp * (50 + assist_rotation_blend)) / 100;
        rotation_factor = (rotation_factor * weapon_gain_rotation_mix) / 100;
        if(ads){
            rotation_factor = (rotation_factor * weapon_gain_ads_rotation_mix) / 100;
        }
        rotation_factor = clamp_i(rotation_factor, 4, 40);
        rotation_factor = (rotation_factor * 5) / 2;

        g_temp = (0 - stabilized_rx) * assist_rotation_blend;
        rotation_x = g_temp / (rotation_factor * 20);
        g_temp = (0 - stabilized_ry) * assist_rotation_blend;
        rotation_y = g_temp / (rotation_factor * 20);

        rotation_x = clamp_i(rotation_x, -12, 12);
        rotation_y = clamp_i(rotation_y, -10, 10);

        if(idle_timer >= IDLE_AUTO_PULL_TIME && movement_timer >= MOVEMENT_GATE_TIME &&
           (r2_assist_timer >= 150 || r2_assist_fade_timer > 0) && !hyper_burst_active && !flick_detected){
            g_temp = (AUTO_PULL_STRENGTH * assist_core_blend * weapon_gain_autopull_mix) / 10000;
            g_temp = (g_temp * aim_state_auto_pull_pct) / 100;
            g_temp = clamp_i(g_temp, 0, 150);
            auto_pull_x = ((0 - stabilized_rx) * g_temp) / 100;
            auto_pull_y = ((0 - stabilized_ry) * g_temp) / 100;
            rotation_x = rotation_x + auto_pull_x;
            rotation_y = rotation_y + auto_pull_y;
        }

        if(sticky_edge_weight > 0){
            rotation_x = (rotation_x * (100 + STICKY_EDGE_GAIN)) / 100;
            rotation_y = (rotation_y * (100 + STICKY_EDGE_GAIN)) / 100;
        }
        if(freedom_release_active){
            rotation_x = (rotation_x * (100 - FREEDOM_RELEASE_ROTATION)) / 100;
            rotation_y = (rotation_y * (100 - FREEDOM_RELEASE_ROTATION)) / 100;
        }
        rotation_x = clamp_i(rotation_x, -15, 15);
        rotation_y = clamp_i(rotation_y, -12, 12);

        stabilized_rx = stabilized_rx + rotation_x;
        stabilized_ry = stabilized_ry + rotation_y;
    }
    else {
        snap_ramp_timer = 0;
    }

    // ========= v2.0 PROGRESSIVE SNAP (150ms delay!) =========
    snap_x = 0;
    snap_y = 0;

    // DELAY-AWARE: snap alleen actief NA 150ms delay (sync met Fortnite delayed tracking)
    if((subsystem_flags & SUBSYSTEM_SNAP) && target_locked && lock_strength >= SNAP_MIN_LOCK && bubble_zone_stable > 0 && bubble_zone_stable <= 3 && r2_assist_timer >= 150){
        // HYPER-BURST snap!
        if(hyper_burst_active){
            snap_factor = HYPER_BURST_SNAP;  // 60px mega snap!
            snap_ramp_timer = SNAP_RAMP_TIME;  // Instant max
        }
        // ONE-SHOT krijgt INSTANT ramp!
        else if(oneshot_mode) {
            if(bubble_zone_stable == 1) snap_factor = SNAP_STRENGTH_ULTRA;
            else if(bubble_zone_stable == 2) snap_factor = SNAP_STRENGTH_CLOSE;
            else snap_factor = SNAP_STRENGTH_MEDIUM;
            snap_ramp_timer = SNAP_RAMP_TIME;  // Instant max
        }
        else {
            // Basis strength op zone
            if(bubble_zone == 1) snap_factor = SNAP_STRENGTH_ULTRA;
            else if(bubble_zone == 2) snap_factor = SNAP_STRENGTH_CLOSE;
            else snap_factor = SNAP_STRENGTH_MEDIUM;

            // Progressive ramp-up (120ms smooth)
            if(snap_ramp_timer < SNAP_RAMP_TIME){
                snap_ramp_timer = snap_ramp_timer + delta;
                // Quadratic ease-in voor natuurlijk gevoel
                ramp_pct = (snap_ramp_timer * 100) / SNAP_RAMP_TIME;
                ramp_pct = (ramp_pct * ramp_pct) / 100;  // Square voor ease
                snap_factor = (snap_factor * ramp_pct) / 100;
            }

            snap_factor = (snap_factor * (50 + range_slider)) / 100;
        }
        snap_factor = (snap_factor * weapon_gain_snap_mix) / 100;
        if(snap_factor > 220) snap_factor = 220;
        if(snap_factor < 10) snap_factor = 10;

        g_val = bubble_outer_radius - bubble_inner_radius;
        if(g_val < 1) g_val = 1;
        g_temp = distance_pixels - bubble_inner_radius;
        if(g_temp < 0) g_temp = 0;
        if(g_temp > g_val) g_temp = g_val;
        g_expected = (g_temp * 100) / g_val;
        snap_stage = 0;
        if(g_expected >= SNAP_STAGE_TWO) snap_stage = 2;
        else if(g_expected >= SNAP_STAGE_ONE) snap_stage = 1;

        if(snap_stage == 1){
            snap_factor = (snap_factor * 120) / 100;
        }
        else if(snap_stage == 2){
            snap_factor = (snap_factor * 150) / 100;
        }

        if(sticky_edge_weight > 0){
            snap_factor = (snap_factor * (100 + STICKY_EDGE_SNAP_GAIN)) / 100;
        }
        if(freedom_release_active){
            snap_factor = (snap_factor * (100 - FREEDOM_RELEASE_SNAP)) / 100;
        }

        snap_x = ((0 - stabilized_rx) * lock_strength) / 100;
        snap_y = ((0 - stabilized_ry) * lock_strength) / 100;

        if(sticky_edge_weight > 0){
            snap_x = (snap_x * (100 + STICKY_EDGE_SNAP_GAIN)) / 100;
            snap_y = (snap_y * (100 + STICKY_EDGE_SNAP_GAIN)) / 100;
        }
        if(freedom_release_active){
            snap_x = (snap_x * (100 - FREEDOM_RELEASE_SNAP)) / 100;
            snap_y = (snap_y * (100 - FREEDOM_RELEASE_SNAP)) / 100;
        }

        if(snap_x > snap_factor) snap_x = snap_factor;
        if(snap_x < 0 - snap_factor) snap_x = 0 - snap_factor;
        if(snap_y > snap_factor) snap_y = snap_factor;
        if(snap_y < 0 - snap_factor) snap_y = 0 - snap_factor;

        stabilized_rx = stabilized_rx + snap_x;
        stabilized_ry = stabilized_ry + snap_y;
    }

    // ========= MICRO SEARCH =========
    m_x = 0;
    m_y = 0;

    if(!target_locked && bubble_zone == 0 && input_mag < MICRO_ACTIVE_THRESH){
        g_temp = MICRO_RADIUS_SEARCH;

        // Deadzone slider is removed. This feature is not active.

        micro_angle = micro_angle + MICRO_SPEED_SEARCH;
        if(micro_angle >= 360) micro_angle = micro_angle - 360;

        // ✅ SMOOTH CIRCULAR MOTION - Lookup table instead of piecewise linear!
        // Convert angle (0-360) to index (0-15)
        g_val = (micro_angle * 16) / 360;
        if(g_val > 15) g_val = 15;  // Safety clamp

        // Use lookup tables for smooth sin/cos
        m_x = (g_temp * cosLUT[g_val]) / 100;
        m_y = (g_temp * sinLUT[g_val]) / 100;
    }

    // ========= AERIAL/TRICKSHOT BOOST =========
    aerial_offset_y = 0;

    if(jumping || aerial_mode || trickshot_lock){
        aerial_timer = aerial_timer + 1;

        if(trickshot_lock || (jumping && input_mag <= 50)){
            if(!target_locked && input_mag <= 50){
                target_locked = 1;
                lock_timer = 10;
            }

            if(target_locked){
                snap_x = snap_x * 2;
                snap_y = snap_y * 2;
            }

            rotation_x = rotation_x * 2;
            rotation_y = rotation_y * 2;

            fall_velocity = (aerial_timer * 15) / 10;

            if(shooting){
                aerial_offset_y = (fall_velocity * 20) / 100;
            }
            else {
                aerial_offset_y = (fall_velocity * 30) / 100;
            }

            // Trickshot slider is removed, logic is now baseline.
        }
    }
    else {
        aerial_timer = 0;
        fall_velocity = 0;
    }

    stabilized_ry = stabilized_ry + aerial_offset_y;

    // ========= PREDICTIVE LAZY AIM BIAS =========
    // Add predictive bias voor off-target hits!
    stabilized_rx = stabilized_rx + lazy_bias_x;
    stabilized_ry = stabilized_ry + lazy_bias_y;

    // ========= STICK RESISTANCE CORE (V4.5 TRUE MAGNETIC ADHESION!) =========
    // v4.5: ULTRA STICKY - crosshair BLIJFT op enemy zelfs tijdens movement!
    // Resistance actief tijdens ALLE tracking movements (niet alleen slow input)
    // Dit is de FIX: assist blijft actief zelfs als je stick beweegt!

    if((subsystem_flags & SUBSYSTEM_RESISTANCE) && target_locked && !build_mode &&
       (resistance_active || distance_pixels < 20) &&
       input_velocity < 45){  // v4.5: VEEL HOGER voor true sticky tijdens tracking! (was 25)
        // CRITICAL: Use REAL pixel distance, not processed stick output!
        // Using stabilized_rx/ry was causing resistance outside bubble!

        // TIGHT BUBBLE ONLY: distance_pixels < STICK_RESISTANCE_THRESHOLD (15px)
        if(distance_pixels < STICK_RESISTANCE_THRESHOLD){
            // Base strength from slider using NEW system (0=disabled, 50=100%, 100=200%)
            if(ads) {
                g_expected = apply_drift_free_scaling(STICK_RESISTANCE_MAX, slider_ads_strength);
            } else {
                g_expected = apply_drift_free_scaling(STICK_RESISTANCE_MAX, slider_hip_strength);
            }
            g_expected = (g_expected * weapon_gain_resist_mix) / 100;

            // SCALAR RESISTANCE: lock confidence, snap stage, and error stability
            resistance_lock_scalar = clamp_i((lock_confidence * 120) / 100, 30, 100);
            resistance_snap_scalar = clamp_i((snap_stage * 25), 50, 100);
            resistance_error_scalar = 100 - soft_step(aim_error_avg, 5, 25);
            resistance_error_scalar = clamp_i(resistance_error_scalar, 10, 100);

            resistance_combined_pct = (resistance_lock_scalar * 40 + resistance_snap_scalar * 30 + resistance_error_scalar * 30) / 100;
            resistance_combined_pct = clamp_i(resistance_combined_pct, 40, 120);

            g_expected = (g_expected * resistance_combined_pct) / 100;
            g_expected = g_expected + hipfire_resistance_bonus;
            if(resistance_glue_active){
                g_expected = g_expected + resistance_glue_gain;
            }
            g_expected = (g_expected * aim_state_resistance_pct) / 100;
            if(g_expected > 90) g_expected = 90;
            if(g_expected < 5) g_expected = 5;

            // GRADUAL FADE: closer to center = stronger damping
            // Distance 0 = 100% of strength, distance 15 = 0%
            g_temp = (STICK_RESISTANCE_THRESHOLD - distance_pixels) * 100 / STICK_RESISTANCE_THRESHOLD;
            g_expected = (g_expected * g_temp) / 100;

    // v4.5: ANTI-FEEDBACK LOOP - resistance blijft actief tijdens tracking!
    // Veel minder gevoelig voor velocity changes = true sticky adhesion!
    g_temp = INPUT_VELOCITY_DISABLE_HIP;
    if(ads) g_temp = INPUT_VELOCITY_DISABLE_ADS;

    // v4.5: Start fading VEEL HOGER voor maximum persistence tijdens tracking
    if(input_velocity > 25){  // v4.5: HOGER threshold! (was 15)
        g_val = ((g_temp - input_velocity) * 100) / (g_temp - 15);
        if(g_val < 0) g_val = 0;
        g_val = clamp_i(g_val, 0, 100);
        g_expected = (g_expected * g_val) / 100;
    }

    // Apply smooth fading due to freedom release
    if(freedom_release_blend > 0){
        g_expected = (g_expected * (100 - freedom_release_blend)) / 100;
    }

    // Apply smooth damping (complement rotation pulse)
    stabilized_rx = (stabilized_rx * (100 - g_expected)) / 100;
    stabilized_ry = (stabilized_ry * (100 - g_expected)) / 100;
        }
    }
    // Else: fast input detected - NO RESISTANCE (vrije correctie!)

    // ========= ADD DITHERING (PHASE F ANTI-DETECTION) =========
    g_val = clamp_i(100 - slider_smoothness, 0, 100); // Jitter strength inverse to smoothness
    g_temp = (g_val * 12) / 100; // Max dither +/- 12 units (if slider_smoothness = 0)
    g_p = waveform_rand_signed(g_temp);
    g_fill = waveform_rand_signed(g_temp);

/* COMBINE & OUTPUT - ATOMIC FIX v3 (ULTRA ISOLATION) */
    // Stage micro + dither additions into specialized temp globals
    g_val = micro_x + g_p; // g_val = micro_x + dither_x
    g_temp = micro_y + g_fill; // g_temp = micro_y + dither_y

    // Step 1: Initialize final output with stabilized input
    final_rx = stabilized_rx;
    final_ry = stabilized_ry;

    // Step 2: Apply horizontal additions
    final_rx = final_rx + g_val;

    // Step 3: Apply vertical additions
    final_ry = final_ry + g_temp;

    g_total = abs(final_rx) + abs(final_ry);
    if(g_total > 100){
        final_rx = (final_rx * 100) / g_total;
        final_ry = (final_ry * 100) / g_total;
    }

    if(final_rx > 100) final_rx = 100;
    if(final_rx < -100) final_rx = -100;
    if(final_ry > 100) final_ry = 100;
    if(final_ry < -100) final_ry = -100;

    // Diagnostics removed for Titan Two memory constraints

    // ========= LEFT STICK OUTPUT (ROTATION PULSE INJECTION!) =========
    // Inject rotation trigger pulse into left stick
    final_lx = lx + rotation_pulse_lx;
    final_ly = ly + rotation_pulse_ly;

    // Clamp left stick
    if(final_lx > 100) final_lx = 100;
    if(final_lx < -100) final_lx = -100;
    if(final_ly > 100) final_ly = 100;
    if(final_ly < -100) final_ly = -100;

    // Output both sticks
    set_val(AXIS_RX, final_rx);
    set_val(AXIS_RY, final_ry);
    set_val(LX, final_lx);
    set_val(LY, final_ly);
}

void toggle_aim_off() {
    aim_on = 0;
    combo_stop(UltimateMaster);
    assist_pipeline_reset();
}

// ======================= COMBO =======================
combo UltimateMaster {
    ultimate_master();
    wait(4);
}
