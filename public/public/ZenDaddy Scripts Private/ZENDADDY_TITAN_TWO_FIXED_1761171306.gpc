// =================== HELPER UTILITIES ===================
int clamp_i(int val, int min_val, int max_val){
    if(val < min_val) return min_val;
    if(val > max_val) return max_val;
    return val;
}

int saturate_pct(int val){
    return clamp_i(val, 0, 100);
}

int lerp_pct(int base, int target, int pct){
    return base + ((target - base) * pct) / 100;
}

int smooth_gain(int current, int target, int gain_pct){
    // gain_pct 0-100 (0 = no change, 100 = snap)
    gain_pct = saturate_pct(gain_pct);
    if(gain_pct == 0) return current;
    if(gain_pct >= 100) return target;
    return current + ((target - current) * gain_pct) / 100;
}

int soft_step(int value, int start_val, int end_val){
    // Returns 0-100 softened ramp between start and end
    if(value <= start_val) return 0;
    if(value >= end_val) return 100;
    value = (value - start_val) * 100 / (end_val - start_val);
    // cubic ease (value^2 * (3 - 2*value)) in 0-100 range
    return (value * value * (300 - (2 * value))) / 10000;
}

// ============== CUSTOM INTEGER SQUARE ROOT (GPC SAFE) ==============
int isqrt_custom(int n) {
    if (n <= 0) return 0;

    // Initial guess, assuming max value is less than 2^31 (int limits)
    // Refactored to use global variables g_val (root) and g_temp (next_root) for GPC compatibility.
    // g_val, g_temp are already defined as globals.
    g_val = n;
    g_temp = (g_val + (n / g_val)) / 2;

    while(g_val > g_temp) {
        g_val = g_temp;
        g_temp = (g_val + (n / g_val)) / 2;
    }
    return g_val;
}

