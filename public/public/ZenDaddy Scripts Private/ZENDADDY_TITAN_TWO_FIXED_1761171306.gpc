void apply_weapon_profile_scaling(){
    assist_core_blend = clamp_i((assist_core_blend * weapon_gain_core_mix) / 100, 0, 100);
    assist_slowdown_blend = clamp_i((assist_slowdown_blend * weapon_gain_slowdown_mix) / 100, 0, 100);
    assist_rotation_blend = clamp_i((assist_rotation_blend * weapon_gain_rotation_mix) / 100, 0, 100);
    assist_snap_blend = clamp_i((assist_snap_blend * weapon_gain_snap_mix) / 100, 0, 100);
    aim_state_resistance_pct = clamp_i((aim_state_resistance_pct * weapon_gain_resist_mix) / 100, 40, 200);
}

// ============== RECOIL GAIN MODULATION ==============
void apply_recoil_modulation(){
    if(!ads || !shooting) return;

    g_val = weapon_recoil_pitch_gain[weapon_profile_current]; // current_pitch_gain
    g_temp = weapon_recoil_yaw_gain[weapon_profile_current]; // current_yaw_gain

    // Vertical modulation (pitch) applied to Snap (vertical)
    // Reduce snap strength to prevent aim assist fighting recoil.
    // Max reduction is 50%. A gain of 48 means 48% of the assist is modulated/reduced
    g_p = 100 - (g_val / 2); // vertical_mod_pct
    if(g_p < 50) g_p = 50;

    // Horizontal modulation (yaw)
    g_fill = 100 - (g_temp / 2); // horizontal_mod_pct
    if(g_fill < 70) g_fill = 70;

    // Apply modulation to blended assist factors
    // Horizontal modulation primarily affects Rotation (aim pull)
    assist_rotation_blend = (assist_rotation_blend * g_fill) / 100;

    // Vertical modulation primarily affects Snap (target acquisition/vertical pull)
    assist_snap_blend = (assist_snap_blend * g_p) / 100;

    // Core blend modulation (general sensitivity to control everything)
    assist_core_blend = (assist_core_blend * g_p) / 100;
}

void update_weapon_profile(){
    // g_val = the determined target profile index (replacement for local 'target')
    g_val = weapon_profile_target;
    if(g_val < 0) g_val = 0;
    if(g_val >= WEAPON_PROFILE_COUNT) g_val = WEAPON_PROFILE_COUNT - 1;

    // g_temp = active profile index (replacement for local 'active')
    g_temp = weapon_profile_active;
    if(g_temp < 0 || g_temp >= WEAPON_PROFILE_COUNT){
        g_temp = g_val; // active = target
        weapon_profile_active = g_temp;
        weapon_profile_timer = 0;
        weapon_profile_blend_pct = 0;
    }

    if(g_temp != g_val){ // active != target
        weapon_profile_timer = weapon_profile_timer + delta;
        if(weapon_profile_timer >= WEAPON_PROFILE_BLEND_TIME){
            weapon_profile_active = g_val; // active = target
            weapon_profile_current = g_val; // current = target
            weapon_profile_timer = 0;
            weapon_profile_blend_pct = 0;
        } else {
            weapon_profile_blend_pct = (weapon_profile_timer * 100) / WEAPON_PROFILE_BLEND_TIME;
            if(weapon_profile_blend_pct > 100) weapon_profile_blend_pct = 100;
        }
    } else {
        g_temp = weapon_profile_current;
        weapon_profile_current = g_temp; // current = active
        weapon_profile_timer = 0;
        weapon_profile_blend_pct = 0;
    }

    g_p = weapon_profile_blend_pct; // blend_pct
    g_fill = weapon_profile_active; // blend_from
    g_expected = g_val; // blend_to

    if(g_p > 0 && g_fill != g_expected){
        weapon_gain_core_mix = lerp_pct(weapon_core_gain[g_fill], weapon_core_gain[g_expected], g_p);
        weapon_gain_slowdown_mix = lerp_pct(weapon_slowdown_gain[g_fill], weapon_slowdown_gain[g_expected], g_p);
        weapon_gain_rotation_mix = lerp_pct(weapon_rotation_gain[g_fill], weapon_rotation_gain[g_expected], g_p);
        weapon_gain_snap_mix = lerp_pct(weapon_snap_gain[g_fill], weapon_snap_gain[g_expected], g_p);
        weapon_gain_resist_mix = lerp_pct(weapon_resist_gain[g_fill], weapon_resist_gain[g_expected], g_p);
        weapon_gain_autopull_mix = lerp_pct(weapon_autopull_gain[g_fill], weapon_autopull_gain[g_expected], g_p);
        weapon_gain_ads_slowdown_mix = lerp_pct(weapon_ads_slowdown_gain[g_fill], weapon_ads_slowdown_gain[g_expected], g_p);
        weapon_gain_ads_rotation_mix = lerp_pct(weapon_ads_rotation_gain[g_fill], weapon_ads_rotation_gain[g_expected], g_p);
    } else {
        g_temp = weapon_profile_current;
        weapon_gain_core_mix = weapon_core_gain[g_temp];
        weapon_gain_slowdown_mix = weapon_slowdown_gain[g_temp];
        weapon_gain_rotation_mix = weapon_rotation_gain[g_temp];
        weapon_gain_snap_mix = weapon_snap_gain[g_temp];
        weapon_gain_resist_mix = weapon_resist_gain[g_temp];
        weapon_gain_autopull_mix = weapon_autopull_gain[g_temp];
        weapon_gain_ads_slowdown_mix = weapon_ads_slowdown_gain[g_temp];
        weapon_gain_ads_rotation_mix = weapon_ads_rotation_gain[g_temp];
    }
}

// ====================== INIT =======================
init {
    splash_draw();  // Initialize (Titan Two has no OLED)

    last_time = system_time();
    // Titan Two has no LED support - LED code removed

    // Initialize SIN/COS lookup tables (GPC needs manual init)
    sinLUT[0]=0; sinLUT[1]=38; sinLUT[2]=71; sinLUT[3]=92;
    sinLUT[4]=100; sinLUT[5]=92; sinLUT[6]=71; sinLUT[7]=38;
    sinLUT[8]=0; sinLUT[9]=-38; sinLUT[10]=-71; sinLUT[11]=-92;
    sinLUT[12]=-100; sinLUT[13]=-92; sinLUT[14]=-71; sinLUT[15]=-38;
    cosLUT[0]=100; cosLUT[1]=92; cosLUT[2]=71; cosLUT[3]=38;
    cosLUT[4]=0; cosLUT[5]=-38; cosLUT[6]=-71; cosLUT[7]=-92;
    cosLUT[8]=-100; cosLUT[9]=-92; cosLUT[10]=-71; cosLUT[11]=-38;
    cosLUT[12]=0; cosLUT[13]=38; cosLUT[14]=71; cosLUT[15]=92;

    // Initialize adaptive resistance
    prev_rx = 0; prev_ry = 0;
    input_velocity = 0;
    resistance_active = 0;  // Start DISABLED - only activate inside bubble!

    // Initialize edge detection variables
    prev_shoot = 0; prev_jump = 0;

    micro_angle = 0;
    micro_orbit_index = 0;
    init_weapon_profiles();
    assist_pipeline_reset();
    waveform_seed(system_time());
    rotation_gap_current = ROTATION_FREQ_SLOW_LOCK;
    rotation_jitter_timer = 0;
    rotation_jitter_interval = 0;
    micro_orbit_timer = 0;
    micro_orbit_interval_ms = 12;
    micro_orbit_variation_timer = 0;
    micro_orbit_direction = 1;

    // Phase F: Anti-Detection Jitter Initialization for Combo Timers
    stealth_stealth_factor = 100; // Max stealth (max jitter)
    idle_pull_interval = IDLE_AUTO_PULL_TIME + waveform_rand_signed(STEALTH_IDLE_JITTER);
    movement_gate_interval = MOVEMENT_GATE_TIME + waveform_rand_signed(STEALTH_MOVEMENT_JITTER);
    if(idle_pull_interval < 10) idle_pull_interval = 10; // Safety minimum
    if(movement_gate_interval < 10) movement_gate_interval = 10; // Safety minimum

    subsystem_flags = SUBSYSTEM_ALL;
    hipfire_sticky_active = 0;
    hipfire_sticky_timer = 0;
    hipfire_sticky_weight = 0;
    hipfire_resistance_bonus = 0;

    bubble_zone_edges[0] = 20;
    bubble_zone_edges[1] = 40;
    bubble_zone_edges[2] = 70;
    bubble_zone_edges[3] = 110;
    bubble_zone_edges[4] = 150;

    slowdown_zone_map[0] = SLOWDOWN_ULTRA;
    slowdown_zone_map[1] = SLOWDOWN_CLOSE;
    slowdown_zone_map[2] = SLOWDOWN_MEDIUM;
    slowdown_zone_map[3] = SLOWDOWN_FAR;
    slowdown_zone_map[4] = SLOWDOWN_OUTER;

    rotation_pull_hip_map[0] = ROTATION_PULL_HIP_ULTRA;
    rotation_pull_hip_map[1] = ROTATION_PULL_HIP_CLOSE;
    rotation_pull_hip_map[2] = ROTATION_PULL_HIP_MEDIUM;
    rotation_pull_hip_map[3] = ROTATION_PULL_HIP_FAR;

    rotation_pull_ads_map[0] = ROTATION_PULL_ADS_ULTRA;
    rotation_pull_ads_map[1] = ROTATION_PULL_ADS_CLOSE;
    rotation_pull_ads_map[2] = ROTATION_PULL_ADS_MEDIUM;
    rotation_pull_ads_map[3] = ROTATION_PULL_ADS_FAR;
}

// ====================== MAIN =======================
main {
    delta = system_time() - last_time;
    last_time = system_time();
    shake_timer = shake_timer + delta;

    // Update hyper-burst timer
    if(hyper_burst_active){
        hyper_burst_timer = hyper_burst_timer + delta;
        if(hyper_burst_timer > HYPER_BURST_DURATION){
            hyper_burst_active = 0;
        }
    
    if(jump_timer > 0){ 
        jump_timer = jump_timer - delta; 
        if(jump_timer < 0) jump_timer = 0; 
    }
    if(shot_timer > 0){ 
        shot_timer = shot_timer - delta; 
        if(shot_timer < 0) shot_timer = 0; 
    }
    if(build_lockout > 0){ 
        build_lockout = build_lockout - delta; 
        if(build_lockout < 0) build_lockout = 0; 
    }

    // Script is ALWAYS ACTIVE - no menu or toggle
    aim_on = 1;

    // Diagnostics feature removed to save memory for Titan Two

    if(oneshot_mode && !ads){
        if(get_val(BTN_SHOOT) && !prev_shoot){
            hipfire_sticky_active = 1;
            hipfire_sticky_timer = HIP_STICKY_WINDOW_MS;
        }
        prev_shoot = get_val(BTN_SHOOT);
        if(hipfire_sticky_active){
            if(shooting){
                hipfire_sticky_timer = HIP_STICKY_WINDOW_MS;
            } else if(hipfire_sticky_timer > 0){
                hipfire_sticky_timer = hipfire_sticky_timer - delta;
                if(hipfire_sticky_timer < 0) hipfire_sticky_timer = 0;
            }
            g_val = abs(lx) + abs(ly) + abs(rx) + abs(ry); // GPC Compatibility Fix: Replaced local int with global g_val
            if(hipfire_sticky_timer == 0 || g_val >= HIP_STICKY_CANCEL_VELOCITY){ // Used g_val instead of local var
                hipfire_sticky_active = 0;
            }
        }
    } else {
        hipfire_sticky_active = 0;
        hipfire_sticky_timer = 0;
    }


    // ===== XBOX BACK BUTTON MAPPING (LS + MENU = MAP) =====
    // Xbox controller - LS + MENU simulates back button for Fortnite map

    // Build/Edit detection - SMART real-time detection!
    // B button ingedrukt = build mode, release = weapon mode
    if(get_val(BTN_BUILD)){
        // CIRCLE pressed = BUILD MODE ACTIVE
        if(!build_mode){
            // Net in build mode gegaan - stop aim assist + LOCKOUT
            build_mode = 1;
            combo_stop(UltimateMaster);
            build_lockout = 100;
        }

        // Edit mode timer (hold > 200ms = edit)
        edit_timer = edit_timer + delta;
        if(edit_timer > 200 && !edit_mode){
            edit_mode = 1;
        }
    }
    else {
        // CIRCLE released = WEAPON MODE ACTIVE
        if(build_mode || edit_mode){
            // Net uit build/edit - instant restart aim assist (ONLY if lockout expired!)
            build_mode = 0;
            edit_mode = 0;
            edit_timer = 0;
        }
    }

    // Aim assist actief tijdens ADS of schieten
    if(aim_on && (ads || shooting)){
        combo_run(UltimateMaster);
    } else if(!aim_on){
        assist_pipeline_reset();
    }

    // Get raw inputs
    raw_rx = get_val(AXIS_RX);
    raw_ry = get_val(AXIS_RY);
    raw_lx = get_val(LX);
    raw_ly = get_val(LY);

    // Drift compensation
    if(abs(raw_lx) < 10 && abs(raw_ly) < 10 && !shooting){
        drift_timer = drift_timer + 1;

        if(drift_timer > 50){
            if(abs(raw_rx) < 25 && abs(raw_rx) > 3){
                drift_x = raw_rx;
            }
            if(abs(raw_ry) < 25 && abs(raw_ry) > 3){
                drift_y = raw_ry;
            }
        }
    }
    else {
        drift_timer = 0;
    }

    rx = raw_rx - drift_x;
    ry = raw_ry - drift_y;
    lx = raw_lx;
    ly = raw_ly;

    if(abs(rx) < DEADZONE_BASE) rx = 0;
    if(abs(ry) < DEADZONE_BASE) ry = 0;

    // Edit mode direct output
    if(edit_mode){
        set_val(AXIS_RX, rx);
        set_val(AXIS_RY, ry);
    }

    // State detection
    ads = (get_val(BTN_ADS) > 30);
    shooting = (get_val(BTN_SHOOT) > 30);
    velocity_mag = abs(lx) + abs(ly);

    // R2-TRIGGERED ASSIST: v4.7 ZERO DELAY - PRO FORTNITE!
    if(shooting && !r2_was_pressed) {
        // v4.7: INSTANT assist - GEEN DELAY! (weapon swap fix!)
        r2_assist_timer = 150;  // INSTANT actief - geen wachttijd!
        r2_was_pressed = 1;
        r2_hipfire_instant = 1;
    }
    else if(shooting) {
        // Keep active while shooting
        r2_assist_timer = 150;
    }
    else if(r2_was_pressed) {
        // R2 just released - start fade-out
        r2_assist_fade_timer = 280;  // v4.4: LANGERE fade! (was 150)
        r2_was_pressed = 0;
        r2_hipfire_instant = 0;
    }

    // Fade-out countdown
    if(r2_assist_fade_timer > 0) {
        r2_assist_fade_timer = r2_assist_fade_timer - delta;
        if(r2_assist_fade_timer < 0) r2_assist_fade_timer = 0;
    }

    // Jump detection
    if(get_val(BTN_JUMP) && !prev_jump) {
        jump_timer = 1200;
        aerial_timer = 0;
        fall_velocity = 0;
        aerial_offset_y = 0;
    }
    prev_jump = get_val(BTN_JUMP);

    if(jump_timer > 0 && get_val(BTN_JUMP) < 30){
        jump_timer = 0;
        aerial_timer = 0;
        fall_velocity = 0;
        aerial_offset_y = 0;
    }

    jumping = (jump_timer > 0);
    if(jump_timer > (1200 - AERIAL_THRESHOLD)) aerial_mode = 1; else aerial_mode = 0;

    // Weapon detection - VERBETERD voor one-shots!
    if(get_val(BTN_SHOOT) && !prev_shoot){
        // Bereken interval tussen shots
        if(last_shot_time > 0){
            shot_interval = system_time() - last_shot_time;

            // Detecteer weapon type op basis van interval
            if(shot_interval > WEAPON_SHOTGUN_TIME){
                oneshot_mode = 1;  // Shotgun
            }
            else if(shot_interval > WEAPON_SNIPER_TIME){
                oneshot_mode = 1;  // Sniper
            }
            else if(shot_interval < WEAPON_AR_TIME){
                oneshot_mode = 0;  // AR/SMG
            }
        }

        last_shot_time = system_time();

        // Sniper mode voor aerial
        if(shot_timer > SNIPER_DELAY) sniper_mode = 1; else sniper_mode = 0;
        shot_timer = 1500;

    }

    update_weapon_profile_detection();

    // FLICKSHOT DETECTION - instant max assist!
    input_spike = abs(input_mag - last_input_mag);
    if(input_spike > FLICK_THRESHOLD && input_mag > 40){
        flick_detected = 1;
        // Reset na 150ms
        if(delta > FLICK_WINDOW) flick_detected = 0;
    }
    else {
        flick_detected = 0;
    }
    last_input_mag = input_mag;

    // Trickshot detection
    if((aerial_mode && sniper_mode) || (jumping && velocity_mag > 150)) trickshot_lock = 1;
    else if(!jumping) trickshot_lock = 0;

    input_mag = abs(rx) + abs(ry);

    // Aim assist actief tijdens ADS of schieten
    if(aim_on && (ads || shooting) && !build_mode && !edit_mode){
        combo_run(UltimateMaster);
    }
}

// ================ BUBBLE ZONE DETECTION =============
void update_bubble_state(){
    bubble_zone_raw = 0;
    g_chars = 0;
    while(g_chars < 5){
        if(distance_pixels <= bubble_zone_edges[g_chars]){
            bubble_zone_raw = g_chars + 1;
            break;
        }
        g_chars = g_chars + 1;
    }

    if(bubble_zone_stable == 0){
        bubble_zone_stable = bubble_zone_raw;
    }

    if(bubble_zone_stable > 0){
        g_val = get_zone_slider_value(bubble_zone_stable);
        g_temp = BUBBLE_ENABLE_MARGIN + ((g_val - 50) * BUBBLE_ENABLE_MARGIN) / 100;
        if(g_temp < 1) g_temp = 1;
        bubble_inner_radius = bubble_zone_edges[bubble_zone_stable - 1] - g_temp;
        if(bubble_inner_radius < 0) bubble_inner_radius = 0;

        g_total = BUBBLE_DISABLE_MARGIN + ((g_val - 50) * BUBBLE_DISABLE_MARGIN) / 100;
        if(g_total < 1) g_total = 1;
        bubble_outer_radius = bubble_zone_edges[bubble_zone_stable - 1] + g_total;

        if(distance_pixels <= bubble_inner_radius){
            bubble_zone_stable = bubble_zone_stable;  // Stay in current zone
        } else if(distance_pixels >= bubble_outer_radius){
            bubble_zone_stable = bubble_zone_raw;
        }
    } else {
        bubble_inner_radius = 0;
        bubble_outer_radius = 0;
    }

    if(bubble_zone_stable == 0 && bubble_zone_raw > 0){
        bubble_zone_stable = bubble_zone_raw;
    }

    bubble_zone = bubble_zone_stable;
}

// ================ RANGE DETECTION ===================
// CRITICAL: Use distance_pixels (screen-space) not input_mag (stick magnitude)!
// input_mag is LOW when locked (stick centered), maar distance kan GROOT zijn!
// Dit zorgt dat long/med sliders correct werken op alle ranges!
void get_current_range(){
    // Range based on screen-space distance (pixels from center)
    if(distance_pixels <= 25){
        current_range = 0;  // SHORT: 0-25px (close combat)
    }
    else if(distance_pixels <= 50){
        current_range = 1;  // MEDIUM: 25-50px (mid-range)
    }
    else {
        current_range = 2;  // LONG: 50+px (long-range)
    }
}

// =============== TARGET LOCK DETECTION ==============
// HYSTERESIS toegevoegd: voorkomt oscillatie!
void update_target_lock(){
    delta_rx = abs(rx - last_rx);
        delta_ry = abs(ry - last_ry);
    tk_combined_delta = delta_rx + delta_ry;


    input_mag = abs(rx) + abs(ry);
    aim_error_pixels = distance_pixels;
    distance_delta = distance_pixels - last_distance_pixels;

    aim_error_avg = smooth_gain(aim_error_avg, aim_error_pixels, 20);
    aim_error_trend = smooth_gain(aim_error_trend, distance_delta, 20);
    velocity_avg = smooth_gain(velocity_avg, input_mag, 20);

    tk_proximity_score = 100 - soft_step(aim_error_pixels, BUBBLE_ULTRA_CLOSE, BUBBLE_OUTER);
    if(tk_proximity_score < 0) tk_proximity_score = 0;
    assist_last_proximity_score = tk_proximity_score;
    tk_stability_score = 100 - soft_step(tk_combined_delta, 8, 45);
    if(tk_stability_score < 0) tk_stability_score = 0;
    tk_trend_score = 100 - soft_step(abs(distance_delta), 5, 35);
    if(tk_trend_score < 0) tk_trend_score = 0;
    tk_timer_score = soft_step(lock_timer, LOCK_TIMER_MIN, LOCK_TIMER_STABLE);

    aim_error_variance = smooth_gain(aim_error_variance, abs(aim_error_pixels - aim_error_avg), 35);

    tk_raw_lock_conf = (tk_proximity_score * 45 + tk_stability_score * 25 + tk_trend_score * 15 + tk_timer_score * 15) / 100;
    tk_raw_lock_conf = clamp_i(tk_raw_lock_conf, 0, 100);

    if(oneshot_mode || flick_detected || shooting){
        if(tk_raw_lock_conf < 80) tk_raw_lock_conf = 80;
    }

    g_temp = 30;
    if(target_locked) g_temp = 12;
    lock_confidence = smooth_gain(lock_confidence, tk_raw_lock_conf, g_temp);

    lock_confidence = clamp_i(lock_confidence, 0, 100);

    if(lock_confidence >= 55){
        if(!target_locked){
            target_locked = 1;
            lock_timer = 0;
            if(oneshot_mode || flick_detected){
                hyper_burst_active = 1;
                hyper_burst_timer = 0;
            }
        } else {
            if(lock_timer < LOCK_TIMER_MAX) lock_timer = lock_timer + 1;
        }
    }
    else if(lock_confidence <= 15){  // v4.4: LAGER voor langere lock persistence! (was 20)
        target_locked = 0;
        lock_timer = 0;
        hyper_burst_active = 0;
    }

    if(target_locked){
        if(lock_confidence >= 90){
            lock_strength = 100;
        }
        else if(lock_confidence >= 70){
            lock_strength = 85 + ((lock_confidence - 70) * 15) / 20;
        }
        else {
            lock_strength = 70 + ((lock_confidence - 55) * 15) / 15;
        }
        lock_strength = clamp_i(lock_strength, 60, 100);
    }
    else {
        lock_strength = clamp_i(lock_confidence, 0, 75);
    }

    last_rx = rx;
    last_ry = ry;
    last_distance_pixels = distance_pixels;
}

// =============== SCREEN-SPACE CONVERSION ==============
void update_screen_space(){
    // Convert rx/ry to screen pixels from center
    pixel_offset_x = (rx * SCREEN_WIDTH) / 200;
    pixel_offset_y = (ry * SCREEN_HEIGHT) / 200;

    // Calculate distance in pixels (Pythagoras)
    distance_pixels = isqrt_custom((pixel_offset_x * pixel_offset_x) + (pixel_offset_y * pixel_offset_y));

    // Hyper-burst maakt bubble 2x groter voor one-shots!
    if(hyper_burst_active){
        distance_pixels = (distance_pixels * 100) / HYPER_BUBBLE_MULTI;
    }
}

// =============== MULTI-ZONE WEIGHTED SYSTEM ==============
void update_weighted_zones(){
    // Reset weights
    zone_weight_ultra = 0;
    zone_weight_close = 0;
    zone_weight_mid = 0;
    zone_weight_far = 0;

    // Weighted blending tussen zones (smooth transitions!)
    if(distance_pixels <= BUBBLE_ZONE_ULTRA){
        zone_weight_ultra = 100;
    }
    else if(distance_pixels <= BUBBLE_ZONE_CLOSE){
        zone_weight_ultra = 100 - (((distance_pixels - BUBBLE_ZONE_ULTRA) * 100) / (BUBBLE_ZONE_CLOSE - BUBBLE_ZONE_ULTRA));
        zone_weight_close = 100 - zone_weight_ultra;
    }
    else if(distance_pixels <= BUBBLE_ZONE_MID){
        zone_weight_close = 100 - (((distance_pixels - BUBBLE_ZONE_CLOSE) * 100) / (BUBBLE_ZONE_MID - BUBBLE_ZONE_CLOSE));
        zone_weight_mid = 100 - zone_weight_close;
    }
    else if(distance_pixels <= BUBBLE_ZONE_FAR){
        zone_weight_mid = 100 - (((distance_pixels - BUBBLE_ZONE_MID) * 100) / (BUBBLE_ZONE_FAR - BUBBLE_ZONE_MID));
        zone_weight_far = 100 - zone_weight_mid;
    }
    else if(distance_pixels <= BUBBLE_ZONE_OUTER){
        zone_weight_far = 100 - (((distance_pixels - BUBBLE_ZONE_FAR) * 100) / (BUBBLE_ZONE_OUTER - BUBBLE_ZONE_FAR));
    }
}

// =============== LEFT-STICK ROTATION GATE ==============
void update_rotation_gate(){
    // Bereken strafe velocity (left stick + VIRTUAL strafe!)
    // Virtual strafe wordt toegevoegd voor magnetic mode calculation
    strafe_velocity = abs(lx + virtual_strafe_x) + abs(ly + virtual_strafe_y);

    // Rotation ALLEEN actief bij strafe OF micro aim movements
    // Virtual strafe zorgt dat dit ALTIJD triggered bij magnetic mode!
    if(strafe_velocity > ROTATION_STRAFE_GATE || (input_mag > 5 && input_mag < 25)){
        rotation_active = 1;
    }
    else {
        rotation_active = 0;
    }

    if(hipfire_sticky_active){
        rotation_active = 1;
    }
}

// =============== PREDICTIVE LAZY AIM ==============
void update_predictive_aim_legacy(){
    enemy_velocity_prev_x = enemy_velocity_x;
    enemy_velocity_prev_y = enemy_velocity_y;

    enemy_velocity_x = pixel_offset_x - last_pixel_x;
    enemy_velocity_y = pixel_offset_y - last_pixel_y;

    enemy_accel_x = enemy_velocity_x - enemy_velocity_prev_x;
    enemy_accel_y = enemy_velocity_y - enemy_velocity_prev_y;

    enemy_velocity_hist_x[enemy_hist_index] = enemy_velocity_x;
    enemy_velocity_hist_y[enemy_hist_index] = enemy_velocity_y;

    enemy_hist_index = enemy_hist_index + 1;
    if(enemy_hist_index >= PRED_BUFFER_SIZE){
        enemy_hist_index = 0;
    }

    if(enemy_hist_count < PRED_BUFFER_SIZE){
        enemy_hist_count = enemy_hist_count + 1;
    }

    enemy_velocity_avg_prev_x = enemy_velocity_avg_x;
    enemy_velocity_avg_prev_y = enemy_velocity_avg_y;

    g_chars = 0;
    g_total = 0;
    while(g_chars < enemy_hist_count){
        g_total = g_total + enemy_velocity_hist_x[g_chars];
        g_chars = g_chars + 1;
    }
    if(enemy_hist_count > 0) {
        g_temp = g_total / enemy_hist_count;
    } else {
        g_temp = enemy_velocity_x;
    }
    enemy_velocity_avg_x = smooth_gain(enemy_velocity_avg_x, g_temp, PRED_VELOCITY_SMOOTH_GAIN);

    g_chars = 0;
    g_total = 0;
    while(g_chars < enemy_hist_count){
        g_total = g_total + enemy_velocity_hist_y[g_chars];
        g_chars = g_chars + 1;
    }
    if(enemy_hist_count > 0) {
        g_temp = g_total / enemy_hist_count;
    } else {
        g_temp = enemy_velocity_y;
    }
    enemy_velocity_avg_y = smooth_gain(enemy_velocity_avg_y, g_temp, PRED_VELOCITY_SMOOTH_GAIN);

    g_temp = enemy_velocity_avg_x - enemy_velocity_avg_prev_x;
    enemy_accel_avg_x = smooth_gain(enemy_accel_avg_x, g_temp, PRED_ACCEL_SMOOTH_GAIN);
    g_temp = enemy_velocity_avg_y - enemy_velocity_avg_prev_y;
    enemy_accel_avg_y = smooth_gain(enemy_accel_avg_y, g_temp, PRED_ACCEL_SMOOTH_GAIN);

    g_temp = enemy_accel_avg_x * enemy_accel_avg_x;
    g_total = enemy_accel_avg_y * enemy_accel_avg_y;
    enemy_accel_avg_mag = isqrt_custom((g_temp + g_total));
    if(enemy_accel_avg_mag > 160) enemy_accel_avg_mag = 160;

    g_total = 100 - PRED_HISTORY_BLEND;
    enemy_velocity_blend_x = ((enemy_velocity_avg_x * PRED_HISTORY_BLEND) + (enemy_velocity_x * g_total)) / 100;
    enemy_velocity_blend_y = ((enemy_velocity_avg_y * PRED_HISTORY_BLEND) + (enemy_velocity_y * g_total)) / 100;
    enemy_accel_blend_x = ((enemy_accel_avg_x * PRED_HISTORY_BLEND) + (enemy_accel_x * g_total)) / 100;
    enemy_accel_blend_y = ((enemy_accel_avg_y * PRED_HISTORY_BLEND) + (enemy_accel_y * g_total)) / 100;

    g_temp = enemy_accel_blend_x * enemy_accel_blend_x;
    g_total = enemy_accel_blend_y * enemy_accel_blend_y;
    enemy_accel_mag = isqrt_custom((g_temp + g_total));
    if(enemy_accel_mag > 160) enemy_accel_mag = 160;

    g_temp = enemy_velocity_blend_x * enemy_velocity_blend_x;
    g_temp = enemy_velocity_blend_x * enemy_velocity_blend_x;
    g_total = enemy_velocity_blend_y * enemy_velocity_blend_y;
    enemy_speed_mag = isqrt_custom((g_temp + g_total));
    if(enemy_speed_mag > 160) enemy_speed_mag = 160;

    predict_horizon_target = 4 + (lock_confidence * 6) / 100;
    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
    if(predict_horizon_target > 10) predict_horizon_target = 10;

    g_val = slider_smoothness - 50;
    if(g_val != 0){
        predict_horizon_target = predict_horizon_target + (g_val / 25);
    }
    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
    if(predict_horizon_target > PRED_HORIZON_MAX) predict_horizon_target = PRED_HORIZON_MAX;

    g_total = abs(enemy_velocity_blend_x) + abs(enemy_velocity_blend_y);
    if(g_total > 120){
        predict_horizon_target = (predict_horizon_target * 70) / 100;
    } else if(g_total < 35){
        predict_horizon_target = (predict_horizon_target * 120) / 100;
    }
    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
    if(predict_horizon_target > PRED_HORIZON_MAX) predict_horizon_target = PRED_HORIZON_MAX;

    if(enemy_accel_mag > PRED_ACCEL_VARIANCE_GATE){
        g_chars = enemy_accel_mag - PRED_ACCEL_VARIANCE_GATE;
        if(g_chars > PRED_ACCEL_VARIANCE_CLAMP) g_chars = PRED_ACCEL_VARIANCE_CLAMP;
        g_expected = 100 - g_chars;
        if(g_expected < 30) g_expected = 30;
        predict_horizon_target = (predict_horizon_target * g_expected) / 100;
    }

    if(enemy_accel_avg_mag < 15 && enemy_speed_mag < 45){
        predict_horizon_target = (predict_horizon_target * 120) / 100;
    }

    if(oneshot_mode){
        predict_horizon_target = predict_horizon_target + 1;
    }

    if(predict_horizon_target < PRED_HORIZON_MIN) predict_horizon_target = PRED_HORIZON_MIN;
    if(predict_horizon_target > PRED_HORIZON_MAX) predict_horizon_target = PRED_HORIZON_MAX;

    if(predict_horizon_frames <= 0){
        predict_horizon_frames = predict_horizon_target;
    } else {
        predict_horizon_frames = smooth_gain(predict_horizon_frames, predict_horizon_target, PRED_HORIZON_SMOOTH_GAIN);
    }
    if(predict_horizon_frames < PRED_HORIZON_MIN) predict_horizon_frames = PRED_HORIZON_MIN;
    if(predict_horizon_frames > PRED_HORIZON_MAX) predict_horizon_frames = PRED_HORIZON_MAX;

    g_val = (predict_horizon_frames * (predict_horizon_frames + 1)) / 2;
    if(g_val < 1) g_val = 1;

    g_temp = enemy_velocity_blend_x * predict_horizon_frames;
    g_total = (enemy_accel_blend_x * g_val * PRED_ACCEL_GAIN) / 100;
    predict_offset_x = pixel_offset_x + g_temp + g_total;

    g_temp = enemy_velocity_blend_y * predict_horizon_frames;
    if(lock_strength >= LAZY_AIM_MIN_LOCK && target_locked){
        pred_weapon_mult = PRED_AR_MULT;
        if(oneshot_mode){
            pred_weapon_mult = PRED_ONESHOT_MULT;
        } else if(sniper_mode){
            pred_weapon_mult = PRED_SNIPER_MULT;
        }
        if(aerial_mode){
            pred_weapon_mult = (pred_weapon_mult * PRED_AERIAL_MULT) / 100;
        }
        if(pred_weapon_mult < 60) pred_weapon_mult = 60;
        if(pred_weapon_mult > 180) pred_weapon_mult = 180;

        predictive_bias_strength = LAZY_AIM_BIAS;
        predictive_bias_strength = (predictive_bias_strength * (40 + lock_confidence)) / 100;
        predictive_bias_strength = (predictive_bias_strength * (60 + assist_core_blend)) / 100;
        predictive_bias_strength = (predictive_bias_strength * pred_weapon_mult) / 100;
        predictive_bias_strength = (predictive_bias_strength * (80 + enemy_stability_pct)) / 100;
        predictive_bias_strength = (predictive_bias_strength * weapon_gain_core_mix) / 100;
        if(predictive_bias_strength < 6) predictive_bias_strength = 6;
        if(predictive_bias_strength > 80) predictive_bias_strength = 80;

        g_val = (predict_horizon_frames * (predict_horizon_frames + 1)) / 2;
        if(g_val < 1) g_val = 1;

        g_temp = enemy_velocity_blend_x * predict_horizon_frames;
        g_total = (enemy_accel_blend_x * g_val * PRED_ACCEL_GAIN) / 100;
        predict_offset_x = pixel_offset_x + g_temp + g_total;

        g_temp = enemy_velocity_blend_y * predict_horizon_frames;
        g_expected = (enemy_accel_blend_y * g_val * PRED_ACCEL_GAIN) / 100;
        g_chars = (enemy_velocity_blend_y * PRED_VERTICAL_GAIN) / 100;
        predict_offset_y = pixel_offset_y + g_temp + g_expected + g_chars;

        lazy_bias_x = ((predict_offset_x - pixel_offset_x) * predictive_bias_strength) / 100;
        lazy_bias_y = ((predict_offset_y - pixel_offset_y) * predictive_bias_strength) / 100;

        g_temp = 50 + (ads ? slider_ads_rotation : slider_hip_rotation);
        lazy_bias_x = (lazy_bias_x * g_temp) / 100;
        lazy_bias_y = (lazy_bias_y * g_temp) / 100;

        g_total = 100 + (enemy_speed_mag * VELOCITY_FOLLOW_STRENGTH) / 200;
        if(g_total < 80) g_total = 80;
        if(g_total > 160) g_total = 160;
        lazy_bias_x = (lazy_bias_x * g_total) / 100;
        lazy_bias_y = (lazy_bias_y * g_total) / 100;

        lazy_bias_cap_x = 10 + (assist_rotation_blend / 4);
        lazy_bias_cap_y = 8 + (assist_rotation_blend / 6);
        if(lazy_bias_cap_x < 8) lazy_bias_cap_x = 8;
        if(lazy_bias_cap_x > 32) lazy_bias_cap_x = 32;
        if(lazy_bias_cap_y < 8) lazy_bias_cap_y = 8;
        if(lazy_bias_cap_y > 28) lazy_bias_cap_y = 28;

        if(oneshot_mode){
            lazy_bias_cap_x = (lazy_bias_cap_x * 12) / 10;
            lazy_bias_cap_y = (lazy_bias_cap_y * 12) / 10;
        }

        if(lazy_bias_x > lazy_bias_cap_x) lazy_bias_x = lazy_bias_cap_x;
        if(lazy_bias_x < (0 - lazy_bias_cap_x)) lazy_bias_x = 0 - lazy_bias_cap_x;
        
        if(lazy_bias_y > lazy_bias_cap_y) lazy_bias_y = lazy_bias_cap_y;
        if(lazy_bias_y < (0 - lazy_bias_cap_y)) lazy_bias_y = 0 - lazy_bias_cap_y;
    }
    else {
        predict_offset_x = pixel_offset_x;
        predict_offset_y = pixel_offset_y;
        lazy_bias_x = 0;
        lazy_bias_y = 0;
    }

    last_pixel_x = pixel_offset_x;
    last_pixel_y = pixel_offset_y;

    if(enemy_speed_mag > 0){
        enemy_dir_x = (enemy_velocity_blend_x * 100) / enemy_speed_mag;
        enemy_dir_y = (enemy_velocity_blend_y * 100) / enemy_speed_mag;
        enemy_dir_x = clamp_i(enemy_dir_x, -100, 100);
        enemy_dir_y = clamp_i(enemy_dir_y, -100, 100);
    } else {
        enemy_dir_x = 0;
        enemy_dir_y = 0;
    }

    enemy_velocity_avg_prev_x = enemy_velocity_avg_x;
    enemy_velocity_avg_prev_y = enemy_velocity_avg_y;
    enemy_velocity_prev_x = enemy_velocity_x;
    enemy_velocity_prev_y = enemy_velocity_y;
}

void update_assist_core(){
    // GPC FIX: No local variables! Use globals g_val, g_temp, g_p, etc.

    if(input_velocity >= INPUT_VELOCITY_PANIC){
        panic_triggered = 250;
    }
    if(panic_triggered > 0){
        panic_triggered = panic_triggered - delta;
        if(panic_triggered < 0) panic_triggered = 0;
    }

    g_val = 100 - soft_step(aim_error_pixels, BUBBLE_ULTRA_CLOSE, BUBBLE_OUTER);
    if(g_val < 0) g_val = 0;
    assist_last_proximity_score = g_val;

    g_temp = abs(aim_error_trend);
    g_p = 100 - soft_step(g_temp, 3, 30);
    if(g_p < 0) g_p = 0;

    g_tboost = 100 - soft_step(abs(distance_delta), 4, 35);
    if(g_tboost < 0) g_tboost = 0;

    g_expected = INPUT_VELOCITY_FAST_HIP;
    if(ads) g_expected = INPUT_VELOCITY_FAST_ADS;
    g_fill = soft_step(input_velocity, 12, g_expected);
    if(g_fill < 0) g_fill = 0;

    g_chars = (lock_confidence * 50 + g_val * 20 + g_p * 15 + (100 - g_fill) * 15) / 100;

    if(!target_locked && g_val > 70 && g_fill < 40){
        if(g_chars < 25) g_chars = 25;
    }

    if(ads) g_chars = clamp_i(g_chars + 8, 0, 100);

    if(panic_triggered > 0){
        g_expected = soft_step(panic_triggered, 1, 250);
        g_chars = (g_chars * (100 - g_expected)) / 100;
    }

    assist_core_blend = smooth_gain(assist_core_blend, g_chars, 18);
    assist_core_blend = clamp_i(assist_core_blend, 0, 100);

    // Phase C refinement: Error Variance Stability Score (VSS) for smooth snap blending
    g_expected = 100 - soft_step(aim_error_variance, 6, 40); // 100 = Stable (low variance), 0 = Volatile (high variance)
    if(g_expected < 0) g_expected = 0;

    g_total = (assist_core_blend * 60 + g_val * 25 + (100 - g_fill) * 15) / 100;
    if(!ads) g_total = (g_total * 85) / 100;
    g_total = clamp_i(g_total, 0, 100);

    range_slider = assist_core_blend;
    if(rotation_active || strafe_active) range_slider = clamp_i(range_slider + 15, 0, 100);
    range_slider = range_slider - (g_fill / 2);
    if(range_slider < 0) range_slider = 0;
    range_slider = clamp_i(range_slider, 0, 100);

    // Snap Blend Target (Refined Phase C: Core Blend, Proximity, VSS, Trend Stability)
    // g_expected holds the VSS (aim_error_variance stability) from before g_total calculation
    g_temp = (assist_core_blend * 50 + g_val * 20 + g_expected * 15 + g_tboost * 15) / 100;
    if(flick_detected) g_temp = clamp_i(g_temp + 30, 0, 100);
    g_temp = clamp_i(g_temp, 0, 100);

    assist_slowdown_blend = smooth_gain(assist_slowdown_blend, g_total, 18);
    assist_rotation_blend = smooth_gain(assist_rotation_blend, range_slider, 18);
    assist_snap_blend = smooth_gain(assist_snap_blend, g_temp, 18);
}

void detect_assist_state(){
    g_val = aim_error_trend; // trend_abs
    if(g_val < 0) g_val = 0 - g_val;
    g_temp = distance_delta; // delta_abs
    if(g_temp < 0) g_temp = 0 - g_temp;
    g_p = assist_last_proximity_score; // proximity_score
    g_fill = input_velocity; // velocity_score
    g_tboost = lock_confidence; // lock_score
    g_expected = aim_state_current; // candidate
    // Using global temps for flags to ensure GPC compatibility
    g_val = 0; // acquire_flag
    g_temp = 0; // correct_flag
    g_p = 0; // recenter_flag
    g_fill = 0; // track_flag

    if(!target_locked){
        g_expected = AIM_STATE_ACQUIRE;
    } else {
        if(g_tboost <= AIM_ACQUIRE_LOCK_MAX || (g_tboost < 70 && aim_error_pixels > AIM_CORRECT_ERROR_MIN)){
            g_val = 1; // acquire_flag = 1
        }
        if(aim_error_pixels >= AIM_CORRECT_ERROR_MIN) g_temp = 1; // correct_flag = 1
        if(g_val >= AIM_CORRECT_DELTA_MIN) g_temp = 1; // correct_flag = 1
        if(sticky_edge_weight >= AIM_CORRECT_EDGE_WEIGHT) g_temp = 1; // correct_flag = 1

        if(g_p >= AIM_RECENTER_ZONE_MIN && g_val <= AIM_RECENTER_TREND_MAX && g_temp <= AIM_RECENTER_TREND_MAX){
            if(aim_state_current == AIM_STATE_RECENTER || aim_state_timer >= AIM_RECENTER_STABLE_TIME){
                g_p = 1; // recenter_flag = 1
            }
        }

        if(g_tboost > AIM_ACQUIRE_LOCK_MAX && aim_error_pixels <= AIM_TRACK_ERROR_MAX && g_fill <= AIM_TRACK_VELOCITY_MAX){
            g_fill = 1; // track_flag = 1
        }

        if(g_p){ // if(recenter_flag)
            g_expected = AIM_STATE_RECENTER;
        } else if(g_temp){ // if(correct_flag)
            g_expected = AIM_STATE_CORRECT;
        } else if(g_fill){ // if(track_flag)
            g_expected = AIM_STATE_TRACK;
        } else if(g_val){ // if(acquire_flag)
            g_expected = AIM_STATE_ACQUIRE;
        } else if(g_tboost > AIM_ACQUIRE_LOCK_MAX){
            g_expected = AIM_STATE_TRACK;
        } else {
            g_expected = AIM_STATE_ACQUIRE;
        }
    }

    if(g_expected != aim_state_current){
        aim_state_current = g_expected;
        aim_state_timer = 0;
    } else {
        if(aim_state_timer < 10000){
            aim_state_timer = aim_state_timer + delta;
            if(aim_state_timer > 10000) aim_state_timer = 10000;
        }
    }

    // target_weight vervangen door g_total om GPC-fout op lijn 2011 op te lossen.

    if(aim_state_current == AIM_STATE_ACQUIRE) g_total = 100; else g_total = 0;
    aim_state_weight_acquire = smooth_gain(aim_state_weight_acquire, g_total, AIM_STATE_BLEND_GAIN);

    if(aim_state_current == AIM_STATE_TRACK) g_total = 100; else g_total = 0;
    aim_state_weight_track = smooth_gain(aim_state_weight_track, g_total, AIM_STATE_BLEND_GAIN);

    if(aim_state_current == AIM_STATE_CORRECT) g_total = 100; else g_total = 0;
    aim_state_weight_correct = smooth_gain(aim_state_weight_correct, g_total, AIM_STATE_BLEND_GAIN);

    if(aim_state_current == AIM_STATE_RECENTER) g_total = 100; else g_total = 0;
    aim_state_weight_recenter = smooth_gain(aim_state_weight_recenter, g_total, AIM_STATE_BLEND_GAIN);

    // weight_sum vervangen door g_p
    g_p = aim_state_weight_acquire + aim_state_weight_track + aim_state_weight_correct + aim_state_weight_recenter;
    if(g_p < 1) g_p = 1;

    aim_state_core_pct = clamp_i(
        (AIM_ACQUIRE_CORE_PCT * aim_state_weight_acquire +
         AIM_TRACK_CORE_PCT * aim_state_weight_track +
         AIM_CORRECT_CORE_PCT * aim_state_weight_correct +
         AIM_RECENTER_CORE_PCT * aim_state_weight_recenter) / g_p,
        40, 160);

    aim_state_slowdown_pct = clamp_i(
        (AIM_ACQUIRE_SLOWDOWN_PCT * aim_state_weight_acquire +
         AIM_TRACK_SLOWDOWN_PCT * aim_state_weight_track +
         AIM_CORRECT_SLOWDOWN_PCT * aim_state_weight_correct +
         AIM_RECENTER_SLOWDOWN_PCT * aim_state_weight_recenter) / g_p,
        40, 185);

    aim_state_rotation_pct = clamp_i(
        (AIM_ACQUIRE_ROTATION_PCT * aim_state_weight_acquire +
         AIM_TRACK_ROTATION_PCT * aim_state_weight_track +
         AIM_CORRECT_ROTATION_PCT * aim_state_weight_correct +
         AIM_RECENTER_ROTATION_PCT * aim_state_weight_recenter) / g_p,
        40, 185);

    aim_state_snap_pct = clamp_i(
        (AIM_ACQUIRE_SNAP_PCT * aim_state_weight_acquire +
         AIM_TRACK_SNAP_PCT * aim_state_weight_track +
         AIM_CORRECT_SNAP_PCT * aim_state_weight_correct +
         AIM_RECENTER_SNAP_PCT * aim_state_weight_recenter) / g_p,
        40, 185);

    aim_state_resistance_pct = clamp_i(
        (AIM_ACQUIRE_RESIST_PCT * aim_state_weight_acquire +
         AIM_TRACK_RESIST_PCT * aim_state_weight_track +
         AIM_CORRECT_RESIST_PCT * aim_state_weight_correct +
         AIM_RECENTER_RESIST_PCT * aim_state_weight_recenter) / g_p,
        40, 200);

    aim_state_auto_pull_pct = clamp_i(
        (AIM_ACQUIRE_AUTOPULL_PCT * aim_state_weight_acquire +
         AIM_TRACK_AUTOPULL_PCT * aim_state_weight_track +
         AIM_CORRECT_AUTOPULL_PCT * aim_state_weight_correct +
         AIM_RECENTER_AUTOPULL_PCT * aim_state_weight_recenter) / g_p,
        40, 200);

    assist_core_blend = clamp_i((assist_core_blend * aim_state_core_pct) / 100, 0, 100);
    assist_slowdown_blend = clamp_i((assist_slowdown_blend * aim_state_slowdown_pct) / 100, 0, 100);
    assist_rotation_blend = clamp_i((assist_rotation_blend * aim_state_rotation_pct) / 100, 0, 100);
    assist_snap_blend = clamp_i((assist_snap_blend * aim_state_snap_pct) / 100, 0, 100);
}

// ================ STRAFE DETECTION ==================
void update_strafe_detection(){
    velocity_mag = abs(lx) + abs(ly);

    if(velocity_mag >= STRAFE_THRESHOLD){
        strafe_active = 1;
    }
    else {
        strafe_active = 0;
    }
}

// ========== ASSIST AMPLIFICATION (V3.0 RE-ENABLED - OPTIMIZED!) ==========
// OPLOSSING: Subtielere micro-orbit werkt NU SAMEN met Fortnite's aim assist!
// - Kleinere left-stick inject (6-12 units) TRIGGERT Fortnite's rotational assist
// - Geoptimaliseerde motion vult rotation pull aan → super smooth
// - Gecontroleerde beweging voorkomt weapon fire delays
// RESULTAAT: INGESCHAKELD - perfect samenspel tussen alle systemen!
void update_assist_amplification(){
    // RE-ENABLED V3.0 - micro-orbit triggert Fortnite rotation assist!
    // GEEN return meer - volledig functioneel!

    // OUDE CODE (bewaard voor referentie):
    // Gate: target locked + slider enabled (BOTH hipfire AND ADS!)
    // Fortnite's rotational assist werkt in BEIDE modes!
    if(!target_locked || build_mode || edit_mode){
        micro_orbit_index = 0;  // Reset orbit
        micro_orbit_timer = 0;
        micro_orbit_variation_timer = 0;
        micro_orbit_direction = 1;
        virtual_strafe_x = 0;
        virtual_strafe_y = 0;
        return;
    }

    // SIMPLIFIED: Als target locked, ga gewoon micro-orbit doen!
    // De micro-orbit TRIGGERT Fortnite's rotational assist via rotation gate
    // Dit is het ECHTE mechanisme: orbit → left stick velocity → Fortnite's rotational assist!

    // Bereken engagement strength op basis van proximity + lock quality
    // Dit schaalt de INTENSITEIT van de orbit, niet of het actief is
    bubble_weight_factor = ((zone_weight_ultra * 100) / 100) +
                          ((zone_weight_close * 70) / 100) +
                          ((zone_weight_mid * 40) / 100) +
                          ((zone_weight_far * 15) / 100);

    assist_engagement_signal = ((bubble_weight_factor * 50) / 100) +
                               ((lock_strength * 50) / 100);

    if(assist_engagement_signal > 100) assist_engagement_signal = 100;

    // Minimum 40% engagement (maar dit wordt later ge-boosted naar 90% voor rotation gate!)
    if(assist_engagement_signal < 40) assist_engagement_signal = 40;

    // === STAP 2: MICRO-ORBIT GENERATION ===
    // Kleine circulaire beweging OM de target heen (blijft IN bubble!)

    // TIMED INCREMENT: dynamic interval met jitter voor natuurlijke variatie
    micro_orbit_timer = micro_orbit_timer - 4;
    if(micro_orbit_timer <= 0){
        micro_orbit_index = micro_orbit_index + micro_orbit_direction;
        if(micro_orbit_index >= 16){
            micro_orbit_index = 0;
        }
        if(micro_orbit_index < 0){
            micro_orbit_index = 15;
        }
        micro_orbit_timer = micro_orbit_interval_ms;
        if(micro_orbit_timer < 4) micro_orbit_timer = 4;
    }

    micro_orbit_variation_timer = micro_orbit_variation_timer - 4;
    if(micro_orbit_variation_timer <= 0){
        g_val = clamp_i(slider_smoothness, 0, 100);
        g_temp = clamp_i(lock_confidence, 0, 100);
        g_total = 8 + (g_val * 8) / 100;
        g_expected = (g_temp * 6) / 100;
        g_total = g_total - g_expected;
        if(g_total < 6) g_total = 6;
        if(g_total > 18) g_total = 18;

        g_chars = clamp_i(100 - slider_smoothness, 0, 100);
        g_p = clamp_i(100 - lock_confidence, 0, 100);
        g_fill = 1 + (g_chars / 35) + (g_p / 40);
        if(enemy_speed_mag > 70){
            g_total = g_total - 1;
            if(g_total < 5) g_total = 5;
            g_fill = g_fill + 1;
        }
        if(g_fill > 4) g_fill = 4;

        micro_orbit_interval_ms = clamp_i(g_total + waveform_rand_signed(g_fill), 5, 20);

        g_expected = 20 + (g_p / 3) + (g_chars / 4);
        if(g_expected > 60) g_expected = 60;
        if(waveform_rand_range(0, 99) < g_expected){
            micro_orbit_direction = 0 - micro_orbit_direction;
            if(micro_orbit_direction == 0) micro_orbit_direction = 1;
        }

        micro_orbit_variation_timer = 24 + (g_val * 12) / 100;
    }

    // Radius op basis van proximity
    // bubble_weight_factor is al berekend hierboven (lijnen 772-775)
    micro_orbit_radius = MICRO_ORBIT_BASE +
                        (((MICRO_ORBIT_MAX - MICRO_ORBIT_BASE) * bubble_weight_factor) / 100);

    // === HARDCODED VALUES (DRIFT-FREE!) ===
    if(current_range == 0) g_val = slider_close;
    else if(current_range == 1) g_val = slider_medium;
    else g_val = slider_far;

    if(ads) {
        g_expected = apply_drift_free_scaling(100, slider_ads_strength);
    } else {
        g_expected = apply_drift_free_scaling(100, slider_hip_strength);
    }
    g_expected = apply_drift_free_scaling(g_expected, g_val);

    if(g_expected > 200) g_expected = 200;  // Clamp max
    if(g_expected < 0) g_expected = 0;      // Clamp min

    // Apply multiplier to orbit radius
    micro_orbit_radius = (micro_orbit_radius * g_expected) / 100;
    micro_orbit_radius = (micro_orbit_radius * weapon_gain_rotation_mix) / 100;

    g_total = clamp_i(lock_confidence, 0, 100);
    g_val = 80 + (g_total * 40) / 100;
    micro_orbit_radius = (micro_orbit_radius * g_val) / 100;

    g_temp = clamp_i(enemy_speed_mag, 0, 160);
    g_expected = 120 - (g_temp * 20) / 160;
    if(g_expected < 60) g_expected = 60;
    micro_orbit_radius = (micro_orbit_radius * g_expected) / 100;

    if(micro_orbit_radius < 4) micro_orbit_radius = 4;

    // Direct gebruik van index (0-15) - GEEN integer division drift!
    g_temp = micro_orbit_index;

    // 16-POINT CIRCLE LOOKUP (22.5° increments) - SMOOTH!
    if(g_temp == 0){        // 0° = right
        virtual_strafe_x = micro_orbit_radius;
        virtual_strafe_y = 0;
    }
    else if(g_temp == 1){   // 22.5°
        virtual_strafe_x = (micro_orbit_radius * 92) / 100;
        virtual_strafe_y = (micro_orbit_radius * 38) / 100;
    }
    else if(g_temp == 2){   // 45°
        virtual_strafe_x = (micro_orbit_radius * 71) / 100;
        virtual_strafe_y = (micro_orbit_radius * 71) / 100;
    }
    else if(g_temp == 3){   // 67.5°
        virtual_strafe_x = (micro_orbit_radius * 38) / 100;
        virtual_strafe_y = (micro_orbit_radius * 92) / 100;
    }
    else if(g_temp == 4){   // 90° = up
        virtual_strafe_x = 0;
        virtual_strafe_y = micro_orbit_radius;
    }
    else if(g_temp == 5){   // 112.5°
        virtual_strafe_x = 0 - ((micro_orbit_radius * 38) / 100);
        virtual_strafe_y = (micro_orbit_radius * 92) / 100;
    }
    else if(g_temp == 6){   // 135°
        virtual_strafe_x = 0 - ((micro_orbit_radius * 71) / 100);
        virtual_strafe_y = (micro_orbit_radius * 71) / 100;
    }
    else if(g_temp == 7){   // 157.5°
        virtual_strafe_x = 0 - ((micro_orbit_radius * 92) / 100);
        virtual_strafe_y = (micro_orbit_radius * 38) / 100;
    }
    else if(g_temp == 8){   // 180° = left
        virtual_strafe_x = 0 - micro_orbit_radius;
        virtual_strafe_y = 0;
    }
    else if(g_temp == 9){   // 202.5°
        virtual_strafe_x = 0 - ((micro_orbit_radius * 92) / 100);
        virtual_strafe_y = 0 - ((micro_orbit_radius * 38) / 100);
    }
    else if(g_temp == 10){  // 225°
        virtual_strafe_x = 0 - ((micro_orbit_radius * 71) / 100);
        virtual_strafe_y = 0 - ((micro_orbit_radius * 71) / 100);
    }
    else if(g_temp == 11){  // 247.5°
        virtual_strafe_x = 0 - ((micro_orbit_radius * 38) / 100);
        virtual_strafe_y = 0 - ((micro_orbit_radius * 92) / 100);
    }
    else if(g_temp == 12){  // 270° = down
        virtual_strafe_x = 0;
        virtual_strafe_y = 0 - micro_orbit_radius;
    }
    else if(g_temp == 13){  // 292.5°
        virtual_strafe_x = (micro_orbit_radius * 38) / 100;
        virtual_strafe_y = 0 - ((micro_orbit_radius * 92) / 100);
    }
    else if(g_temp == 14){  // 315°
        virtual_strafe_x = (micro_orbit_radius * 71) / 100;
        virtual_strafe_y = 0 - ((micro_orbit_radius * 71) / 100);
    }
    else {                  // 337.5°
        virtual_strafe_x = (micro_orbit_radius * 92) / 100;
        virtual_strafe_y = 0 - ((micro_orbit_radius * 38) / 100);
    }

    // === STAP 3: ROTATION GATE GUARANTEE ===
    // Magnetic multiplier is AL toegepast in radius berekening (regel 823)!
    // GEEN extra scaling meer - anders dubbel effect!

    // ROTATION GATE GUARANTEE: minimum 11 units voor rotation_active!
    g_total = abs(virtual_strafe_x) + abs(virtual_strafe_y);

    if(g_total > 0 && g_total < 11){
        // Boost naar 11 units (>10 gate threshold)
        virtual_strafe_x = (virtual_strafe_x * 11) / g_total;
        virtual_strafe_y = (virtual_strafe_y * 11) / g_total;
    }

    // === STAP 4: VERTICAL CLAMP (PREVENT GROUND-PULL BUG!) ===
    if(virtual_strafe_y > VERTICAL_CLAMP_MAX) virtual_strafe_y = VERTICAL_CLAMP_MAX;
    if(virtual_strafe_y < -VERTICAL_CLAMP_MAX) virtual_strafe_y = -VERTICAL_CLAMP_MAX;

    // Final caps
    if(virtual_strafe_x > 15) virtual_strafe_x = 15;
    if(virtual_strafe_x < -15) virtual_strafe_x = -15;
}

// ============== DRIFT-FREE SCALING (REDESIGNED!) ==============
// CRITICAL: Slider 50 = 100% (NEUTRAL - preserves base values!)
// 0 = 0%, 50 = 100%, 100 = 200%
// This prevents drift: both ADS and hipfire scale RELATIVE to tuned bases

// ============== DRIFT-FREE SCALING (REDESIGNED!) ==============
// CRITICAL: Slider 50 = 100% (NEUTRAL - preserves base values!)
// 0 = 0%, 50 = 100%, 100 = 200%
// This prevents drift: both ADS and hipfire scale RELATIVE to tuned bases

int apply_drift_free_scaling(int base, int slider_val){
    if(slider_val == 0) return 0;  // Disabled

    // Slider 50 = 100% (neutral!)
    if(slider_val <= 50){
        g_val = slider_val * 2;  // 0→50 maps to 0→100%
    }
    else {
        g_val = 100 + ((slider_val - 50) * 2);  // 51→100 maps to 102→200%
    }

    return (base * g_val) / 100;
}

void waveform_seed(int seed){
    if(seed == 0) seed = 1;
    waveform_rng_state = seed & 0x7FFF;
    if(waveform_rng_state == 0) waveform_rng_state = 12345;
}

int waveform_rand(){
    waveform_rng_state = (waveform_rng_state * 214013 + 2531011) & 0x7FFF;
    return waveform_rng_state;
}

int waveform_rand_range(int min_val, int max_val){
    if(max_val <= min_val) return min_val;
    // Gebruik globals g_total (span) en g_fill (rnd) i.v.m. GPC beperkingen
    g_total = max_val - min_val + 1; // span
    g_fill = waveform_rand() % g_total; // rnd
    return min_val + g_fill;
}

int waveform_rand_signed(int range_val){
    if(range_val <= 0) return 0;
    return waveform_rand_range(0, range_val * 2) - range_val;
}

void update_weapon_profile_detection(){
    weapon_detect_score[WEAPON_PROFILE_AR] = 45;
    weapon_detect_score[WEAPON_PROFILE_ONESHOT] = 12;
    weapon_detect_score[WEAPON_PROFILE_SNIPER] = 12;

    if(ads){
        weapon_detect_score[WEAPON_PROFILE_AR] = weapon_detect_score[WEAPON_PROFILE_AR] + 20;
        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 10;
    }
    if(oneshot_mode){
        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 55;
    }
    if(sniper_mode){
        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 60;
    }
    if(hipfire_sticky_active){
        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 18;
    }
    if(aerial_mode){
        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 12;
        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 8;
    }
    if(hyper_burst_active){
        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 10;
    }
    if(distance_pixels >= BUBBLE_ZONE_FAR){
        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 12;
    } else if(distance_pixels <= BUBBLE_ZONE_CLOSE){
        weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 10;
    }

    if(shot_interval > 0){
        if(shot_interval <= WEAPON_AR_TIME){
            weapon_detect_score[WEAPON_PROFILE_AR] = weapon_detect_score[WEAPON_PROFILE_AR] + 22;
        } else if(shot_interval >= WEAPON_SNIPER_TIME){
            weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 22;
        } else if(shot_interval >= WEAPON_SHOTGUN_TIME){
            weapon_detect_score[WEAPON_PROFILE_ONESHOT] = weapon_detect_score[WEAPON_PROFILE_ONESHOT] + 24;
        }
    }

    if(ads && shot_timer > 0 && shot_timer <= WEAPON_QUICK_SCOPE){
        weapon_detect_score[WEAPON_PROFILE_SNIPER] = weapon_detect_score[WEAPON_PROFILE_SNIPER] + 15;
    }

    g_total = 0;
    while(g_total < WEAPON_PROFILE_COUNT){
        weapon_detect_score[g_total] = clamp_i(weapon_detect_score[g_total], 0, 100);
        weapon_profile_confidence[g_total] = smooth_gain(weapon_profile_confidence[g_total], weapon_detect_score[g_total], 30);
        g_total = g_total + 1;
    }

    g_val = weapon_profile_target;
    if(g_val < 0 || g_val >= WEAPON_PROFILE_COUNT){
        g_val = WEAPON_PROFILE_AR;
    }
    g_temp = weapon_profile_confidence[g_val];

    g_total = 0;
    while(g_total < WEAPON_PROFILE_COUNT){
        if(weapon_profile_confidence[g_total] > g_temp + 6){
            g_val = g_total;
            g_temp = weapon_profile_confidence[g_total];
        }
        g_total = g_total + 1;
    }

    weapon_profile_target = g_val;
}

// Diagnostics functions removed to save memory for Titan Two

int get_zone_slider_value(int zone){
    if(zone <= 1) return slider_close;
    if(zone == 2) return slider_medium;
    return slider_far;
}

void update_sticky_edge_weight(){
    if(sticky_edge_flip_timer > 0){
        sticky_edge_flip_timer = sticky_edge_flip_timer - delta;
        if(sticky_edge_flip_timer < 0) sticky_edge_flip_timer = 0;
    }
    if(sticky_edge_timer > 0 && !sticky_edge_active){
        sticky_edge_timer = sticky_edge_timer - delta;
        if(sticky_edge_timer < 0) sticky_edge_timer = 0;
    }

    sticky_edge_weight = 0;
    if(distance_pixels > bubble_zone_edges[4] + STICKY_EDGE_MARGIN){
        sticky_edge_recent_sign = 0;
        if(sticky_edge_flip_timer == 0){
            sticky_edge_flip_count = 0;
        }
        sticky_edge_active = 0;
        sticky_edge_boost = 0;
        sticky_edge_snap_boost = 0;
        return;
    }

    g_temp = 0;
    while(g_temp < 5){
        g_val = bubble_zone_edges[g_temp];
        g_p = distance_pixels - g_val;
        if(g_p < 0) g_p = 0 - g_p;
        if(g_p <= STICKY_EDGE_MARGIN){
            sticky_edge_weight = 100 - ((g_p * 100) / STICKY_EDGE_MARGIN);
            break;
        }
        g_temp = g_temp + 1;
    }

    if(sticky_edge_weight == 0 && distance_pixels <= STICKY_EDGE_MARGIN){
        sticky_edge_weight = 100 - ((distance_pixels * 100) / STICKY_EDGE_MARGIN);
    }
    if(sticky_edge_weight < 0) sticky_edge_weight = 0;
    if(sticky_edge_weight > 100) sticky_edge_weight = 100;

    g_expected = 0; // current_sign
    if(distance_delta > 1) g_expected = 1;
    else if(distance_delta < -1) g_expected = -1;

    if(sticky_edge_weight >= 50 && g_expected != 0){
        if(g_expected != sticky_edge_recent_sign){
            if(sticky_edge_flip_timer == 0){
                sticky_edge_flip_count = 1;
            } else {
                sticky_edge_flip_count = sticky_edge_flip_count + 1;
                if(sticky_edge_flip_count > 4) sticky_edge_flip_count = 4;
            }
            sticky_edge_flip_timer = 140;
            sticky_edge_recent_sign = g_expected;
        } else if(sticky_edge_flip_timer == 0){
            sticky_edge_flip_count = clamp_i(sticky_edge_flip_count - 1, 0, 4);
        }
    } else if(sticky_edge_weight < 25){
        if(sticky_edge_flip_timer == 0){
            sticky_edge_flip_count = 0;
            sticky_edge_recent_sign = 0;
        }
    }

    if(sticky_edge_flip_timer == 0 && sticky_edge_flip_count > 0){
        sticky_edge_flip_count = clamp_i(sticky_edge_flip_count - 1, 0, 4);
    }

    if(sticky_edge_weight >= 55 && sticky_edge_flip_count >= 2){
        sticky_edge_active = 1;
    } else {
        sticky_edge_active = 0;
    }
    if(sticky_edge_active){
        sticky_edge_timer = sticky_edge_timer + delta;
        if(sticky_edge_timer > 220) sticky_edge_timer = 220;
    }

    g_tboost = 0; // ramp_pct
    if(sticky_edge_timer > 0){
        g_tboost = (sticky_edge_timer * 100) / 160;
        if(g_tboost > 100) g_tboost = 100;
    }

    g_val = 30 + (sticky_edge_flip_count * 12); // flip_scale, using g_val
    sticky_edge_boost = (sticky_edge_weight * g_val * g_tboost) / 10000;
    sticky_edge_boost = clamp_i(sticky_edge_boost, 12, 60);

    g_temp = 40 + (sticky_edge_flip_count * 15); // snap_scale, using g_temp
    sticky_edge_snap_boost = (sticky_edge_weight * g_temp * g_tboost) / 10000;
    sticky_edge_snap_boost = clamp_i(sticky_edge_snap_boost, 10, 70);

    if(!sticky_edge_active){
        sticky_edge_boost = (sticky_edge_weight * STICKY_EDGE_GAIN) / 120;
        sticky_edge_snap_boost = (sticky_edge_weight * STICKY_EDGE_SNAP_GAIN) / 120;
    }
}

// ============== INPUT VELOCITY TRACKER (ADAPTIVE!) ==============
// Measure how fast USER is moving stick (not Fortnite's output!)
// Fast input = corrections → disable resistance (vrije beweging)
// Slow input = tracking → enable resistance (sticky)
void update_input_velocity(){
    // Re-read FRESH rx/ry values to ensure current frame data
    g_val = get_val(AXIS_RX);
    g_temp = get_val(AXIS_RY);

    // Apply deadzone
    if(abs(g_val) < DEADZONE_BASE) g_val = 0;
    if(abs(g_temp) < DEADZONE_BASE) g_temp = 0;

    // Calculate raw input delta (absolute change per frame)
    input_velocity = abs(g_val - prev_rx) + abs(g_temp - prev_ry);

    // Store current for next frame
    prev_rx = g_val;
    prev_ry = g_temp;

    if(input_velocity >= FREEDOM_RELEASE_THRESHOLD){
        freedom_release_timer = FREEDOM_RELEASE_RECOVER;
    }

    if(freedom_release_timer > 0){
        freedom_release_timer = freedom_release_timer - delta;
        if(freedom_release_timer < 0) freedom_release_timer = 0;
    }

    if(freedom_release_timer > 0){
        freedom_release_active = 1;
    } else {
        freedom_release_active = 0;
    }
    if(freedom_release_active){
        freedom_release_target = 100;
    } else {
        freedom_release_target = 0;
    }

    // 🚨 PANIC MODE: Instant disable at extreme speeds (360 flicks, super-fast tracking)
    if(input_velocity >= INPUT_VELOCITY_PANIC){
        resistance_active = 0;  // FULL DISABLE - zero interference!
        return;
    }

    // CRITICAL: Only allow resistance INSIDE bubble when locked!
    // This prevents "magnetic repulsion" during target acquisition
    // Check BOTH lock status AND true pixel distance (not processed stick values!)
    if(!target_locked || distance_pixels > STICK_RESISTANCE_THRESHOLD){
        resistance_active = 0;  // FORCE DISABLE outside bubble!
        return;
    }

    // Additional safety: if we somehow got here with large distance, force disable
    if(distance_pixels > 20){
        resistance_active = 0;
        return;
    }

    // ✅ DUAL-THRESHOLD HYSTERESIS (Architect approved!)
    // ENABLE threshold (low) vs DISABLE threshold (also low) creates smooth buffer
    // FAST thresholds for instant override
    g_val = INPUT_VELOCITY_ENABLE_HIP;      // 15 units - enable assist
    g_temp = INPUT_VELOCITY_DISABLE_HIP;    // 8 units - disable assist
    g_tboost = INPUT_VELOCITY_FAST_HIP;     // 65 units - instant disable

    if(ads){
        g_val = INPUT_VELOCITY_ENABLE_ADS;   // 20 units
        g_temp = INPUT_VELOCITY_DISABLE_ADS; // 12 units
        g_tboost = INPUT_VELOCITY_FAST_ADS;  // 70 units
    }

    // Check for FAST movement first - instant disable
    if(input_velocity >= g_tboost){
        velocity_hysteresis_active = 0;
        resistance_active = 0;
        return;
    }

    // Hysteresis state machine
    if(velocity_hysteresis_active){
        // Currently active - disable if velocity drops BELOW disable threshold
        if(input_velocity < g_temp){
            velocity_hysteresis_active = 0;
            resistance_active = 0;
        }
        else {
            resistance_active = 1;  // Keep active
        }
    }
    else {
        // Currently disabled - enable if velocity drops BELOW enable threshold
        if(input_velocity < g_val){
            velocity_hysteresis_active = 1;
            resistance_active = 1;
        }
    }
}

// ============== ROTATION PULSE CORE (PRIMARY MAGNETIC!) ==============
// Dit is de KERN: left-stick bursts triggeren Fortnite's rotation assist
// Slider controls: 0=OFF, slider scaling 0-200%
void calculate_pulse_magnitude(){
    pulse_magnitude = 0;
    rotation_mag_offset = 0;

    if(ads) {
        g_temp = apply_drift_free_scaling(2, slider_ads_strength);
    } else {
        g_temp = apply_drift_free_scaling(2, slider_hip_strength);
    }

    pulse_magnitude = g_temp;
    if(pulse_magnitude > 0){
        pulse_magnitude = (pulse_magnitude * weapon_gain_rotation_mix) / 100;
    }
    if(pulse_magnitude < 1) pulse_magnitude = 1;
    if(pulse_magnitude > 6) pulse_magnitude = 6;

    if(pulse_magnitude > 0){
        g_val = clamp_i(100 - slider_smoothness, 0, 100); // jitter_scale
        g_temp = clamp_i(100 - lock_confidence, 0, 100);  // lock_gap
        g_val = (g_val * g_temp) / 100;
        if(g_val > 0){
            g_p = (ROTATION_MAG_JITTER * (25 + g_val)) / 100; // mag_window
            if(g_p < 1 && g_val > 15) g_p = 1;
            if(g_p > 3) g_p = 3;
            rotation_mag_offset = waveform_rand_signed(g_p);
            if(rotation_mag_offset != 0){
                pulse_magnitude = pulse_magnitude + rotation_mag_offset;
                if(pulse_magnitude < 1) pulse_magnitude = 1;
                if(pulse_magnitude > 6) pulse_magnitude = 6;
            }
        }
    }

    if(input_velocity > 20) {
        pulse_magnitude = 0;
        rotation_mag_offset = 0;
    }

    if(input_velocity >= INPUT_VELOCITY_PANIC){
        pulse_magnitude = 0;
        rotation_mag_offset = 0;
        return;
    }

    if(!resistance_active){
        pulse_magnitude = pulse_magnitude / 2;
        if(pulse_magnitude < 1) pulse_magnitude = 1;
    }
}

// ============== CIRCULAR MAGNETIC AIM (AGGRESSIVE!) ==============
// LEFT-STICK circular movements = constant rotational assist!
// GEEN tegensturen - triggert Fortnite's native assist via movement
void update_rotation_pulse(){
    rotation_pulse_lx = 0;
    rotation_pulse_ly = 0;

    if(!(subsystem_flags & SUBSYSTEM_ROTATION)){
        rotation_pulse_timer = 0;
        return;
    }

    // CORE GATES (strict but simple)
    // 1. Target must be locked (bubble active)
    if(!target_locked) {
        rotation_pulse_timer = 0;  // Reset timer on lock loss
        return;
    }

    // 2. Lock confidence must be high enough
    if(lock_strength < ROTATION_PULSE_LOCK_MIN) {
        rotation_pulse_timer = 0;
        return;
    }

    // 3. Pulse magnitude check
    if(pulse_magnitude == 0) {
        return;
    }

    // 4. Not in build/edit mode
    if(build_mode || edit_mode) {
        return;
    }

    // 5. ✅ STRAFE GATE (v4.3 ADS OPTIMIZED!)
    // ADS krijgt VOLLEDIGE rotation zonder strafe vereiste!
    // Hipfire blijft reduced voor balans
    if(!ads){
        // Hipfire: reduced rotation pulse (30% kracht voor balans)
        pulse_magnitude = (pulse_magnitude * 30) / 100;
    }
    // ADS: GEEN reductie meer - volle kracht voor sticky tracking!

    // ALL GATES PASSED - pulse is active!

    // Timer management - SMOOTHNESS SLIDER CONTROL + jitter
    if(rotation_pulse_timer <= 0) {
        g_val = 50 + slider_smoothness;
        rotation_gap_dynamic = ROTATION_GAP_MAX - ((ROTATION_GAP_MAX - ROTATION_GAP_MIN) * clamp_i(lock_confidence, 0, 100)) / 100;
        if(rotation_gap_dynamic < ROTATION_GAP_MIN) rotation_gap_dynamic = ROTATION_GAP_MIN;
        g_temp = (g_val * 60 + rotation_gap_dynamic * 40) / 100;
        if(g_temp < ROTATION_GAP_MIN) g_temp = ROTATION_GAP_MIN;
        if(g_temp > ROTATION_GAP_MAX) g_temp = ROTATION_GAP_MAX;

        rotation_gap_current = g_temp;
        g_total = clamp_i(100 - slider_smoothness, 0, 100);
        g_chars = clamp_i(100 - lock_confidence, 0, 100);
        g_fill = (ROTATION_JITTER_MAX_MS * (g_total + g_chars)) / 200;
        if(enemy_speed_mag > 60){
            g_fill = g_fill + ((enemy_speed_mag - 60) * ROTATION_JITTER_MAX_MS) / 200;
        }
        if(g_fill > ROTATION_JITTER_MAX_MS) g_fill = ROTATION_JITTER_MAX_MS;
        if(g_fill < 0) g_fill = 0;
        if(g_fill < 1 && (g_total > 10 || g_chars > 10)){
            g_fill = 1;
        }
        if(g_fill > 0){
            rotation_gap_current = rotation_gap_current + waveform_rand_signed(g_fill);
            if(rotation_gap_current < ROTATION_GAP_MIN) rotation_gap_current = ROTATION_GAP_MIN;
            if(rotation_gap_current > ROTATION_GAP_MAX) rotation_gap_current = ROTATION_GAP_MAX;
        }

        rotation_jitter_interval = rotation_gap_current;
        rotation_jitter_timer = rotation_jitter_interval;

        rotation_pulse_angle = rotation_pulse_angle + 90;
        if(rotation_pulse_angle >= 360){
            rotation_pulse_angle = 0;
        }
        rotation_pulse_timer = rotation_gap_current;
    } else if(rotation_jitter_timer > 0){
        rotation_jitter_timer = rotation_jitter_timer - 4;
        if(rotation_jitter_timer < 0) rotation_jitter_timer = 0;
    }

    // Generate circular movement (AGGRESSIVE MAGNETIC!)
    // LEFT-STICK cirkels = constant rotational assist trigger
    if(rotation_pulse_angle == 0) {
        rotation_pulse_lx = 0 - pulse_magnitude;  // LEFT
        rotation_pulse_ly = 0;
    }
    else if(rotation_pulse_angle == 90) {
        rotation_pulse_lx = 0;
        rotation_pulse_ly = 0 - pulse_magnitude;  // UP
    }
    else if(rotation_pulse_angle == 180) {
        rotation_pulse_lx = pulse_magnitude;      // RIGHT
        rotation_pulse_ly = 0;
    }
    else {
        rotation_pulse_lx = 0;
        rotation_pulse_ly = pulse_magnitude;      // DOWN
    }

    if(enemy_speed_mag > 15 && lock_confidence > 40) {
        g_p = ads ? slider_ads_rotation : slider_hip_rotation;
        rotation_bias_x = (enemy_dir_x * g_p) / 400;
        rotation_bias_y = (enemy_dir_y * g_p) / 400;
        
        if(rotation_bias_x > 4) rotation_bias_x = 4;
        if(rotation_bias_x < -4) rotation_bias_x = -4;
        if(rotation_bias_y > 4) rotation_bias_y = 4;
        if(rotation_bias_y < -4) rotation_bias_y = -4;
        
        rotation_pulse_lx = rotation_pulse_lx + rotation_bias_x;
        if(rotation_pulse_lx > 6) rotation_pulse_lx = 6;
        if(rotation_pulse_lx < -6) rotation_pulse_lx = -6;
        
        rotation_pulse_ly = rotation_pulse_ly + rotation_bias_y;
        if(rotation_pulse_ly > 6) rotation_pulse_ly = 6;
        if(rotation_pulse_ly < -6) rotation_pulse_ly = -6;
    }

    // Count down timer
    rotation_pulse_timer = rotation_pulse_timer - 4;  // 4ms per frame
}

// ============== SAVE SLIDERS (TITAN TWO PMEM) =======================
void save_sliders(){
    pmem_write(0, slider_hip_strength);
    pmem_write(1, slider_hip_rotation);
    pmem_write(2, slider_ads_strength);
    pmem_write(3, slider_ads_rotation);
    pmem_write(4, slider_smoothness);
    pmem_write(5, slider_close);
    pmem_write(6, slider_medium);
    pmem_write(7, slider_far);
}

// ============== LOAD SLIDERS (TITAN TWO PMEM) =======================
void load_sliders(){
    pmem_read(0, &slider_hip_strength);
    pmem_read(1, &slider_hip_rotation);
    pmem_read(2, &slider_ads_strength);
    pmem_read(3, &slider_ads_rotation);
    pmem_read(4, &slider_smoothness);
    pmem_read(5, &slider_close);
    pmem_read(6, &slider_medium);
    pmem_read(7, &slider_far);
    
    // Set defaults if not initialized
    if(slider_hip_strength == 0 && slider_ads_strength == 0){
        slider_hip_strength = 50;
        slider_hip_rotation = 50;
        slider_ads_strength = 50;
        slider_ads_rotation = 50;
        slider_smoothness = 50;
        slider_close = 50;
        slider_medium = 50;
        slider_far = 50;
    }
}

