// ============ SIN/COS LOOKUP TABLES (16-POINT SMOOTH CIRCULAR MOTION) ===========
// Fixed-point integers scaled to 100 (100 = 1.0, -100 = -1.0)
// Prevents "hoekig" movement - architect approved!
int sinLUT[16];
int cosLUT[16];

// Hysteresis state tracking
int velocity_hysteresis_active;  // Track if velocity resistance is active
int panic_triggered;
int sticky_edge_weight;
